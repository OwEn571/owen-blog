/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 1.5rem
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: oklch(0.62 0.11 var(--hue)) oklch(0.78 0.08 var(--hue))
  --page-bg: oklch(0.985 0.004 240) oklch(0.19 0.012 250)
  --card-bg: rgba(255, 255, 255, 0.72) rgba(23, 25, 31, 0.82)
  --card-bg-transparent: rgba(255, 255, 255, 0.58) rgba(18, 20, 26, 0.68)
  --glass-border: rgba(15, 23, 42, 0.08) rgba(255, 255, 255, 0.08)
  --surface-highlight: rgba(255, 255, 255, 0.65) rgba(255, 255, 255, 0.04)

  --btn-content: oklch(0.46 0.07 var(--hue)) oklch(0.82 0.04 var(--hue))

  --btn-regular-bg: rgba(15, 23, 42, 0.05) rgba(255, 255, 255, 0.06)
  --btn-regular-bg-hover: rgba(15, 23, 42, 0.08) rgba(255, 255, 255, 0.1)
  --btn-regular-bg-active: rgba(15, 23, 42, 0.11) rgba(255, 255, 255, 0.14)

  --btn-plain-bg-hover: rgba(15, 23, 42, 0.05) rgba(255, 255, 255, 0.08)
  --btn-plain-bg-active: rgba(15, 23, 42, 0.08) rgba(255, 255, 255, 0.12)

  --btn-card-bg-hover: rgba(255, 255, 255, 0.86) rgba(255, 255, 255, 0.09)
  --btn-card-bg-active: rgba(255, 255, 255, 0.92) rgba(255, 255, 255, 0.13)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: oklch(0.22 0.015 var(--hue))

  --title-active: oklch(0.56 0.08 var(--hue))

  --line-divider: rgba(15, 23, 42, 0.08) rgba(255, 255, 255, 0.08)

  --line-color: rgba(15, 23, 42, 0.08) rgba(255, 255, 255, 0.08)
  --meta-divider: rgba(15, 23, 42, 0.18) rgba(255, 255, 255, 0.18)
  --content-meta: rgba(15, 23, 42, 0.66) rgba(255, 255, 255, 0.62)

  --inline-code-bg: var(--btn-regular-bg)
  --inline-code-color: var(--btn-content)
  --selection-bg: oklch(0.90 0.05 var(--hue)) oklch(0.40 0.08 var(--hue))
  --codeblock-selection: var(--selection-bg)
  --codeblock-bg: rgba(248, 250, 252, 0.92) oklch(0.17 0.012 var(--hue))
  --codeblock-topbar-bg: rgba(241, 245, 249, 0.92) oklch(0.13 0.012 var(--hue))

  --license-block-bg: black(0.03) var(--codeblock-bg)

  --link-underline: rgba(104, 140, 255, 0.16) rgba(104, 140, 255, 0.28)
  --link-hover: rgba(104, 140, 255, 0.2) rgba(104, 140, 255, 0.32)
  --link-active: rgba(104, 140, 255, 0.25) rgba(104, 140, 255, 0.38)

  --float-panel-bg: rgba(255, 255, 255, 0.74) rgba(18, 20, 26, 0.84)

  --scrollbar-bg-light: black(0.4)
  --scrollbar-bg-hover-light: black(0.5)
  --scrollbar-bg-active-light: black(0.6)

  --scrollbar-bg-dark: white(0.4)
  --scrollbar-bg-hover-dark: white(0.5)
  --scrollbar-bg-active-dark: white(0.6)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: oklch(0.7 0.14 180) oklch(0.75 0.14 180)
  --admonitions-color-note: oklch(0.7 0.14 250) oklch(0.75 0.14 250)
  --admonitions-color-important: oklch(0.7 0.14 310) oklch(0.75 0.14 310)
  --admonitions-color-warning: oklch(0.7 0.14 60) oklch(0.75 0.14 60)
  --admonitions-color-caution: oklch(0.6 0.2 25) oklch(0.65 0.2 25)

  --toc-badge-bg: rgba(104, 140, 255, 0.12) var(--btn-regular-bg)
  --toc-btn-hover: rgba(15, 23, 42, 0.05) rgba(255, 255, 255, 0.08)
  --toc-btn-active: rgba(15, 23, 42, 0.08) rgba(255, 255, 255, 0.12)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.70 0.13 var(--hue)) oklch(0.35 0.07 var(--hue))
})

/* 非全屏壁纸模式下，--card-bg-transparent 应该和 --card-bg 一致（不透明） */
body:not(.wallpaper-transparent)
  --card-bg-transparent: var(--card-bg)

/* 全屏壁纸模式下，--card-bg-transparent 使用真正的半透明值 */
body.wallpaper-transparent
  --card-bg-transparent: rgba(255, 255, 255, 0.8)

:root.dark body.wallpaper-transparent
  --card-bg-transparent: rgba(23, 23, 23, 0.8)
