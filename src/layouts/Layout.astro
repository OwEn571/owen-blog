---
import ConfigCarrier from "@components/misc/ConfigCarrier.astro";
import {
	profileConfig,
	siteConfig,
} from "@/config";

const BANNER_HEIGHT = 35;
const BANNER_HEIGHT_EXTEND = 30;
const BANNER_HEIGHT_HOME = BANNER_HEIGHT + BANNER_HEIGHT_EXTEND;

import { PAGE_WIDTH } from "../constants/constants";
import { pathsEqual, url } from "../utils/url-utils";
import "../styles/main.css";
import "../styles/mobile-navbar.css";
import "../styles/wallpaper-navbar-transparent.css";
import "../styles/fancybox-custom.css";
import "../styles/expressive-code.css";
import "../styles/panel-animations.css";

// 导入新提取的 Head 组件
import AnalyticsScripts from "./partials/AnalyticsScripts.astro";
import HeadTags from "./partials/HeadTags.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
	bodyClass?: string;
}

let { title, banner, description, lang, setOGTypeArticle, postSlug } =
	Astro.props;
const bodyClass = Astro.props.bodyClass;

// apply a class to the body element to decide the height of the banner, only used for initial page load
// Swup can update the body for each page visit, but it's after the page transition, causing a delay for banner height change
// so use Swup hooks instead to change the height immediately when a link is clicked
const isHomePage = pathsEqual(Astro.url.pathname, url("/"));

// defines global css variables
// why doing this in Layout instead of GlobalStyles: https://github.com/withastro/astro/issues/6728#issuecomment-1502203757
const configHue = siteConfig.themeColor.hue;

// 获取导航栏透明模式配置
const navbarTransparentMode =
	siteConfig.banner?.navbar?.transparentMode || "semi";

// 判断是否应该显示顶部高光效果（只在full和semifull模式下显示）
const shouldShowTopHighlight =
	navbarTransparentMode === "full" || navbarTransparentMode === "semifull";

// 获取默认banner图片的辅助函数
const getDefaultBanner = (): string => {
	const src = siteConfig.banner.src;
	if (typeof src === "string") {
		return src;
	}
	if (Array.isArray(src)) {
		return src[0] || "";
	}
	if (src && typeof src === "object") {
		// 优先使用desktop，如果没有则使用mobile
		const desktopSrc = src.desktop;
		const mobileSrc = src.mobile;
		if (typeof desktopSrc === "string") {
			return desktopSrc;
		}
		if (Array.isArray(desktopSrc) && desktopSrc.length > 0) {
			return desktopSrc[0];
		}
		if (typeof mobileSrc === "string") {
			return mobileSrc;
		}
		if (Array.isArray(mobileSrc) && mobileSrc.length > 0) {
			return mobileSrc[0];
		}
	}
	return "";
};

if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = getDefaultBanner();
}

// TODO don't use post cover as banner for now
banner = getDefaultBanner();

const enableBanner = !!siteConfig.banner.src;

let pageTitle: string;
if (title) {
	pageTitle = `${title} - ${siteConfig.title}`;
} else {
	pageTitle = siteConfig.subtitle
		? `${siteConfig.title} - ${siteConfig.subtitle}`
		: siteConfig.title;
}

let ogImageUrl: string | undefined;
if (siteConfig.generateOgImages && postSlug) {
	ogImageUrl = new URL(`/og/${postSlug}.png`, Astro.site).toString();
}

// const siteLang = siteConfig.lang.replace('_', '-')
if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset =
	bannerOffsetByPosition[siteConfig.banner.position || "center"];
const gtmId = import.meta.env.PUBLIC_GTM_ID || "";
const clarityId = import.meta.env.PUBLIC_CLARITY_ID || "";

// 构建字体配置的 CSS 变量
// ASCII 字体优先级最高（用于英文、数字等），CJK 字体作为回退
let bodyFontFamily = "";
if (siteConfig.font) {
	const fonts: string[] = [];
	// 先添加 ASCII 字体（优先级最高）
	if (siteConfig.font.asciiFont?.fontFamily) {
		const asciiFont = siteConfig.font.asciiFont.fontFamily;
		// 如果字体名包含空格，需要用引号包围
		fonts.push(asciiFont.includes(" ") ? `"${asciiFont}"` : asciiFont);
	}
	// 再添加 CJK 字体（作为回退）
	if (siteConfig.font.cjkFont?.fontFamily) {
		const cjkFont = siteConfig.font.cjkFont.fontFamily;
		// 如果字体名包含空格，需要用引号包围
		fonts.push(cjkFont.includes(" ") ? `"${cjkFont}"` : cjkFont);
	}
	// 添加系统字体作为最终回退
	fonts.push(
		"system-ui",
		"-apple-system",
		"BlinkMacSystemFont",
		"'Segoe UI'",
		"Roboto",
		"Oxygen",
		"Ubuntu",
		"Cantarell",
		"'Open Sans'",
		"'Helvetica Neue'",
		"sans-serif",
	);
	// 组合成完整的 font-family 字符串
	bodyFontFamily = fonts.join(", ");
}
---

<!doctype html>
<html
	lang={siteLang}
	class="bg-[var(--page-bg)] text-[14px] md:text-[16px]"
	data-overlayscrollbars-initialize
>
	<head>
		<!-- 第三方分析脚本 -->
		<AnalyticsScripts gtmId={gtmId} clarityId={clarityId} />

		<!-- SEO Meta Tags, Open Graph, Twitter Card, Favicons, Theme Init -->
		<HeadTags
			title={pageTitle}
			description={description}
			ogImageUrl={ogImageUrl}
			setOGTypeArticle={setOGTypeArticle}
			configHue={configHue}
		/>

		<!-- defines global css variables. This will be applied to <html> <body> and some other elements idk why -->
		<slot name="head" />

		<!-- Global CSS variables for page width and hue -->
		<style
			define:vars={{
				configHue,
				"page-width": `${PAGE_WIDTH}rem`,
			}}
		></style>

		<link
			rel="alternate"
			type="application/rss+xml"
			title={profileConfig.name}
			href={`${Astro.site}rss.xml`}
		/>
	</head>
	<body
		class="min-h-screen"
		class:list={[
			bodyClass,
			{ "lg:is-home": isHomePage, "enable-banner": enableBanner },
		]}
		style={bodyFontFamily ? `font-family: ${bodyFontFamily};` : ""}
		data-overlayscrollbars-initialize
	>
		{
			gtmId && (
				<noscript
					><iframe
						src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
						height="0"
						width="0"
						style="display:none;visibility:hidden"></iframe></noscript
				>
			)
		}
		<!-- 页面顶部渐变高光效果 - 只在full和semifull模式下显示 -->
		{shouldShowTopHighlight && <div class="top-gradient-highlight" />}

		<ConfigCarrier />
		<div
			id="theme-transition-overlay"
			class="theme-transition-overlay"
			data-state="idle"
			data-theme="dark"
			aria-hidden="true"
		>
			<div class="theme-transition-overlay__panel">
				<div class="theme-transition-overlay__orb" aria-hidden="true">
					<span class="theme-transition-overlay__sun">◐</span>
					<span class="theme-transition-overlay__moon">◓</span>
				</div>
				<p class="theme-transition-overlay__eyebrow">Theme Shift</p>
				<p class="theme-transition-overlay__title">正在切换昼夜氛围</p>
			</div>
		</div>
		<slot />
		<script
			is:inline
			define:vars={{ PYTHON_PLAYGROUND_URL: url("/scripts/python-playground.js") }}
		>
			(() => {
				const selector = "[data-python-playground], [data-python-code-card], [data-python-lab]";
				let loaded = false;

				const loadPlaygroundScript = () => {
					if (loaded || !document.querySelector(selector)) {
						return;
					}

					loaded = true;
					const script = document.createElement("script");
					script.src = PYTHON_PLAYGROUND_URL;
					document.body.appendChild(script);
				};

				loadPlaygroundScript();

				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", loadPlaygroundScript, {
						once: true,
					});
				}

			})();
		</script>
		<script is:inline>
			(() => {
				const cleanupImmersiveArtifacts = () => {
					const hasImmersiveRoot = !!document.querySelector("[data-immersive-ready-root]");

					if (hasImmersiveRoot) {
						document.body.classList.add("immersive-page");
						return;
					}

					if (!hasImmersiveRoot) {
						document.documentElement.classList.remove("immersive-preloading");
						document.body.classList.remove("immersive-preloading");
						document.body.classList.remove("immersive-page");
						document
							.querySelectorAll("[data-immersive-video-shell], [data-immersive-preload]")
							.forEach((node) => node.remove());
					}
				};

				const scheduleCleanup = () => {
					requestAnimationFrame(() => {
						requestAnimationFrame(cleanupImmersiveArtifacts);
					});
				};

				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", scheduleCleanup, {
						once: true,
					});
				} else {
					scheduleCleanup();
				}

				window.addEventListener("pageshow", scheduleCleanup);
			})();
		</script>
		<script is:inline>
			(() => {
				const overlay = document.getElementById("theme-transition-overlay");
				if (!(overlay instanceof HTMLElement)) {
					return;
				}

				let hideTimer = 0;
				let safetyTimer = 0;
				const setTheme = (dark) => {
					overlay.dataset.theme = dark ? "dark" : "light";
				};
				const resetTransitionState = () => {
					document.documentElement.classList.remove("is-theme-transitioning");
					overlay.dataset.state = "idle";
				};
				const scheduleSafetyReset = () => {
					window.clearTimeout(safetyTimer);
					safetyTimer = window.setTimeout(() => {
						resetTransitionState();
					}, 980);
				};

				setTheme(document.documentElement.classList.contains("dark"));
				resetTransitionState();

				window.addEventListener("owen:theme-transition", (event) => {
					const detail = event.detail || {};
					window.clearTimeout(hideTimer);
					setTheme(Boolean(detail.dark));

					if (detail.phase === "start") {
						overlay.dataset.state = "enter";
						scheduleSafetyReset();
						return;
					}

					overlay.dataset.state = "leave";
					hideTimer = window.setTimeout(() => {
						overlay.dataset.state = "idle";
					}, 340);
				});

				window.addEventListener("owen:theme-applied", (event) => {
					const detail = event.detail || {};
					setTheme(Boolean(detail.dark));
				});

				window.addEventListener("pageshow", resetTransitionState);
				window.addEventListener("load", resetTransitionState, { once: true });
				document.addEventListener("visibilitychange", () => {
					if (document.visibilityState === "visible") {
						resetTransitionState();
					}
				});
			})();
		</script>
		<script is:inline>
			(() => {
				if ((window).__owenControlFallbackBound) {
					return;
				}
				(window).__owenControlFallbackBound = true;

				const FLOAT_PANELS = [
					"display-setting",
					"nav-menu-panel",
					"search-panel",
					"mobile-toc-panel",
					"wallpaper-mode-panel",
				];

				const getFloatPanel = (panelId) => {
					const panel = document.getElementById(panelId);
					return panel instanceof HTMLElement ? panel : null;
				};

				const openFloatPanel = (panelId, exceptIds = []) => {
					FLOAT_PANELS.filter((id) => id !== panelId && !exceptIds.includes(id)).forEach(
						(id) => {
							const node = getFloatPanel(id);
							node?.classList.add("float-panel-closed");
							if (node) {
								node.style.opacity = "";
								node.style.transform = "";
								node.style.pointerEvents = "";
							}
						},
					);
					const panel = getFloatPanel(panelId);
					if (!panel) {
						return false;
					}
					panel.classList.remove("float-panel-closed");
					panel.style.opacity = "1";
					panel.style.transform = "scale(1) translateY(0)";
					panel.style.pointerEvents = "auto";
					return true;
				};

				const closeFloatPanel = (panelId) => {
					const panel = getFloatPanel(panelId);
					if (!panel) {
						return;
					}
					panel.classList.add("float-panel-closed");
					panel.style.opacity = "";
					panel.style.transform = "";
					panel.style.pointerEvents = "";
				};

				const toggleFloatPanel = (panelId, exceptIds = []) => {
					const panel = getFloatPanel(panelId);
					if (!panel) {
						return false;
					}
					const shouldOpen = panel.classList.contains("float-panel-closed");
					if (!shouldOpen) {
						closeFloatPanel(panelId);
						return false;
					}
					return openFloatPanel(panelId, exceptIds);
				};

				const setDesktopSearchExpanded = (open) => {
					const bar = document.getElementById("search-bar");
					const input = document.getElementById("search-input-desktop");
					const navbar = document.getElementById("navbar");
					if (!(bar instanceof HTMLElement) || !(input instanceof HTMLInputElement)) {
						return;
					}

					bar.dataset.fallbackExpanded = open ? "true" : "false";
					bar.classList.toggle("owen-search-expanded", open);
					bar.style.width = open ? "12rem" : "";
					input.style.width = open ? "9rem" : "";
					input.style.pointerEvents = open ? "auto" : "";

					if (open) {
						navbar?.classList.add("is-searching");
						window.setTimeout(() => input.focus(), 0);
						return;
					}

					if (!input.value) {
						navbar?.classList.remove("is-searching");
					}
				};

				const setPythonLabOpen = (open) => {
					const root = document.querySelector("[data-python-lab]");
					if (!(root instanceof HTMLElement)) {
						return;
					}
					const panel = root.querySelector("[data-python-lab-panel]");
					const toggle = root.querySelector("[data-python-lab-toggle]");
					const fallback = root.querySelector("[data-python-lab-fallback]");
					if (!(panel instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) {
						return;
					}

					if (open && typeof window.__owenEnsurePythonLabRuntime === "function") {
						window.__owenEnsurePythonLabRuntime();
					}

					panel.hidden = !open;
					root.dataset.state = open ? "open" : "closed";
					toggle.setAttribute("aria-expanded", open ? "true" : "false");
					if (open) {
						root.style.zIndex = "70";
						if (fallback instanceof HTMLTextAreaElement) {
							window.setTimeout(() => fallback.focus(), 0);
						}
						if (typeof window.__owenBootstrapPythonLabFallback === "function") {
							window.__owenBootstrapPythonLabFallback(true);
						}
						return;
					}
					if (typeof window.__owenBootstrapPythonLabFallback === "function") {
						window.__owenBootstrapPythonLabFallback(false);
					}
					root.style.zIndex = "";
				};

				const toggleControl = (control) => {
					switch (control) {
						case "desktop-search":
							setDesktopSearchExpanded(true);
							return;
						case "python-lab": {
							const root = document.querySelector("[data-python-lab]");
							const isOpen =
								root instanceof HTMLElement && root.dataset.state === "open";
							setPythonLabOpen(!isOpen);
							return;
						}
						default:
							toggleFloatPanel(control);
					}
				};

				window.__owenToggleFloatPanel = toggleFloatPanel;
				window.__owenOpenDesktopSearch = () => setDesktopSearchExpanded(true);
				window.__owenCloseDesktopSearch = () => setDesktopSearchExpanded(false);
				window.__owenSetPythonLabOpen = setPythonLabOpen;
				window.__owenTogglePythonLab = () => toggleControl("python-lab");
				window.__owenApplyTheme = (theme) => {
					localStorage.setItem("theme", theme);
					const dark = theme === "dark";
					document.documentElement.classList.add("is-theme-transitioning");
					window.dispatchEvent(
						new CustomEvent("owen:theme-transition", {
							detail: { phase: "start", theme, dark },
						}),
					);

					window.setTimeout(() => {
						document.documentElement.classList.toggle("dark", dark);
						document.documentElement.setAttribute(
							"data-theme",
							dark ? "github-dark" : "github-light",
						);
						window.dispatchEvent(
							new CustomEvent("owen:theme-applied", {
								detail: { theme, dark },
							}),
						);
					}, 210);

					window.setTimeout(() => {
						document.documentElement.classList.remove("is-theme-transitioning");
						window.dispatchEvent(
							new CustomEvent("owen:theme-transition", {
								detail: { phase: "end", theme, dark },
							}),
						);
					}, 760);
				};
				window.__owenUiController = {
					openFloatPanel,
					closeFloatPanel,
					toggleFloatPanel,
					setDesktopSearchExpanded,
					setPythonLabOpen,
					applyTheme: window.__owenApplyTheme,
				};

				document.addEventListener(
					"click",
					(event) => {
						const target = event.target;
						if (!(target instanceof Element)) {
							return;
						}

						const closeControl = target.closest("[data-ui-control-close]");
						if (closeControl instanceof HTMLElement) {
							event.preventDefault();
							event.stopImmediatePropagation();
							if (closeControl.dataset.uiControlClose === "python-lab") {
								setPythonLabOpen(false);
							}
							return;
						}

						const control = target.closest("[data-ui-control]");
						if (control instanceof HTMLElement) {
							const panelId = control.dataset.uiControl;
							if (!panelId) {
								return;
							}
							event.preventDefault();
							event.stopImmediatePropagation();
							toggleControl(panelId);
						}
					},
					true,
				);

				document.addEventListener(
					"mousedown",
					(event) => {
						const target = event.target;
						if (!(target instanceof Element)) {
							return;
						}

						if (!target.closest("#search-bar, #search-panel, [data-ui-control='desktop-search'], [data-ui-control='search-panel']")) {
							setDesktopSearchExpanded(false);
							closeFloatPanel("search-panel");
						}

						if (!target.closest("#display-setting, [data-ui-control='display-setting']")) {
							closeFloatPanel("display-setting");
						}

						if (!target.closest("#nav-menu-panel, [data-ui-control='nav-menu-panel']")) {
							closeFloatPanel("nav-menu-panel");
						}

						if (!target.closest("#mobile-toc-panel, [data-ui-control='mobile-toc-panel']")) {
							closeFloatPanel("mobile-toc-panel");
						}

						if (!target.closest("#wallpaper-mode-panel, [data-ui-control='wallpaper-mode-panel']")) {
							closeFloatPanel("wallpaper-mode-panel");
						}

						if (!target.closest("[data-python-lab]")) {
							setPythonLabOpen(false);
						}
					},
					true,
				);

				document.addEventListener("keydown", (event) => {
					if (event.key !== "Escape") {
						return;
					}
					setDesktopSearchExpanded(false);
					FLOAT_PANELS.forEach((id) => closeFloatPanel(id));
					setPythonLabOpen(false);
				});
			})();
		</script>


		<!-- increase the page height during page transition to prevent the scrolling animation from jumping -->
		<div id="page-height-extend" class="hidden h-[300vh]"></div>
	</body>
</html>

<style
	is:global
	define:vars={{
		bannerOffset,
		"banner-height-home": `${BANNER_HEIGHT_HOME}vh`,
		"banner-height": `${BANNER_HEIGHT}vh`,
	}}
>
	@tailwind components;
	@layer components {
		.enable-banner.is-home #banner-wrapper {
			@apply h-[var(--banner-height-home)] translate-y-[var(--banner-height-extend)];
		}
		.enable-banner #banner-wrapper {
			@apply h-[var(--banner-height-home)];
		}
		.enable-banner.is-home #banner {
			@apply h-[var(--banner-height-home)] translate-y-0;
		}
		.enable-banner #banner {
			@apply h-[var(--banner-height-home)] translate-y-[var(--bannerOffset)];
		}
		.enable-banner.is-home #main-grid {
			@apply translate-y-[var(--banner-height-extend)];
		}
		.enable-banner #top-row {
			@apply h-[calc(var(--banner-height-home)_-_4.5rem)] transition-all duration-300;
		}
		.enable-banner.is-home #sidebar-sticky {
			@apply top-[calc(1rem_-_var(--banner-height-extend))];
		}
		.navbar-hidden {
			@apply opacity-0 -translate-y-16;
		}

		/* Water waves animation */
		.waves > .parallax use {
			animation: wave 25s cubic-bezier(0.5, 0.5, 0.45, 0.5) infinite;
		}
		@keyframes wave {
			0% {
				transform: translate3d(-90px, 0, 0);
			}
			100% {
				transform: translate3d(85px, 0, 0);
			}
		}
	}
</style>

<script>
	const bootPageRuntime = async () => {
		const runtime = await import("../scripts/page-runtime");
		await runtime.initPageRuntime();
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => {
			void bootPageRuntime();
		}, { once: true });
	} else {
		void bootPageRuntime();
	}
</script>

<!-- 代码块折叠功能 -->
<script>
	const loadCodeCollapse = async () => {
		if (!document.querySelector(".expressive-code")) {
			return;
		}

		await import("../scripts/code-collapse.js");
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => {
			void loadCodeCollapse();
		}, { once: true });
	} else {
		void loadCodeCollapse();
	}
</script>
