---
/**
 * AnalyticsScripts.astro
 * 第三方分析脚本组件 - 延迟加载优化
 *
 * 包含:
 * - Google Tag Manager (GTM)
 * - Microsoft Clarity
 *
 * 使用 requestIdleCallback 延迟加载以优化性能
 */

interface Props {
	gtmId?: string;
	clarityId?: string;
}

const {
	gtmId = import.meta.env.PUBLIC_GTM_ID || "",
	clarityId = import.meta.env.PUBLIC_CLARITY_ID || "",
} = Astro.props;
---

{
	(gtmId || clarityId) && (
		<script is:inline define:vars={{ gtmId, clarityId }}>
			window.analyticsLoaded = window.analyticsLoaded || false;

			function loadAnalytics() {
				if (window.analyticsLoaded) {
					return;
				}
				window.analyticsLoaded = true;

				if (gtmId) {
					(function (w, d, s, l, i) {
						w[l] = w[l] || [];
						w[l].push({
							"gtm.start": new Date().getTime(),
							event: "gtm.js",
						});
						const f = d.getElementsByTagName(s)[0];
						const j = d.createElement(s);
						const dl = l !== "dataLayer" ? "&l=" + l : "";
						j.async = true;
						j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
						f.parentNode.insertBefore(j, f);
					})(window, document, "script", "dataLayer", gtmId);
				}

				if (clarityId) {
					(function (c, l, a, r, i, t, y) {
						c[a] =
							c[a] ||
							function () {
								(c[a].q = c[a].q || []).push(arguments);
							};
						t = l.createElement(r);
						t.async = 1;
						t.src = "https://www.clarity.ms/tag/" + i;
						y = l.getElementsByTagName(r)[0];
						y.parentNode.insertBefore(t, y);
					})(window, document, "clarity", "script", clarityId);
				}
			}

			const deferAnalytics = () => {
				if ("requestIdleCallback" in window) {
					requestIdleCallback(loadAnalytics, { timeout: 4000 });
				} else {
					setTimeout(loadAnalytics, 4000);
				}
			};

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", deferAnalytics, {
					once: true,
				});
			} else {
				deferAnalytics();
			}
		</script>
	)
}
