---
import { profileConfig, siteConfig } from "@/config";

import "../styles/splash.css";
import HeadTags from "./partials/HeadTags.astro";

interface Props {
	title?: string;
	description?: string;
	lang?: string;
}

const { title, description, lang } = Astro.props;
const configHue = siteConfig.themeColor.hue;
const pageTitle = title
	? `${title} - ${siteConfig.title}`
	: siteConfig.subtitle
		? `${siteConfig.title} - ${siteConfig.subtitle}`
		: siteConfig.title;
const siteLang = (lang || siteConfig.lang).replace("_", "-");
---

<!doctype html>
<html lang={siteLang} data-overlayscrollbars-initialize>
	<head>
		<HeadTags
			title={pageTitle}
			description={description}
			configHue={configHue}
		/>
		<slot name="head" />
		<link
			rel="alternate"
			type="application/rss+xml"
			title={profileConfig.name}
			href={`${Astro.site}rss.xml`}
		/>
	</head>
	<body data-overlayscrollbars-initialize>
		<div
			id="theme-transition-overlay"
			class="theme-transition-overlay"
			data-state="idle"
			data-theme="dark"
			aria-hidden="true"
		>
			<div class="theme-transition-overlay__panel">
				<div class="theme-transition-overlay__orb" aria-hidden="true">
					<span class="theme-transition-overlay__sun">◐</span>
					<span class="theme-transition-overlay__moon">◓</span>
				</div>
				<p class="theme-transition-overlay__eyebrow">Theme Shift</p>
				<p class="theme-transition-overlay__title">正在切换昼夜氛围</p>
			</div>
		</div>
		<slot />
		<script is:inline>
			(() => {
				const overlay = document.getElementById("theme-transition-overlay");
				if (!(overlay instanceof HTMLElement)) {
					return;
				}

				let hideTimer = 0;
				const setTheme = (dark) => {
					overlay.dataset.theme = dark ? "dark" : "light";
				};

				setTheme(document.documentElement.classList.contains("dark"));

				window.addEventListener("owen:theme-transition", (event) => {
					const detail = event.detail || {};
					window.clearTimeout(hideTimer);
					setTheme(Boolean(detail.dark));
					if (detail.phase === "start") {
						overlay.dataset.state = "enter";
						return;
					}

					overlay.dataset.state = "leave";
					hideTimer = window.setTimeout(() => {
						overlay.dataset.state = "idle";
					}, 340);
				});

				window.addEventListener("owen:theme-applied", (event) => {
					const detail = event.detail || {};
					setTheme(Boolean(detail.dark));
				});
			})();
		</script>
	</body>
</html>
