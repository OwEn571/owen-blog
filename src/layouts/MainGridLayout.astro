---
import BackToTop from "@components/control/BackToTop.astro";
import FloatingPythonLab from "@components/control/FloatingPythonLab.astro";
import { FloatingTOC, SidebarTOC } from "@components/features/toc";
import Banner from "@components/layout/Banner.astro";
import RightSideBar from "@components/layout/RightSideBar.astro";
import SplashSelector from "@components/features/home/SplashSelector.astro";
import FullscreenWallpaper from "@components/misc/FullscreenWallpaper.astro";
import IconifyLoader from "@components/misc/IconifyLoader.astro";
import Footer from "@components/organisms/footer/Footer.astro";
import Navbar from "@components/organisms/navigation/Navbar.astro";
import SideBar from "@components/widgets/sidebar/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";

import {
	fullscreenWallpaperConfig,
	siteConfig,
} from "../config";
import {
	BANNER_HEIGHT,
} from "../constants/constants";
import {
	calculateGridLayout,
	getBannerImages,
	getMainPanelTop,
	getTransparencyClass,
	shouldEnableTransparency,
} from "../utils/grid-layout-utils";
import { widgetManager } from "../utils/widget-manager";
import Layout from "./Layout.astro";
import GridScripts from "./partials/GridScripts.astro";

// TOC模式配置
const tocMode = siteConfig.toc.mode || "float";
const isFloatTOC = tocMode === "float";
const isSidebarTOC = tocMode === "sidebar";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
	headings?: MarkdownHeading[];
	showSplash?: boolean;
	splashOnly?: boolean;
	immersiveLayout?: boolean;
}

// 获取 banner 图片
const bannerImages = await getBannerImages(siteConfig);

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	postSlug,
	headings = [],
	showSplash = false,
	splashOnly = false,
	immersiveLayout = false,
} = Astro.props;
const hasHeadings = headings.length > 0;
const hasBannerCredit = siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

// 检查是否为首页
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";
// 手机端非首页不显示banner的CSS类
const mobileNonHomeBannerClass = !isHomePage ? "mobile-hide-banner" : "";

// 计算主内容区域位置
const finalMainPanelTop = getMainPanelTop(
	siteConfig.wallpaperMode.defaultMode,
	BANNER_HEIGHT,
);

// 计算网格布局
const {
	gridCols,
	sidebarClass,
	rightSidebarClass,
	mainContentClass,
	sidebarPresence,
	mobileShowSidebar,
	tabletShowSidebar,
	desktopShowSidebar,
} = calculateGridLayout({
	siteConfig,
	widgetManager,
});

const {
	hasRightSidebarComponents,
	hasMobileDrawerComponents,
} = sidebarPresence;

const effectiveGridCols = immersiveLayout
	? "grid-cols-1 md:grid-cols-1 lg:grid-cols-1"
	: gridCols;
const effectiveMainContentClass = immersiveLayout
	? "transition-swup-fade overflow-visible w-full col-span-1 row-start-1 row-end-2 md:col-start-1 md:col-end-2 lg:col-start-1 lg:col-end-2"
	: mainContentClass;
const shouldRenderSidebars = !immersiveLayout;
const shouldRenderFloatTOC =
	siteConfig.toc.enable && isFloatTOC && !immersiveLayout && hasHeadings;
const shouldRenderSidebarTOC =
	siteConfig.toc.enable && isSidebarTOC && !immersiveLayout && hasHeadings;
const shouldRenderImmersiveFloatTOC =
	siteConfig.toc.enable && immersiveLayout && hasHeadings;
const shouldRenderImmersiveSidebarTOC =
	false;

// 半透明效果
const shouldEnable = shouldEnableTransparency(siteConfig.wallpaperMode.defaultMode);
const transparentClass = getTransparencyClass(shouldEnable);

// 布局模式
const defaultPostListLayout = siteConfig.postListLayout?.defaultMode || "list";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle} postSlug={postSlug} bodyClass={immersiveLayout ? "immersive-page" : undefined}>

<GridScripts
	navbarTransparentMode={siteConfig.banner?.navbar?.transparentMode || "semi"}
	defaultWallpaperMode={siteConfig.wallpaperMode.defaultMode}
	defaultPostListLayout={siteConfig.postListLayout?.defaultMode || "list"}
	BANNER_HEIGHT={BANNER_HEIGHT}
	pageScaling={siteConfig.pageScaling}
/>

<!-- 全屏壁纸 - 始终渲染，通过 JS 控制显示隐藏 -->
<FullscreenWallpaper config={fullscreenWallpaperConfig} />

<!-- 全局图标加载器 -->
<IconifyLoader />

<!-- Navbar -->
<slot slot="head" name="head"></slot>
{!splashOnly ? (
	immersiveLayout ? (
		<>
			<script is:inline>
				(() => {
					const applyImmersiveShell = () => {
						document.body.classList.add("immersive-page");
					};

					if (document.readyState === "loading") {
						document.addEventListener("DOMContentLoaded", applyImmersiveShell, { once: true });
					} else {
						applyImmersiveShell();
					}

					window.addEventListener(
						"pagehide",
						() => {
							document.body.classList.remove("immersive-page");
						},
						{ once: true },
					);

					window.addEventListener("pageshow", (event) => {
						if (event.persisted) {
							window.location.reload();
						}
					});
				})();
			</script>

			<div class="immersive-video-shell" data-immersive-video-shell aria-hidden="true">
				<video
					class="immersive-video"
					data-immersive-video
					autoplay
					muted
					loop
					playsinline
					preload="metadata"
					poster="/assets/opening/qidian-splash-poster.jpg"
					data-poster-dark="/assets/opening/qidian-splash-poster.jpg"
					data-poster-light="/assets/opening/sakura-field-day-poster.svg"
					disableRemotePlayback
				>
					<source data-src-dark="/assets/opening/qidian-splash.mp4" data-src-light="/assets/opening/sakura-field-day.mp4" type="video/mp4" />
				</video>
				<div class="immersive-video-overlay"></div>
			</div>

			<script is:inline>
				(() => {
					if (typeof window === "undefined") return;

					const shell = document.querySelector("[data-immersive-video-shell]");
					const video = shell?.querySelector("[data-immersive-video]");
					const videoSource = video?.querySelector("source");
					if (!shell || !(video instanceof HTMLVideoElement)) return;

					const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
					const mobileRenderQuery = window.matchMedia("(max-width: 820px), (pointer: coarse)");
					let resumeTimer = 0;
					let themeObserver;

					const resolveTheme = () =>
						document.documentElement.classList.contains("dark") ? "dark" : "light";

					const applyThemeVideo = () => {
						if (!(videoSource instanceof HTMLSourceElement)) {
							return;
						}

						const theme = resolveTheme();
						shell.dataset.theme = theme;
						const nextPoster =
							theme === "dark" ? video.dataset.posterDark : video.dataset.posterLight;
						if (nextPoster) {
							video.poster = nextPoster;
						}
						const nextSrc =
							theme === "dark" ? videoSource.dataset.srcDark : videoSource.dataset.srcLight;
						if (!nextSrc) {
							return;
						}

						if (videoSource.getAttribute("src") !== nextSrc) {
							videoSource.src = nextSrc;
							video.load();
						}
					};

					const tryPlayVideo = () => {
						video.play().catch(() => {});
					};

					const scheduleResume = (delay = 0) => {
						window.clearTimeout(resumeTimer);
						resumeTimer = window.setTimeout(() => {
							if (document.hidden || mediaQuery.matches) {
								return;
							}
							tryPlayVideo();
						}, delay);
					};

					const syncMotionPreference = () => {
						if (mediaQuery.matches) {
							shell.setAttribute("hidden", "");
							video.pause();
							return;
						}

						shell.removeAttribute("hidden");
						video.muted = true;
						video.defaultMuted = true;
						video.playsInline = true;
						video.setAttribute("muted", "");
						video.setAttribute("playsinline", "");

						if (video.readyState >= 2) {
							scheduleResume(mobileRenderQuery.matches ? 120 : 0);
						} else {
							video.addEventListener("canplay", () => {
								scheduleResume(mobileRenderQuery.matches ? 120 : 0);
							}, { once: true });
						}
					};

					applyThemeVideo();
					syncMotionPreference();
					themeObserver = new MutationObserver(() => {
						applyThemeVideo();
						if (!document.hidden && !mediaQuery.matches) {
							scheduleResume(mobileRenderQuery.matches ? 120 : 0);
						}
					});
					themeObserver.observe(document.documentElement, {
						attributes: true,
						attributeFilter: ["class"],
					});
					window.addEventListener("owen:theme-applied", applyThemeVideo);
					mediaQuery.addEventListener?.("change", syncMotionPreference);
					mobileRenderQuery.addEventListener?.("change", syncMotionPreference);

					document.addEventListener("visibilitychange", () => {
						if (document.hidden) {
							video.pause();
						} else {
							syncMotionPreference();
						}
					});

					window.addEventListener(
						"pagehide",
						() => {
							themeObserver?.disconnect?.();
							window.removeEventListener("owen:theme-applied", applyThemeVideo);
							window.clearTimeout(resumeTimer);
							video.pause();
						},
						{ once: true },
					);
				})();
			</script>

			<script is:inline>
				(() => {
					if (typeof window === "undefined") return;
					const gateWindow = window;

					const bindImmersiveReadyGate = () => {
						const root = document.querySelector("[data-immersive-ready-root]");
						const overlay = document.querySelector("[data-immersive-preload]");
						if (!(root instanceof HTMLElement) || !(overlay instanceof HTMLElement)) {
							return;
						}

						const status = overlay.querySelector("[data-immersive-preload-status]");
						let runId = 0;
						let timeoutId = 0;

						const lock = () => {
							document.documentElement.classList.add("immersive-preloading");
							document.body.classList.add("immersive-preloading");
						};

						const unlock = () => {
							document.documentElement.classList.remove("immersive-preloading");
							document.body.classList.remove("immersive-preloading");
						};

						const waitForWindowLoad = () =>
							new Promise((resolve) => {
								if (document.readyState === "complete") {
									resolve(undefined);
									return;
								}

								const finish = () => resolve(undefined);
								window.addEventListener("load", finish, { once: true });
								window.setTimeout(finish, 12000);
							});

						const armGate = () => {
								runId += 1;
								const currentRun = runId;
								window.clearTimeout(timeoutId);
								root.dataset.readyState = "loading";
								overlay.dataset.state = "loading";
								lock();
								document.dispatchEvent(new CustomEvent("immersive:loading"));

								const images = Array.from(root.querySelectorAll("img")).filter(
									(node) => node instanceof HTMLImageElement,
								);
								const embeds = Array.from(
									root.querySelectorAll("iframe, video"),
								).filter(
									(node) =>
										node instanceof HTMLIFrameElement ||
										node instanceof HTMLVideoElement,
								);
								const backgroundVideo = document.querySelector("[data-immersive-video]");
								const total = images.length + embeds.length + (backgroundVideo instanceof HTMLVideoElement ? 1 : 0);
								let settled = 0;

								const updateStatus = () => {
									if (!(status instanceof HTMLElement)) {
									return;
								}
								status.textContent =
									total > 0
										? `正在准备页面内容 ${Math.min(settled, total)}/${total}`
										: "正在准备页面内容";
							};

							const finalize = () => {
									if (currentRun !== runId) {
										return;
									}
									root.dataset.readyState = "ready";
									overlay.dataset.state = "done";
									unlock();
									document.dispatchEvent(new CustomEvent("immersive:ready"));
								};

								const settleOne = (resolve) => {
									settled += 1;
									updateStatus();
									resolve();
								};

								const waitForImage = (image, index) =>
									new Promise((resolve) => {
										let isSettled = false;
										const done = () => {
											if (isSettled) return;
											isSettled = true;
											settleOne(resolve);
										};

										if (!(image instanceof HTMLImageElement)) {
											done();
											return;
										}

										image.loading = "eager";
										image.decoding = "async";
										if (index < 8) {
											image.fetchPriority = "high";
										}

										const finishAfterDecode = () => {
											if (typeof image.decode === "function") {
												image.decode().catch(() => {}).finally(done);
												return;
											}
											done();
										};

										if (image.complete && image.naturalWidth > 0) {
											finishAfterDecode();
											return;
										}

										image.addEventListener("load", finishAfterDecode, { once: true });
										image.addEventListener("error", done, { once: true });
									});

								const waitForEmbed = (embed) =>
									new Promise((resolve) => {
										let isSettled = false;
										const done = () => {
											if (isSettled) return;
											isSettled = true;
											settleOne(resolve);
										};
										if (embed instanceof HTMLIFrameElement) {
											embed.loading = "eager";
											embed.addEventListener("load", done, { once: true });
											embed.addEventListener("error", done, { once: true });
											window.setTimeout(done, 2500);
											return;
										}

										if (!(embed instanceof HTMLVideoElement)) {
											done();
											return;
										}

										embed.preload = "auto";
										if (embed.readyState >= 2) {
											done();
											return;
										}
										embed.addEventListener("loadeddata", done, { once: true });
										embed.addEventListener("canplay", done, { once: true });
										embed.addEventListener("error", done, { once: true });
										window.setTimeout(done, 2500);
									});

								updateStatus();

								const fontReady =
									document.fonts && "ready" in document.fonts
										? document.fonts.ready.catch(() => {})
										: Promise.resolve();
								const backgroundVideoReady =
									backgroundVideo instanceof HTMLVideoElement
										? waitForEmbed(backgroundVideo)
										: Promise.resolve();

								Promise.all([
									waitForWindowLoad(),
									fontReady,
									...images.map((image, index) => waitForImage(image, index)),
									...embeds.map((embed) => waitForEmbed(embed)),
									backgroundVideoReady,
								]).then(() => {
									requestAnimationFrame(() => {
										requestAnimationFrame(finalize);
									});
								});

							timeoutId = window.setTimeout(finalize, 26000);
						};

						if (!gateWindow.__owenBlogImmersiveReadyGateBound) {
							gateWindow.__owenBlogImmersiveReadyGateBound = true;
							window.addEventListener("pageshow", armGate);
							window.addEventListener(
								"pagehide",
								() => {
									window.clearTimeout(timeoutId);
									unlock();
								},
								{ once: true },
							);
						}

						armGate();
					};

					if (document.readyState === "loading") {
						document.addEventListener("DOMContentLoaded", bindImmersiveReadyGate, {
							once: true,
						});
					} else {
						bindImmersiveReadyGate();
					}
				})();
			</script>

			<div class="immersive-preload-overlay" data-immersive-preload data-state="loading" aria-live="polite" aria-busy="true">
				<div class="immersive-preload-panel">
					<div class="immersive-preload-spinner" aria-hidden="true"></div>
					<p class="immersive-preload-title">Preparing Experience</p>
					<p class="immersive-preload-copy" data-immersive-preload-status>
						正在准备页面内容
					</p>
				</div>
			</div>

			<div data-immersive-ready-root class="immersive-ready-root" data-ready-state="loading">
				<div id="top-row" class="z-50 relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto">
					<div id="navbar-wrapper" class="sticky top-0 transition-all">
						<Navbar class="immersive-navbar-shell"></Navbar>
					</div>
				</div>

				<div class="relative z-30 w-full">
					<div class="mx-auto max-w-[var(--page-width)] px-2 md:px-4">
						<main id="swup-container" class="transition-main w-full">
							<div id="content-wrapper" class="transition-leaving immersive-content-shell">
								<slot></slot>
								<div class="footer onload-animation pt-6">
									<Footer></Footer>
								</div>
							</div>
						</main>
					</div>
				</div>

				<div class="floating-utility-rail">
					<FloatingPythonLab />
					{shouldRenderImmersiveFloatTOC && <FloatingTOC fallbackForSidebar={isSidebarTOC} />}
					<BackToTop></BackToTop>
				</div>
				{shouldRenderImmersiveSidebarTOC && (
					<div class="absolute inset-x-0 top-0 z-20 hidden 2xl:block pointer-events-none">
						<div class="relative max-w-[var(--page-width)] mx-auto px-2 md:px-4">
							<div
								id="toc-wrapper"
								class="hidden lg:block absolute top-0 w-[var(--toc-width)] -right-[var(--toc-width)] pointer-events-none"
							>
								<div
									id="toc-inner-wrapper"
									class="fixed top-24 w-[var(--toc-width)] max-h-[calc(100vh_-_12rem)] overflow-hidden pointer-events-none"
								>
									<div id="toc-container" class="w-full transition-swup-fade pointer-events-auto">
										<SidebarTOC headings={headings}></SidebarTOC>
									</div>
								</div>
							</div>
						</div>
					</div>
				)}
				{(!siteConfig.toc.enable || !hasHeadings || shouldRenderImmersiveFloatTOC) && (
					<div id="toc-container" class="hidden"></div>
				)}
			</div>
		</>
	) : (
		<>
			<div id="top-row" class="z-50 relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto" class:list={[""]}>
				<div id="navbar-wrapper" class="sticky top-0 transition-all">
					<Navbar></Navbar>
				</div>
			</div>

			<Banner
				bannerImages={bannerImages}
				mobileNonHomeBannerClass={mobileNonHomeBannerClass}
			/>

			<div class={`absolute w-full z-30 ${mobileNonHomeBannerClass ? 'mobile-main-no-banner' : ''} ${siteConfig.wallpaperMode.defaultMode === 'none' ? 'no-banner-layout' : ''} ${transparentClass}`} style={`top: ${finalMainPanelTop}`}>
				<div class="relative max-w-[var(--page-width)] mx-auto">
					<div id="main-grid" class={`transition duration-700 w-full left-0 right-0 grid ${effectiveGridCols} grid-rows-none md:grid-rows-[auto] mx-auto gap-4 px-2 md:px-4 ${!mobileShowSidebar || !hasMobileDrawerComponents ? 'mobile-no-sidebar' : ''} ${hasRightSidebarComponents ? 'mobile-both-sidebar' : ''}`}
						 data-layout-mode={defaultPostListLayout}
					>
						{hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
										   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
										   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
						>
							<Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
							<div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
							<Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
								{"group-hover:opacity-100": hasBannerLink}]}
								  name="fa7-solid:arrow-up-right-from-square">
							</Icon>
						</a>}

						<div class="contents">
							{shouldRenderSidebars && (mobileShowSidebar || tabletShowSidebar || desktopShowSidebar) && (
								<SideBar class={`${sidebarClass} ${transparentClass}`} headings={headings}></SideBar>
							)}

							{shouldRenderSidebars && hasRightSidebarComponents && (
								<div class={`right-sidebar-container ${rightSidebarClass} ${transparentClass}`}>
									<RightSideBar headings={headings}></RightSideBar>
								</div>
							)}
						</div>

						<main id="swup-container" class={`${effectiveMainContentClass} transition-main`}>
							<div id="content-wrapper" class="onload-animation transition-leaving">
								<slot></slot>
								<div class="footer col-span-full onload-animation hidden lg:block">
									<Footer></Footer>
								</div>
							</div>
						</main>

						<div class="footer col-span-full onload-animation block lg:hidden">
							<Footer></Footer>
						</div>
					</div>

					<div class="floating-utility-rail">
						<FloatingPythonLab />
						{shouldRenderFloatTOC && <FloatingTOC />}
						<BackToTop></BackToTop>
					</div>
				</div>
			</div>

			{shouldRenderSidebarTOC && (
				<div class="absolute w-full z-0 hidden 2xl:block">
					<div class="relative max-w-[var(--page-width)] mx-auto">
						<div id="toc-wrapper" class:list={["hidden lg:block transition absolute top-0 w-[var(--toc-width)] items-center",
							"-right-[var(--toc-width)]",
							{"toc-hide": siteConfig.wallpaperMode.defaultMode === "banner"}]}
						>
							<div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] max-h-[calc(100vh_-_10rem)] overflow-hidden pointer-events-none">
								<div id="toc-container" class="w-full transition-swup-fade pointer-events-auto">
									<SidebarTOC headings={headings}></SidebarTOC>
								</div>
							</div>
						</div>
					</div>
				</div>
			)}

			{(!siteConfig.toc.enable || isFloatTOC || immersiveLayout || !hasHeadings) && <div id="toc-container" class="hidden"></div>}
		</>
	)
) : (
	<main id="swup-container" class="transition-main min-h-screen">
		<div id="content-wrapper" class="min-h-screen">
			{showSplash && <SplashSelector />}
		</div>
	</main>
)}
{showSplash && !splashOnly && <SplashSelector />}
</Layout>

<!--
  Banner 和网格布局样式已提取到 src/styles/banner.css
  该文件通过 src/styles/main.css 导入
-->
