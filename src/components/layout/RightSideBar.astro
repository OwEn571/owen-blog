---
import type { MarkdownHeading } from "astro";

import { SidebarTOC } from "@/components/features/toc";
import Announcement from "@/components/widgets/announcement/Announcement.astro";
import Calendar from "@/components/widgets/calendar/Calendar.astro";
import Categories from "@/components/widgets/categories/Categories.astro";
import Profile from "@/components/widgets/profile/Profile.astro";
import SiteStats from "@/components/widgets/site-stats/SiteStats.astro";
import Tags from "@/components/widgets/tags/Tags.astro";
import { widgetManager } from "@/utils/widget-manager";
import { buildComponentProps } from "@/utils/widget-renderer";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const { class: className, headings } = Astro.props;

// иҺ·еҸ–еҸідҫ§иҫ№ж Ҹзҡ„з»„д»¶еҲ—иЎЁ
const topComponents = widgetManager.getComponentsByPosition("top", "right");
const stickyComponents = widgetManager.getComponentsByPosition(
	"sticky",
	"right",
);

// з»„д»¶жҳ е°„иЎЁ
const componentMap: Record<string, unknown> = {
	profile: Profile,
	announcement: Announcement,
	categories: Categories,
	tags: Tags,
	toc: SidebarTOC,
	"site-stats": SiteStats,
	calendar: Calendar,
};

// жёІжҹ“з»„д»¶зҡ„иҫ…еҠ©еҮҪж•°
 
function renderComponent(component: WidgetComponentConfig, index: number, _components: WidgetComponentConfig[]) {
	const ComponentToRender = componentMap[component.type] as any;
	if (!ComponentToRender) {return null;}

	const props = buildComponentProps(component, index, headings);

	return {
		Component: ComponentToRender,
		props,
	};
}

type WidgetComponentConfig = ReturnType<typeof widgetManager.getComponentsByPosition>[number];
---

<div id="right-sidebar" class:list={[className, "w-full"]}>
  <!-- йЎ¶йғЁеӣәе®ҡз»„д»¶еҢәеҹҹ -->
  {
    topComponents.length > 0 && (
      <div class="flex flex-col w-full gap-4 mb-4">
        {topComponents.map((component, index) => {
          const renderData = renderComponent(component, index, topComponents);
          if (!renderData) {return null;}

          const { Component, props } = renderData;
          return <Component {...props} />;
        })}
      </div>
    )
  }

  <!-- зІҳжҖ§з»„д»¶еҢәеҹҹ -->
  {
    stickyComponents.length > 0 && (
      <div
        id="right-sidebar-sticky"
        class="transition-all duration-700 flex flex-col w-full gap-4 sticky top-4"
      >
        {stickyComponents.map((component, index) => {
          const renderData = renderComponent(
            component,
            index,
            stickyComponents
          );
          if (!renderData) {return null;}

          const { Component, props } = renderData;
          return <Component {...props} />;
        })}
      </div>
    )
  }
</div>

<!-- е“Қеә”ејҸж ·ејҸе’ҢJavaScript -->
<style>
  /* е“Қеә”ејҸж–ӯзӮ№ж ·ејҸ */
  @media (max-width: 768px) {
    #right-sidebar {
      display: var(--sidebar-mobile-display, block);
    }
  }
  @media (min-width: 769px) and (max-width: 1280px) {
    #right-sidebar {
      display: var(--sidebar-tablet-display, block);
    }
  }
  @media (min-width: 1281px) {
    #right-sidebar {
      display: var(--sidebar-desktop-display, block);
    }
  }
</style>

<script>
  import { widgetManager } from "../../utils/widget-manager";

  // е“Қеә”ејҸеёғеұҖз®ЎзҗҶ
  class RightSidebarManager {
    constructor() {
      this.init();
    }
    
    init() {
      this.updateResponsiveDisplay();
      if (!window.__owenBlogRightSidebarResizeHandler) {
        window.__owenBlogRightSidebarResizeHandler = () => this.updateResponsiveDisplay();
        window.addEventListener('resize', window.__owenBlogRightSidebarResizeHandler);
      }

    }
    
    updateResponsiveDisplay() {
      const breakpoints = widgetManager.getBreakpoints();
      const width = window.innerWidth;
      
      let deviceType: 'mobile' | 'tablet' | 'desktop';
      if (width < breakpoints.mobile) {
        deviceType = 'mobile';
      } else if (width < breakpoints.tablet) {
        deviceType = 'tablet';
      } else {
        deviceType = 'desktop';
      }
      
      const shouldShow = widgetManager.shouldShowSidebar(deviceType);
      const sidebar = document.getElementById('right-sidebar');
      
      if (sidebar) {
        sidebar.style.setProperty(
          `--sidebar-${deviceType}-display`, 
          shouldShow ? 'block' : 'none'
        );
      }
    }
  }
  
  // еҲқе§ӢеҢ–еҸідҫ§иҫ№ж Ҹз®ЎзҗҶеҷЁ
  if (!window.__owenBlogRightSidebarManagerInitialized) {
    window.__owenBlogRightSidebarManagerInitialized = true;
    new RightSidebarManager();
  }
</script>
