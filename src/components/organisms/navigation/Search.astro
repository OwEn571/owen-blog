---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";
---

<div class="hidden lg:block relative z-[1200] w-11 h-11 shrink-0 overflow-visible pointer-events-auto" id="desktop-search-host">
	<button
		type="button"
		id="search-switch-desktop"
		class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90"
		aria-label="Search"
	>
		<Icon name="material-symbols:search" class="text-[1.25rem]" />
	</button>
</div>

<button
	aria-label="Search Panel"
	id="search-switch"
	class="btn-plain scale-animation lg:!hidden rounded-lg w-11 h-11 active:scale-90"
>
	<Icon name="material-symbols:search" class="text-[1.25rem]" />
</button>

<div
	id="search-panel"
	data-ui-panel="search-panel"
	class="float-panel float-panel-closed fixed top-20 left-4 right-4 md:left-auto md:w-[30rem] lg:w-[24rem] md:right-4 z-[1300] search-panel shadow-2xl rounded-2xl p-2"
>
	<div id="search-bar-inside" class="owen-search-inside">
		<Icon name="material-symbols:search" class="owen-search-inside__icon text-[1.25rem]" />
		<input
			id="search-input-panel"
			placeholder={i18n(I18nKey.search)}
			class="owen-search-inside__input"
			type="search"
			autocomplete="off"
		/>
	</div>
	<div id="search-results" class="owen-search-results"></div>
</div>

<style>
	.owen-search-inside {
		position: relative;
		display: flex;
		align-items: center;
		height: 2.75rem;
		border-radius: 0.9rem;
		background: color-mix(in srgb, var(--card-bg) 92%, transparent);
	}

	.owen-search-inside__icon {
		position: absolute;
		left: 0.9rem;
		color: var(--text-secondary);
		pointer-events: none;
	}

	.owen-search-inside__input {
		width: 100%;
		height: 100%;
		padding: 0 0.95rem 0 2.6rem;
		border: none;
		outline: none;
		background: transparent;
		color: var(--text-normal);
	}

	.owen-search-results {
		display: grid;
		gap: 0.55rem;
		margin-top: 0.55rem;
	}

	.owen-search-results__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.1rem 0.15rem 0.35rem;
	}

	.owen-search-results__summary {
		font-size: 0.75rem;
		font-weight: 630;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--text-secondary) 82%, transparent);
	}

	.owen-search-results__count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.8rem;
		height: 1.8rem;
		padding: 0 0.55rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--primary) 14%, transparent);
		background: color-mix(in srgb, var(--primary) 9%, transparent);
		color: var(--primary);
		font-size: 0.78rem;
		font-weight: 680;
	}

	.owen-search-result {
		display: block;
		padding: 0.82rem 0.9rem;
		border-radius: 1rem;
		border: 1px solid color-mix(in srgb, var(--primary) 10%, transparent);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--card-bg) 92%, rgba(255, 255, 255, 0.08)), color-mix(in srgb, var(--card-bg) 82%, transparent)),
			radial-gradient(circle at top right, color-mix(in srgb, var(--primary) 10%, transparent), transparent 68%);
		text-decoration: none;
		transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
	}

	.owen-search-result:hover,
	.owen-search-result:focus-visible {
		transform: translateY(-1px);
		border-color: color-mix(in srgb, var(--primary) 18%, transparent);
		box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
	}

	.owen-search-result__title {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-weight: 700;
		color: var(--text-normal);
	}

	.owen-search-result__meta {
		margin-top: 0.22rem;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.72rem;
		font-weight: 620;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-secondary);
		opacity: 0.76;
	}

	.owen-search-result__meta::before {
		content: "";
		width: 0.42rem;
		height: 0.42rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--primary) 28%, transparent);
	}

	.owen-search-result__excerpt {
		margin-top: 0.32rem;
		font-size: 0.9rem;
		line-height: 1.65;
		color: var(--text-secondary);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.owen-search-highlight {
		padding: 0 0.22rem;
		border-radius: 0.35rem;
		background: color-mix(in srgb, var(--primary) 18%, transparent);
		color: var(--text-normal);
		box-decoration-break: clone;
		-webkit-box-decoration-break: clone;
	}

	.owen-search-empty {
		padding: 0.95rem;
		border-radius: 1rem;
		color: var(--text-secondary);
		background: color-mix(in srgb, var(--card-bg) 84%, transparent);
		text-align: center;
		font-size: 0.9rem;
	}

	.owen-search-empty strong {
		display: block;
		margin-bottom: 0.24rem;
		color: var(--text-normal);
		font-size: 0.92rem;
		font-weight: 650;
	}
</style>

	<script is:inline define:vars={{ rootUrl: url("/") }}>
	(() => {
		const desktopTrigger = document.getElementById("search-switch-desktop");
		const mobileTrigger = document.getElementById("search-switch");
		const panelInput = document.getElementById("search-input-panel");
		const panel = document.getElementById("search-panel");
		const results = document.getElementById("search-results");

		if (
			!(desktopTrigger instanceof HTMLButtonElement) ||
			!(mobileTrigger instanceof HTMLButtonElement) ||
			!(panelInput instanceof HTMLInputElement) ||
			!(panel instanceof HTMLElement) ||
			!(results instanceof HTMLElement)
		) {
			return;
		}

		if (panel.parentElement !== document.body) {
			document.body.appendChild(panel);
		}

		let keyword = "";
		let debounceTimer = 0;

		const fakeResults = [
			{
				url: rootUrl,
				title: "Search preview is only available after build",
				excerpt: "开发模式下这里会显示模拟结果，线上会使用 Pagefind。",
				parentTitle: "",
			},
		];

		const escapeHtml = (value) =>
			value
				.replaceAll("&", "&amp;")
				.replaceAll("<", "&lt;")
				.replaceAll(">", "&gt;")
				.replaceAll('"', "&quot;")
				.replaceAll("'", "&#39;");

		const stripHtml = (value) =>
			String(value || "")
				.replace(/<mark[^>]*>/gi, "")
				.replace(/<\/mark>/gi, "")
				.replace(/<[^>]+>/g, " ")
				.replace(/\s+/g, " ")
				.trim();

		const escapeRegExp = (value) =>
			value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

		const getQueryTokens = (value) => {
			const normalized = String(value || "").trim();
			if (!normalized) {
				return [];
			}

			const parts = normalized
				.split(/\s+/)
				.map((item) => item.trim())
				.filter(Boolean);
			const tokens = normalized.length > 1 ? [normalized, ...parts] : parts;
			return Array.from(new Set(tokens)).sort((left, right) => right.length - left.length);
		};

		const highlightQuery = (value, query) => {
			const plain = stripHtml(value);
			if (!plain) {
				return "";
			}

			let html = escapeHtml(plain);
			for (const token of getQueryTokens(query)) {
				if (!token) {
					continue;
				}
				const pattern = new RegExp(escapeRegExp(escapeHtml(token)), "gi");
				html = html.replace(
					pattern,
					(match) => `<mark class="owen-search-highlight">${match}</mark>`,
				);
			}
			return html;
		};

		const containsPhrase = (value, query) =>
			stripHtml(value).toLocaleLowerCase().includes(String(query || "").trim().toLocaleLowerCase());

		const showPanel = () => {
			panel.classList.remove("float-panel-closed");
			panel.style.opacity = "1";
			panel.style.transform = "translateY(0)";
			panel.style.pointerEvents = "auto";
		};

		const hidePanel = () => {
			panel.classList.add("float-panel-closed");
			panel.style.opacity = "";
			panel.style.transform = "";
			panel.style.pointerEvents = "";
		};

		const renderIdleState = (shouldOpen = true) => {
			results.innerHTML = `
				<div class="owen-search-empty">
					<strong>开始搜索</strong>
					<div>支持标题、正文、目录锚点，以及代码块中的注释与示例内容。</div>
				</div>
			`;
			if (shouldOpen) {
				showPanel();
			}
		};

		const renderResults = (items) => {
			if (!items.length) {
				results.innerHTML = '<div class="owen-search-empty">没有找到匹配内容</div>';
				showPanel();
				return;
			}

			results.innerHTML = `
				<div class="owen-search-results__header">
					<div class="owen-search-results__summary">Search Results</div>
					<div class="owen-search-results__count">${items.length}</div>
				</div>
				${items
					.map(
						(item) => `
						<a class="owen-search-result" href="${item.url}" data-no-swup>
							<div class="owen-search-result__title">
								<span>${highlightQuery(item.title, keyword)}</span>
								<span aria-hidden="true">›</span>
							</div>
							${item.parentTitle ? `<div class="owen-search-result__meta">${highlightQuery(item.parentTitle, keyword)}</div>` : ""}
							<div class="owen-search-result__excerpt">${highlightQuery(item.excerpt, keyword)}</div>
						</a>
					`,
					)
					.join("")}
			`;
			showPanel();
		};

		const buildSearchItems = (entries, query) => {
			const rawItems = entries.flatMap((entry) => {
				const parentTitle = entry.meta?.title || "Untitled";
				const subResults = Array.isArray(entry.sub_results) ? entry.sub_results : [];
				const anchoredItems = subResults
					.filter((item) => typeof item?.url === "string" && item.url)
					.slice(0, 4)
					.map((item) => {
						const sectionTitle =
							typeof item.title === "string" && item.title.trim()
								? item.title.trim()
								: parentTitle;
						const isNested = sectionTitle !== parentTitle;
						return {
							url: item.url,
							title: sectionTitle,
							parentTitle: isNested ? parentTitle : "",
							excerpt: stripHtml(item.excerpt || entry.excerpt || ""),
						};
					});

				if (anchoredItems.length) {
					return anchoredItems;
				}

				return [
					{
						url: entry.url,
						title: parentTitle,
						parentTitle: "",
						excerpt: stripHtml(entry.excerpt || ""),
					},
				];
			});

			const deduped = [];
			const seen = new Set();
			for (const item of rawItems) {
				const key = `${item.url}::${item.title}`;
				if (seen.has(key)) {
					continue;
				}
				seen.add(key);
				const phraseInTitle = containsPhrase(item.title, query);
				const phraseInExcerpt = containsPhrase(item.excerpt, query);
				const phraseInParent = containsPhrase(item.parentTitle, query);
				deduped.push({
					...item,
					relevance:
						(phraseInTitle ? 0 : 10) +
						(phraseInExcerpt ? 1 : 10) +
						(phraseInParent ? 2 : 10),
				});
			}

			const exactMatches = deduped.filter(
				(item) =>
					containsPhrase(item.title, query) ||
					containsPhrase(item.excerpt, query) ||
					containsPhrase(item.parentTitle, query),
			);
			const finalItems = exactMatches.length ? exactMatches : deduped;
			return finalItems.sort((left, right) => left.relevance - right.relevance).slice(0, 8);
		};

		const performSearch = async (nextKeyword) => {
			keyword = nextKeyword.trim();
			panelInput.value = keyword;

			if (!keyword) {
				renderIdleState();
				return;
			}

			if (location.hostname === "localhost" || location.hostname === "127.0.0.1") {
				renderResults(fakeResults);
				return;
			}

			const pagefind = window.pagefind;
			if (!pagefind || typeof pagefind.search !== "function") {
				renderResults([]);
				return;
			}

			try {
				const response = await pagefind.search(keyword);
				const entries = await Promise.all(response.results.map((item) => item.data()));
				renderResults(buildSearchItems(entries, keyword));
			} catch (error) {
				console.error("Search error:", error);
				renderResults([]);
			}
		};

		const scheduleSearch = (value) => {
			window.clearTimeout(debounceTimer);
			debounceTimer = window.setTimeout(() => {
				performSearch(value);
			}, 220);
		};

		const toggleDesktopSearch = (event) => {
			event.preventDefault();
			event.stopPropagation();
			if (!panel.classList.contains("float-panel-closed")) {
				hidePanel();
				return;
			}
			showPanel();
			window.setTimeout(() => {
				panelInput.focus();
				panelInput.select();
			}, 0);
			if (keyword) {
				showPanel();
			} else {
				renderIdleState();
			}
		};

		const toggleMobileSearch = (event) => {
			event.preventDefault();
			event.stopPropagation();
			const shouldOpen = panel.classList.contains("float-panel-closed");
			if (shouldOpen) {
				showPanel();
				window.setTimeout(() => panelInput.focus(), 0);
				if (keyword) {
					scheduleSearch(keyword);
				} else {
					renderIdleState();
				}
			} else {
				hidePanel();
			}
		};

		desktopTrigger.addEventListener("click", toggleDesktopSearch);
		mobileTrigger.addEventListener("click", toggleMobileSearch);

		panelInput.addEventListener("input", (event) => {
			scheduleSearch(event.currentTarget.value);
		});

		panelInput.addEventListener("keydown", (event) => {
			if (event.key === "Escape") {
				hidePanel();
			}
		});

		renderIdleState(false);

		document.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Node)) {
				return;
			}

			if (
				desktopTrigger.contains(target) ||
				panel.contains(target) ||
				(target instanceof Element && target.closest("#search-switch"))
			) {
				return;
			}

			hidePanel();
		});
	})();
</script>
