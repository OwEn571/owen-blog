---
export interface Props {
	text: string | string[];
	speed?: number;
	deleteSpeed?: number;
	pauseTime?: number;
	showCaret?: boolean;
	class?: string;
}

const {
	text,
	speed = 100,
	deleteSpeed = 50,
	pauseTime = 2000,
	showCaret = true,
	class: className = "",
} = Astro.props;
const textData = Array.isArray(text) ? JSON.stringify(text) : text;
const fallbackText = Array.isArray(text) ? (text[0] ?? "") : text;
---

<span
	class={`typewriter ${className}`.trim()}
	data-text={textData}
	data-speed={speed}
	data-delete-speed={deleteSpeed}
	data-pause-time={pauseTime}
	data-show-caret={showCaret ? "true" : "false"}
>{fallbackText}</span>

<script is:inline>
	(() => {
		const typewriterWindow = window;

		class TypewriterEffect {
			constructor(element) {
				this.element = element;
				const textData = element.dataset.text || "";

				try {
					const parsed = JSON.parse(textData);
					this.texts = Array.isArray(parsed) ? parsed : [textData];
				} catch {
					this.texts = [textData];
				}

				this.speed = Number.parseInt(element.dataset.speed || "100", 10);
				this.deleteSpeed = Number.parseInt(element.dataset.deleteSpeed || "50", 10);
				this.pauseTime = Number.parseInt(element.dataset.pauseTime || "2000", 10);
				this.currentTextIndex = 0;
				this.currentIndex = 0;
				this.isDeleting = false;
				this.timeoutId = null;

				if (this.texts.length === 0) return;

				this.element.textContent = "";
				this.element.classList.add("is-typing");
				this.type();
			}

			getCurrentText() {
				return this.texts[this.currentTextIndex] || "";
			}

			type() {
				const currentText = this.getCurrentText();

				if (this.isDeleting) {
					if (this.currentIndex > 0) {
						this.currentIndex -= 1;
						this.element.textContent = currentText.substring(0, this.currentIndex);
						this.timeoutId = window.setTimeout(() => this.type(), this.deleteSpeed);
						return;
					}

					this.isDeleting = false;
					this.currentTextIndex = (this.currentTextIndex + 1) % this.texts.length;
					this.timeoutId = window.setTimeout(() => this.type(), this.speed);
					return;
				}

				if (this.currentIndex < currentText.length) {
					this.currentIndex += 1;
					this.element.textContent = currentText.substring(0, this.currentIndex);
					this.timeoutId = window.setTimeout(() => this.type(), this.speed);
					return;
				}

				this.element.classList.remove("is-typing");
				if (this.texts.length > 1) {
					this.isDeleting = true;
					this.timeoutId = window.setTimeout(() => this.type(), this.pauseTime);
				}
			}

			destroy() {
				if (this.timeoutId) clearTimeout(this.timeoutId);
			}
		}

		function initTypewriters() {
			document.querySelectorAll(".typewriter").forEach((element) => {
				if (!(element instanceof HTMLElement)) return;
				if (element.dataset.typewriterInitialized === "true") return;
				element.dataset.typewriterInitialized = "true";
				new TypewriterEffect(element);
			});
		}

		if (!typewriterWindow.__owenBlogTypewriterBound) {
			typewriterWindow.__owenBlogTypewriterBound = true;
			document.addEventListener("DOMContentLoaded", initTypewriters);
			window.addEventListener("pageshow", initTypewriters);
			document.addEventListener("swup:contentReplaced", initTypewriters);
		}

		if (document.readyState !== "loading") {
			initTypewriters();
		}
	})();
</script>

<style>
	.typewriter {
		position: relative;
		display: inline-block;
		min-height: 1em;
		line-height: inherit;
		vertical-align: baseline;
	}

	.typewriter:empty::before {
		content: "\00A0";
		visibility: hidden;
	}

	.typewriter[data-show-caret="true"]::after {
		content: "";
		display: inline-block;
		width: 1px;
		height: 0.96em;
		margin-left: 0.14em;
		vertical-align: -0.08em;
		background: currentColor;
		opacity: 0.5;
		animation: owen-typewriter-caret 1.08s steps(1) infinite;
	}

	.typewriter:not(.is-typing)[data-show-caret="true"]::after {
		opacity: 0.22;
	}

	@keyframes owen-typewriter-caret {
		0%, 49% {
			opacity: 0.58;
		}
		50%, 100% {
			opacity: 0;
		}
	}
</style>
