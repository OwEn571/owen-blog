---
import { Icon } from "astro-icon/components";
---

<div class="back-to-top-wrapper block">
	<button
		id="back-to-top-btn"
		type="button"
		class="back-to-top-btn hide btn-card flex items-center justify-center rounded-2xl overflow-hidden transition"
		aria-label="Back to Top"
	>
		<Icon
			name="material-symbols:keyboard-arrow-up-rounded"
			class="mx-auto"
		></Icon>
	</button>
</div>

<style lang="stylus">
  .back-to-top-wrapper
    width: 3.5rem
    height: 3.5rem
    position: relative
    pointer-events: auto

  .back-to-top-btn
    color: var(--primary)
    font-size: 2.25rem
    font-weight: bold
    border: none
    width: 3.5rem
    height: 3.5rem
    opacity: 1
    cursor: pointer
    transform: none
    pointer-events: auto
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.12)

    i
      font-size: 1.75rem

    &.hide
      transform: scale(0.9)
      opacity: 0
      pointer-events: none

    &:active
      transform: scale(0.96)

  @media (max-width: 1920px)
    .back-to-top-btn
      box-shadow: none

  // 手机端隐藏返回顶部按钮
  @media (max-width: 768px)
    .back-to-top-wrapper
      display: none

</style>

<script is:inline>
	(() => {
		const animateToTop = () => {
			const startTop = window.scrollY || document.documentElement.scrollTop;
			if (startTop <= 0) {
				return;
			}

			if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
				window.scrollTo({ top: 0, behavior: "auto" });
				return;
			}

			const startTime = performance.now();
			const duration = Math.min(420, Math.max(220, startTop * 0.18));
			const easeInOutCubic = (value) =>
				value < 0.5
					? 4 * value * value * value
					: 1 - ((-2 * value + 2) ** 3) / 2;
			const cleanupUserInterrupts = () => {
				window.removeEventListener("wheel", cancelScrollAnimation);
				window.removeEventListener("touchstart", cancelScrollAnimation);
				window.removeEventListener("keydown", cancelScrollAnimation);
				window.removeEventListener("mousedown", cancelScrollAnimation);
			};

			const cancelScrollAnimation = () => {
				if (window.__owenBlogBackToTopRaf) {
					window.cancelAnimationFrame(window.__owenBlogBackToTopRaf);
					delete window.__owenBlogBackToTopRaf;
				}
				cleanupUserInterrupts();
			};

			const step = (now) => {
				const progress = Math.min((now - startTime) / duration, 1);
				const eased = easeInOutCubic(progress);
				window.scrollTo({
					top: startTop * (1 - eased),
					behavior: "auto",
				});

				if (progress < 1) {
					window.__owenBlogBackToTopRaf = window.requestAnimationFrame(step);
					return;
				}

				cleanupUserInterrupts();
				delete window.__owenBlogBackToTopRaf;
			};

			if (window.__owenBlogBackToTopRaf) {
				window.cancelAnimationFrame(window.__owenBlogBackToTopRaf);
			}

			window.addEventListener("wheel", cancelScrollAnimation, { passive: true });
			window.addEventListener("touchstart", cancelScrollAnimation, { passive: true });
			window.addEventListener("keydown", cancelScrollAnimation);
			window.addEventListener("mousedown", cancelScrollAnimation);

			window.__owenBlogBackToTopRaf = window.requestAnimationFrame(step);
		};

		const bindBackToTop = () => {
			const button = document.getElementById("back-to-top-btn");
			if (!(button instanceof HTMLButtonElement) || button.dataset.bound === "true") {
				return;
			}

			button.dataset.bound = "true";
			button.addEventListener("click", () => {
				animateToTop();
			});
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", bindBackToTop, { once: true });
		} else {
			bindBackToTop();
		}
	})();
</script>
