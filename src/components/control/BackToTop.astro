---
import { Icon } from "astro-icon/components";
---

<div class="back-to-top-wrapper block">
	<button
		id="back-to-top-btn"
		type="button"
		class="back-to-top-btn hide btn-card flex items-center justify-center rounded-2xl overflow-hidden transition"
		aria-label="Back to Top"
	>
		<Icon
			name="material-symbols:keyboard-arrow-up-rounded"
			class="mx-auto"
		></Icon>
	</button>
</div>

<style lang="stylus">
  .back-to-top-wrapper
    width: 3.75rem
    height: 3.75rem
    position: fixed
    right: 6rem
    bottom: 10rem
    z-index: 120
    pointer-events: none

  .back-to-top-btn
    color: var(--primary)
    font-size: 2.25rem
    font-weight: bold
    border: none
    width: 3.75rem
    height: 3.75rem
    opacity: 1
    cursor: pointer
    transform: translateX(5rem)
    pointer-events: auto
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.12)

    i
      font-size: 1.75rem

    &.hide
      transform: translateX(5rem) scale(0.9)
      opacity: 0
      pointer-events: none

    &:active
      transform: translateX(5rem) scale(0.9)

  @media (max-width: 1920px)
    .back-to-top-btn
      box-shadow: none

  // 手机端隐藏返回顶部按钮
  @media (max-width: 768px)
    .back-to-top-wrapper
      display: none

</style>

<script is:inline>
	(() => {
		const bindBackToTop = () => {
			const button = document.getElementById("back-to-top-btn");
			if (!(button instanceof HTMLButtonElement) || button.dataset.bound === "true") {
				return;
			}

			button.dataset.bound = "true";
			button.addEventListener("click", () => {
				window.scrollTo({ top: 0, behavior: "smooth" });
			});
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", bindBackToTop, { once: true });
		} else {
			bindBackToTop();
		}
	})();
</script>
