  .miaomiao-chat-panel__hint
    margin 0
    color rgba(124, 85, 104, .72)
    font-family var(--owen-font-ui)
    font-size .72rem
    line-height 1.56

  .miaomiao-chat-panel__buttons
    display flex
    align-items center
    gap .6rem

  .miaomiao-chat-panel__ghost,
  .miaomiao-chat-panel__send
    min-height 2.65rem
    padding 0 1rem
    border-radius .98rem
    font-family var(--owen-font-ui)
    font-size .84rem
    font-weight 700
    transition transform .18s ease, box-shadow .18s ease, opacity .18s ease

  .miaomiao-chat-panel__ghost
    border 1px solid rgba(255, 192, 216, .16)
    background rgba(255, 240, 246, .72)
    color rgba(149, 74, 110, .88)

  .miaomiao-chat-panel__send
    border 1px solid rgba(255, 192, 216, .22)
    background linear-gradient(180deg, rgba(255, 201, 221, .98), rgba(252, 183, 209, .92))
