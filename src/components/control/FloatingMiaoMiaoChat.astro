  .miaomiao-chat-message__bubble
    width fit-content
    max-width unquote("min(100%, 34rem)")
    padding 1rem 1.08rem 1.02rem
    border-radius 1.24rem 1.24rem 1.24rem .5rem
    border 1px solid rgba(255, 192, 216, .14)
    background linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,247,250,.78))
