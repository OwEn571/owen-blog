  .miaomiao-chat-panel__messages::-webkit-scrollbar
    width .48rem

  .miaomiao-chat-panel__messages::-webkit-scrollbar-thumb
    border-radius 999px
    background rgba(181, 87, 127, .22)

  .miaomiao-chat-message
    display flex
    max-width 100%
    width 100%

  .miaomiao-chat-message[data-role="user"]
