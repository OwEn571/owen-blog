    white-space nowrap
    overflow hidden
    text-overflow ellipsis

  .miaomiao-chat-panel__reading-path
    font-family var(--owen-font-ui)
    font-size .72rem
    color rgba(121, 84, 103, .68)
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

  .miaomiao-chat-panel__quicklist
    display flex
    flex-wrap wrap
    gap .5rem

  .miaomiao-chat-panel__quick
    display inline-flex
    align-items center
    min-height 2rem
    padding 0 .82rem
    border-radius .95rem
    border 1px solid rgba(255, 192, 216, .16)
    background rgba(255,255,255,.72)
