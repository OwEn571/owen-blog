  .miaomiao-chat-panel__privacy
    display grid
    grid-template-columns auto minmax(0, 1fr)
    gap .75rem
    align-items start
    padding .92rem 1rem
    border-radius 1.18rem
    border 1px solid rgba(118, 156, 255, .14)
    background linear-gradient(180deg, rgba(246, 249, 255, .86), rgba(255,255,255,.74))
    box-shadow inset 0 1px 0 rgba(255,255,255,.68), 0 18px 34px rgba(76, 108, 187, .06)

  .miaomiao-chat-panel__privacy-toggle
    margin-top .16rem
