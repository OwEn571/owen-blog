    color rgba(231, 239, 255, .94)

  :root.dark .miaomiao-chat-message[data-tone="error"] .miaomiao-chat-message__bubble
    border-color rgba(223, 112, 149, .18)
    background linear-gradient(180deg, rgba(95, 34, 58, .48), rgba(66, 24, 42, .56))
    color rgba(255, 220, 232, .92)

  :root.dark .miaomiao-chat-panel__input
    color rgba(248, 238, 243, .94)

  :root.dark .miaomiao-chat-panel__send
    border-color rgba(255, 193, 216, .2)
    background linear-gradient(180deg, rgba(255, 173, 205, .28), rgba(203, 101, 147, .36))
    color rgba(255, 236, 244, .94)

  @media (max-width: 820px)
    .miaomiao-chat-shell
      left 1rem
      bottom 5.75rem

    .miaomiao-chat-fab
      width 3.5rem
      padding 0
      justify-content center

    .miaomiao-chat-fab__text
      display none

    .miaomiao-chat-panel
      left 1rem
      right 1rem
      width auto
      bottom calc(5.75rem + 4.2rem)
      height unquote("min(37rem, calc(100vh - 8rem))")

    .miaomiao-chat-panel__reading
      grid-template-columns 1fr

    .miaomiao-chat-panel__actions
      flex-direction column
      align-items stretch

    .miaomiao-chat-panel__buttons
      justify-content space-between
</style>

<script
	is:inline
	define:vars={{
		MIAOMIAO_CHAT_SCRIPT_URL: url("/scripts/miaomiao-chat.js"),
		MIAOMIAO_CHAT_UID: miaomiaoUid,
		MIAOMIAO_PROXY_URL: "/api/miaomiao-chat/",
	}}
>
	(() => {
		const root = document.getElementById(MIAOMIAO_CHAT_UID);
		if (!(root instanceof HTMLElement) || root.dataset.miaomiaoLoader === "true") {
			return;
		}

		root.dataset.miaomiaoLoader = "true";

		const boot = () => {
			if (typeof window.__owenInitMiaoMiaoChat === "function") {
				window.__owenInitMiaoMiaoChat(root, {
					proxyUrl: MIAOMIAO_PROXY_URL,
				});
				return;
			}

			let script = document.querySelector('script[data-miaomiao-chat-script="true"]');
			if (!(script instanceof HTMLScriptElement)) {
				script = document.createElement("script");
				script.src = MIAOMIAO_CHAT_SCRIPT_URL;
				script.dataset.miaomiaoChatScript = "true";
				document.body.appendChild(script);
			}

			script.addEventListener(
				"load",
				() => {
					window.__owenInitMiaoMiaoChat?.(root, {
						proxyUrl: MIAOMIAO_PROXY_URL,
					});
				},
				{ once: true },
			);
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", boot, { once: true });
		} else {
			boot();
		}
	})();
</script>
