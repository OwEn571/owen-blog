    min-width 0

  .miaomiao-chat-panel__reading-label
    font-family var(--owen-font-ui)
    font-size .66rem
    font-weight 700
    letter-spacing .16em
    text-transform uppercase
    color rgba(158, 80, 117, .72)

  .miaomiao-chat-panel__reading-title
    font-family var(--owen-font-ui)
    font-size .88rem
    font-weight 700
