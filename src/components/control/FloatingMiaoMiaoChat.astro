    box-shadow 0 10px 24px rgba(120,82,101,.14)

  .miaomiao-chat-panel__reading
    display grid
    grid-template-columns auto minmax(0, 1fr)
    gap .85rem
    align-items center
    padding .9rem .95rem
    border-radius 1.08rem
    border 1px solid rgba(255, 192, 216, .16)
    background linear-gradient(180deg, rgba(255,255,255,.7), rgba(255,242,247,.58))
    box-shadow inset 0 1px 0 rgba(255,255,255,.7)

  .miaomiao-chat-panel__reading-icon
    display inline-flex
    align-items center
    justify-content center
    width 2.5rem
    height 2.5rem
    border-radius .9rem
    background linear-gradient(135deg, rgba(255, 204, 223, .44), rgba(118, 156, 255, .18))
