    z-index 1

  .miaomiao-chat-panel__stage-head
    display grid
    gap .48rem

  .miaomiao-chat-panel__stage-label
    margin 0
    font-family var(--owen-font-ui)
    font-size .68rem
    font-weight 700
    letter-spacing .16em
    text-transform uppercase
    color rgba(164, 82, 118, .72)

  .miaomiao-chat-panel__status
    min-height auto
    padding .82rem .92rem
    border-radius 1rem
    border 1px solid rgba(255, 192, 216, .16)
    background linear-gradient(180deg, rgba(255, 241, 247, .76), rgba(255, 247, 250, .66))
    color rgba(99, 59, 79, .78)
    font-family var(--owen-font-reading)
    font-size .82rem
    line-height 1.66
    box-shadow inset 0 1px 0 rgba(255,255,255,.62)

  .miaomiao-chat-panel__messages
    min-height 0
    overflow auto
    display grid
    align-content start
    gap 1rem
    padding .95rem
    border-radius 1.2rem
    border 1px solid rgba(255, 192, 216, .14)
    background linear-gradient(180deg, rgba(255,255,255,.82), rgba(255,248,251,.74))
