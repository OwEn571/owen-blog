  .miaomiao-chat-message__avatar
    display inline-flex
    align-items center
    justify-content center
    width 2.1rem
    height 2.1rem
    border-radius 999px
    background linear-gradient(135deg, rgba(255, 199, 220, .96), rgba(255, 174, 205, .86))
