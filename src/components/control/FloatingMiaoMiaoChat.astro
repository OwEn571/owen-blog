---
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

const miaomiaoUid = `miaomiao-chat-${Math.random().toString(36).slice(2, 10)}`;
const miaomiaoPanelId = `${miaomiaoUid}-panel`;
const miaomiaoButtonId = `${miaomiaoUid}-button`;
const publicDifyApiBase =
	import.meta.env.PUBLIC_DIFY_API_BASE_URL || "https://api.dify.ai/v1";
const publicDifyApiKey = import.meta.env.PUBLIC_DIFY_API_KEY || "";
---

<div class="miaomiao-chat-shell" id={miaomiaoUid} data-miaomiao-chat>
	<button
		id={miaomiaoButtonId}
		type="button"
		class="miaomiao-chat-fab"
		data-miaomiao-chat-toggle
		aria-expanded="false"
		aria-controls={miaomiaoPanelId}
		aria-label="打开喵喵聊天面板"
	>
		<span class="miaomiao-chat-fab__icon">
			<Icon name="mdi:cat" />
		</span>
		<span class="miaomiao-chat-fab__label">喵喵</span>
	</button>

	<section
		id={miaomiaoPanelId}
		class="miaomiao-chat-panel"
		data-miaomiao-chat-panel
		hidden
		aria-hidden="true"
		aria-label="喵喵聊天面板"
	>
		<div class="miaomiao-chat-panel__header">
			<div class="miaomiao-chat-panel__copy">
				<p class="miaomiao-chat-panel__eyebrow">MiaoMiao Bot</p>
				<h3 class="miaomiao-chat-panel__title">喵喵</h3>
				<p class="miaomiao-chat-panel__note">
					会先检索站内文章与源码摘要，再把上下文交给你的 Dify bot。
				</p>
			</div>
			<button
				type="button"
				class="miaomiao-chat-panel__close"
				data-miaomiao-chat-close
				aria-label="关闭喵喵面板"
			>
				<Icon name="mdi:close" />
			</button>
		</div>

		<div class="miaomiao-chat-panel__status" data-miaomiao-chat-status>
			喵喵已待命，可以直接问博客内容、当前页面内容，或者站内实现细节。
		</div>

		<div class="miaomiao-chat-panel__messages" data-miaomiao-chat-messages></div>

		<form class="miaomiao-chat-panel__composer" data-miaomiao-chat-form>
			<textarea
				class="miaomiao-chat-panel__input"
				data-miaomiao-chat-input
				rows="3"
				placeholder="例如：帮我总结 LangChain 里的 Tools、Memory 和 Agents 区别"
				aria-label="给喵喵发送消息"
			></textarea>
			<div class="miaomiao-chat-panel__actions">
				<button
					type="button"
					class="miaomiao-chat-panel__ghost"
					data-miaomiao-chat-reset
				>
					新对话
				</button>
				<button
					type="submit"
					class="miaomiao-chat-panel__send"
					data-miaomiao-chat-send
				>
					发送
				</button>
			</div>
		</form>
	</section>
</div>

<style lang="stylus">
  .miaomiao-chat-shell
    position fixed
    left 1.4rem
    bottom 3.75rem
    z-index 1380
    pointer-events none

  .miaomiao-chat-shell > *
    pointer-events auto

  .miaomiao-chat-fab
    display inline-flex
    align-items center
    justify-content center
    gap .55rem
    min-width 3.5rem
    height 3.5rem
    padding 0 .95rem
    border-radius 1.15rem
    border 1px solid rgba(255, 184, 208, .26)
    background linear-gradient(180deg, rgba(255,255,255,.82), rgba(255,240,246,.62)), radial-gradient(circle at top right, rgba(255, 189, 214, .24), transparent 8rem)
    box-shadow 0 24px 56px rgba(120, 82, 101, .16), inset 0 1px 0 rgba(255,255,255,.78)
    backdrop-filter blur(18px) saturate(1.06)
    -webkit-backdrop-filter blur(18px) saturate(1.06)
    color rgba(116, 50, 81, .94)
    transition transform .22s ease, box-shadow .22s ease, border-color .22s ease

  .miaomiao-chat-fab:hover,
  .miaomiao-chat-fab:focus-visible
    transform translateY(-2px) scale(1.02)
    border-color rgba(255, 184, 208, .42)
    box-shadow 0 28px 64px rgba(120, 82, 101, .2), 0 0 24px rgba(255, 189, 214, .14)

  .miaomiao-chat-fab__icon
    display inline-flex
    align-items center
    justify-content center
    width 1.95rem
    height 1.95rem
    border-radius 999px
    background rgba(255, 189, 214, .26)
    font-size 1.1rem

  .miaomiao-chat-fab__label
    font-family var(--owen-font-ui)
    font-size .88rem
    font-weight 700
    letter-spacing .02em

  .miaomiao-chat-panel
    position fixed
    left 1.4rem
    bottom calc(3.75rem + 4.25rem)
    z-index 1450
    width unquote("min(26rem, calc(100vw - 2rem))")
    max-width unquote("calc(100vw - 2rem)")
    height unquote("min(38rem, calc(100vh - 7rem))")
    display grid
    grid-template-rows auto auto minmax(0, 1fr) auto
    gap .85rem
    padding 1rem
    border-radius 1.45rem
    border 1px solid rgba(255, 184, 208, .22)
    background linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,245,249,.78)), radial-gradient(circle at top right, rgba(255, 189, 214, .18), transparent 16rem)
    box-shadow 0 36px 88px rgba(120, 82, 101, .18), inset 0 1px 0 rgba(255,255,255,.84)
    backdrop-filter blur(20px) saturate(1.05)
    -webkit-backdrop-filter blur(20px) saturate(1.05)
    overflow hidden

  .miaomiao-chat-panel[hidden]
    display none !important

  .miaomiao-chat-panel__header
    display flex
    align-items flex-start
    justify-content space-between
    gap 1rem

  .miaomiao-chat-panel__eyebrow
    font-family var(--owen-font-ui)
    font-size .72rem
    font-weight 700
    letter-spacing .16em
    text-transform uppercase
    color rgba(181, 87, 127, .86)

  .miaomiao-chat-panel__title
    margin-top .15rem
    font-family var(--owen-font-display)
    font-size 1.2rem
    font-weight 720
    letter-spacing -.04em
    color rgba(68, 28, 49, .96)

  .miaomiao-chat-panel__note
    margin-top .24rem
    font-family var(--owen-font-reading)
    font-size .84rem
    line-height 1.68
    color rgba(95, 58, 76, .72)

  .miaomiao-chat-panel__close
    display inline-flex
    align-items center
    justify-content center
    width 2.2rem
    height 2.2rem
    border-radius 999px
    border 1px solid rgba(255, 184, 208, .22)
    background rgba(255, 236, 244, .78)
    color rgba(168, 74, 116, .88)
    transition transform .18s ease, box-shadow .18s ease

  .miaomiao-chat-panel__close:hover
    transform translateY(-1px)
    box-shadow 0 10px 24px rgba(120, 82, 101, .14)

  .miaomiao-chat-panel__status
    min-height 2.5rem
    padding .78rem .9rem
    border-radius 1rem
    border 1px solid rgba(255, 184, 208, .18)
    background rgba(255, 239, 246, .72)
    color rgba(103, 61, 81, .78)
    font-family var(--owen-font-reading)
    font-size .82rem
    line-height 1.66

  .miaomiao-chat-panel__messages
    min-height 0
    overflow auto
    display flex
    flex-direction column
    gap .82rem
    padding-right .2rem

  .miaomiao-chat-panel__messages::-webkit-scrollbar
    width .45rem

  .miaomiao-chat-panel__messages::-webkit-scrollbar-thumb
    border-radius 999px
    background rgba(181, 87, 127, .24)

  .miaomiao-chat-message
    display flex
    flex-direction column
    gap .38rem
    max-width 100%

  .miaomiao-chat-message[data-role="user"]
    align-items flex-end

  .miaomiao-chat-message__meta
    font-family var(--owen-font-ui)
    font-size .68rem
    font-weight 700
    letter-spacing .12em
    text-transform uppercase
    color rgba(168, 92, 127, .72)

  .miaomiao-chat-message__bubble
    max-width 100%
    padding .85rem .95rem
    border-radius 1.05rem
    border 1px solid rgba(255, 184, 208, .16)
    background rgba(255, 255, 255, .72)
    color rgba(49, 27, 40, .88)
    font-family var(--owen-font-reading)
    font-size .9rem
    line-height 1.72
    white-space pre-wrap
    word-break break-word
    box-shadow 0 16px 34px rgba(120, 82, 101, .08)

  .miaomiao-chat-message[data-role="user"] .miaomiao-chat-message__bubble
    background linear-gradient(180deg, rgba(255, 230, 239, .92), rgba(255, 239, 245, .78))
    color rgba(97, 41, 67, .94)

  .miaomiao-chat-message__refs
    display flex
    flex-wrap wrap
    gap .45rem

  .miaomiao-chat-message__ref
    display inline-flex
    align-items center
    min-height 1.7rem
    max-width 100%
    padding 0 .72rem
    border-radius 999px
    border 1px solid rgba(255, 184, 208, .18)
    background rgba(255, 241, 247, .72)
    color rgba(149, 74, 110, .88)
    font-family var(--owen-font-ui)
    font-size .71rem
    font-weight 650
    letter-spacing .02em
    text-decoration none
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

  .miaomiao-chat-panel__composer
    display grid
    gap .72rem

  .miaomiao-chat-panel__input
    min-height 5.5rem
    max-height 10rem
    resize vertical
    padding .92rem 1rem
    border-radius 1rem
    border 1px solid rgba(255, 184, 208, .18)
    background rgba(255, 255, 255, .76)
    color rgba(61, 28, 46, .94)
    font-family var(--owen-font-reading)
    font-size .92rem
    line-height 1.68
    box-shadow inset 0 1px 0 rgba(255,255,255,.74)

  .miaomiao-chat-panel__input:focus
    outline none
    border-color rgba(255, 173, 202, .42)
    box-shadow 0 0 0 4px rgba(255, 189, 214, .18)

  .miaomiao-chat-panel__actions
    display flex
    align-items center
    justify-content space-between
    gap .75rem

  .miaomiao-chat-panel__ghost,
  .miaomiao-chat-panel__send
    min-height 2.6rem
    padding 0 .95rem
    border-radius .95rem
    font-family var(--owen-font-ui)
    font-size .84rem
    font-weight 700
    transition transform .18s ease, box-shadow .18s ease

  .miaomiao-chat-panel__ghost
    border 1px solid rgba(255, 184, 208, .16)
    background rgba(255, 239, 246, .7)
    color rgba(149, 74, 110, .88)

  .miaomiao-chat-panel__send
    border 1px solid rgba(255, 184, 208, .22)
    background linear-gradient(180deg, rgba(255, 201, 221, .98), rgba(252, 183, 209, .92))
    color rgba(82, 31, 55, .96)
    box-shadow 0 18px 34px rgba(181, 87, 127, .18)

  .miaomiao-chat-panel__ghost:hover,
  .miaomiao-chat-panel__send:hover
    transform translateY(-1px)

  :root.dark .miaomiao-chat-fab
    border-color rgba(255, 193, 216, .2)
    background linear-gradient(180deg, rgba(33, 17, 30, .86), rgba(21, 10, 20, .72)), radial-gradient(circle at top right, rgba(255, 169, 201, .18), transparent 10rem)
    box-shadow 0 28px 66px rgba(0, 0, 0, .28), inset 0 1px 0 rgba(255,255,255,.08)
    color rgba(255, 224, 236, .94)

  :root.dark .miaomiao-chat-fab__icon
    background rgba(255, 169, 201, .18)
    color rgba(255, 213, 229, .94)

  :root.dark .miaomiao-chat-panel
    border-color rgba(255, 193, 216, .18)
    background linear-gradient(180deg, rgba(22, 12, 21, .9), rgba(11, 7, 13, .8)), radial-gradient(circle at top right, rgba(255, 169, 201, .16), transparent 16rem)
    box-shadow 0 36px 92px rgba(0, 0, 0, .36), inset 0 1px 0 rgba(255,255,255,.08)

  :root.dark .miaomiao-chat-panel__title
    color rgba(255, 242, 247, .96)

  :root.dark .miaomiao-chat-panel__note,
  :root.dark .miaomiao-chat-panel__status
    color rgba(244, 221, 231, .72)

  :root.dark .miaomiao-chat-panel__status
    background rgba(255, 255, 255, .04)

  :root.dark .miaomiao-chat-message__bubble
    border-color rgba(255, 193, 216, .12)
    background rgba(255, 255, 255, .05)
    color rgba(246, 236, 241, .9)

  :root.dark .miaomiao-chat-message[data-role="user"] .miaomiao-chat-message__bubble
    background linear-gradient(180deg, rgba(90, 32, 60, .52), rgba(56, 22, 41, .68))

  :root.dark .miaomiao-chat-message__ref
    border-color rgba(255, 193, 216, .14)
    background rgba(255, 255, 255, .05)
    color rgba(255, 212, 228, .88)

  :root.dark .miaomiao-chat-panel__input
    border-color rgba(255, 193, 216, .14)
    background rgba(255, 255, 255, .05)
    color rgba(248, 238, 243, .94)

  :root.dark .miaomiao-chat-panel__ghost
    border-color rgba(255, 193, 216, .14)
    background rgba(255, 255, 255, .05)
    color rgba(255, 215, 230, .88)

  :root.dark .miaomiao-chat-panel__send
    border-color rgba(255, 193, 216, .2)
    background linear-gradient(180deg, rgba(255, 173, 205, .28), rgba(203, 101, 147, .36))
    color rgba(255, 236, 244, .94)

  @media (max-width: 820px)
    .miaomiao-chat-shell
      left 1rem
      bottom 5.75rem

    .miaomiao-chat-fab
      width 3.5rem
      padding 0

    .miaomiao-chat-fab__label
      display none

    .miaomiao-chat-panel
      left 1rem
      right 1rem
      width auto
      bottom calc(5.75rem + 4.2rem)
      height unquote("min(34rem, calc(100vh - 8rem))")
</style>

<script
	is:inline
	define:vars={{
		MIAOMIAO_CHAT_SCRIPT_URL: url("/scripts/miaomiao-chat.js"),
		MIAOMIAO_CHAT_UID: miaomiaoUid,
		MIAOMIAO_KNOWLEDGE_URL: url("/api/miaomiao-knowledge.json"),
		MIAOMIAO_PROXY_URL: "/api/miaomiao-chat/",
		MIAOMIAO_PUBLIC_DIFY_API_BASE: publicDifyApiBase,
		MIAOMIAO_PUBLIC_DIFY_API_KEY: publicDifyApiKey,
	}}
>
	(() => {
		const root = document.getElementById(MIAOMIAO_CHAT_UID);
		if (!(root instanceof HTMLElement) || root.dataset.miaomiaoLoader === "true") {
			return;
		}

		root.dataset.miaomiaoLoader = "true";

		const boot = () => {
			if (typeof window.__owenInitMiaoMiaoChat === "function") {
				window.__owenInitMiaoMiaoChat(root, {
					knowledgeUrl: MIAOMIAO_KNOWLEDGE_URL,
					proxyUrl: MIAOMIAO_PROXY_URL,
					publicApiBase: MIAOMIAO_PUBLIC_DIFY_API_BASE,
					publicApiKey: MIAOMIAO_PUBLIC_DIFY_API_KEY,
				});
				return;
			}

			let script = document.querySelector('script[data-miaomiao-chat-script="true"]');
			if (!(script instanceof HTMLScriptElement)) {
				script = document.createElement("script");
				script.src = MIAOMIAO_CHAT_SCRIPT_URL;
				script.dataset.miaomiaoChatScript = "true";
				document.body.appendChild(script);
			}

			script.addEventListener(
				"load",
				() => {
					window.__owenInitMiaoMiaoChat?.(root, {
						knowledgeUrl: MIAOMIAO_KNOWLEDGE_URL,
						proxyUrl: MIAOMIAO_PROXY_URL,
						publicApiBase: MIAOMIAO_PUBLIC_DIFY_API_BASE,
						publicApiKey: MIAOMIAO_PUBLIC_DIFY_API_KEY,
					});
				},
				{ once: true },
			);
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", boot, { once: true });
		} else {
			boot();
		}
	})();
</script>
