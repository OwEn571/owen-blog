  .miaomiao-chat-panel__quickwrap
    display grid
    gap .48rem

  .miaomiao-chat-panel__quicklabel
    font-family var(--owen-font-ui)
    font-size .68rem
    font-weight 700
    letter-spacing .16em
    text-transform uppercase
    color rgba(164, 82, 118, .7)

  .miaomiao-chat-panel__quicklist
    display flex
    gap .58rem
    overflow auto
    padding .05rem .08rem .24rem
    scrollbar-width none

  .miaomiao-chat-panel__quicklist::-webkit-scrollbar
    display none

  .miaomiao-chat-panel__quick
    display inline-flex
    align-items center
    justify-content center
    flex 0 0 auto
    min-height 2.2rem
    padding 0 .95rem
    border-radius 999px
    border 1px solid rgba(255, 192, 216, .16)
    background linear-gradient(180deg, rgba(255,255,255,.78), rgba(255,246,250,.7))
    color rgba(129, 62, 96, .92)
    font-family var(--owen-font-ui)
    font-size .76rem
    font-weight 700
    letter-spacing .01em
    white-space nowrap
    box-shadow 0 14px 26px rgba(167, 96, 129, .08)
    transition transform .18s ease, box-shadow .18s ease, border-color .18s ease, background .18s ease

  .miaomiao-chat-panel__quick:hover,
  .miaomiao-chat-panel__quick:focus-visible
    transform translateY(-1px)
    border-color rgba(255, 192, 216, .32)
    background linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,240,247,.78))
    box-shadow 0 16px 30px rgba(181, 87, 127, .14)

  .miaomiao-chat-panel__stage
    position relative
    min-height 0
    display grid
    grid-template-rows auto minmax(18rem, 1fr)
    gap .72rem
    padding .96rem
    border-radius 1.42rem
    border 1px solid rgba(255, 192, 216, .18)
