    border-color rgba(255, 173, 202, .42)
    box-shadow 0 0 0 4px rgba(255, 189, 214, .18)

  .miaomiao-chat-panel__actions
    display flex
    align-items flex-end
    justify-content space-between
    gap .8rem

  .miaomiao-chat-panel__hint
    margin 0
    color rgba(124, 85, 104, .72)
    font-family var(--owen-font-ui)
    font-size .72rem
    line-height 1.56

  .miaomiao-chat-panel__buttons
    display flex
    align-items center
    gap .6rem

  .miaomiao-chat-panel__ghost,
  .miaomiao-chat-panel__send
    min-height 2.8rem
    padding 0 1.02rem
    border-radius 1rem
    font-family var(--owen-font-ui)
    font-size .84rem
    font-weight 700
