    justify-content center
    width 2.45rem
    height 2.45rem
    border-radius 1rem
    flex-shrink 0
    border 1px solid rgba(255,255,255,.52)
    background linear-gradient(135deg, rgba(255, 199, 220, .96), rgba(255, 174, 205, .86))
