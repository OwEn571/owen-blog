    border-color rgba(223, 112, 149, .2)
    color rgba(123, 45, 74, .92)

  .miaomiao-chat-message__typing
    display inline-flex
    align-items center
    gap .35rem

  .miaomiao-chat-message__typing-dot
    width .38rem
    height .38rem
    border-radius 999px
    background rgba(181, 87, 127, .56)
