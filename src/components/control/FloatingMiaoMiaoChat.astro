    box-shadow 0 36px 92px rgba(0, 0, 0, .36), inset 0 1px 0 rgba(255,255,255,.08)

  :root.dark .miaomiao-chat-panel__title,
  :root.dark .miaomiao-chat-panel__reading-title
    color rgba(255, 242, 247, .96)

  :root.dark .miaomiao-chat-panel__note,
  :root.dark .miaomiao-chat-panel__status,
  :root.dark .miaomiao-chat-panel__hint,
  :root.dark .miaomiao-chat-panel__reading-path
    color rgba(244, 221, 231, .72)

  :root.dark .miaomiao-chat-panel__reading,
  :root.dark .miaomiao-chat-panel__quick,
  :root.dark .miaomiao-chat-panel__status,
  :root.dark .miaomiao-chat-message__bubble,
  :root.dark .miaomiao-chat-panel__input,
  :root.dark .miaomiao-chat-panel__ghost
    border-color rgba(255, 193, 216, .14)
    background rgba(255, 255, 255, .05)

  :root.dark .miaomiao-chat-panel__reading-label,
  :root.dark .miaomiao-chat-panel__composer-label,
  :root.dark .miaomiao-chat-panel__eyebrow,
  :root.dark .miaomiao-chat-message__meta
    color rgba(255, 214, 230, .74)

  :root.dark .miaomiao-chat-panel__messages
    background linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01))

  :root.dark .miaomiao-chat-message__avatar
    background linear-gradient(135deg, rgba(255, 174, 205, .28), rgba(203, 101, 147, .34))
    color rgba(255, 234, 244, .96)

  :root.dark .miaomiao-chat-message[data-role="user"] .miaomiao-chat-message__avatar
    background linear-gradient(135deg, rgba(118, 156, 255, .26), rgba(82, 119, 225, .34))
    color rgba(230, 239, 255, .96)

  :root.dark .miaomiao-chat-message__bubble
    color rgba(246, 236, 241, .9)

  :root.dark .miaomiao-chat-message[data-role="user"] .miaomiao-chat-message__bubble
    border-color rgba(118, 156, 255, .18)
