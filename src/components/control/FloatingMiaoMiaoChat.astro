  .miaomiao-chat-panel__privacy-copy
    display grid
    gap .18rem

  .miaomiao-chat-panel__privacy-copy strong
    font-family var(--owen-font-ui)
    font-size .82rem
    color rgba(72, 35, 54, .94)

  .miaomiao-chat-panel__privacy-copy span
    font-family var(--owen-font-reading)
    font-size .76rem
