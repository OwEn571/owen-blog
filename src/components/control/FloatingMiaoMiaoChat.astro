---
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

const miaomiaoUid = `miaomiao-chat-${Math.random().toString(36).slice(2, 10)}`;
const miaomiaoPanelId = `${miaomiaoUid}-panel`;
const miaomiaoButtonId = `${miaomiaoUid}-button`;
---

<div class="miaomiao-chat-shell" id={miaomiaoUid} data-miaomiao-chat>
	<button
		id={miaomiaoButtonId}
		type="button"
		class="miaomiao-chat-fab"
		data-miaomiao-chat-toggle
		aria-expanded="false"
		aria-controls={miaomiaoPanelId}
		aria-label="打开喵喵聊天面板"
	>
		<span class="miaomiao-chat-fab__icon">
			<Icon name="mdi:cat" />
		</span>
		<span class="miaomiao-chat-fab__text">
			<strong>喵喵</strong>
			<span>Page Companion</span>
		</span>
	</button>

	<section
		id={miaomiaoPanelId}
		class="miaomiao-chat-panel"
		data-miaomiao-chat-panel
		hidden
		aria-hidden="true"
		aria-label="喵喵聊天面板"
	>
		<div class="miaomiao-chat-panel__header">
			<div class="miaomiao-chat-panel__copy">
				<p class="miaomiao-chat-panel__eyebrow">Page Companion</p>
				<h3 class="miaomiao-chat-panel__title">喵喵</h3>
				<p class="miaomiao-chat-panel__note">
					我会先读你现在打开的这一页，再帮你梳理重点、解释难点，或者把内容讲得更白一点。
				</p>
			</div>
			<button
				type="button"
				class="miaomiao-chat-panel__close"
				data-miaomiao-chat-close
				aria-label="关闭喵喵面板"
			>
				<Icon name="mdi:close" />
			</button>
		</div>

		<div class="miaomiao-chat-panel__reading">
			<div class="miaomiao-chat-panel__reading-icon" aria-hidden="true">
				<Icon name="material-symbols:auto-stories-outline-rounded" />
			</div>
			<div class="miaomiao-chat-panel__reading-copy">
				<span class="miaomiao-chat-panel__reading-label">正在陪你读</span>
				<strong class="miaomiao-chat-panel__reading-title" data-miaomiao-chat-page-title>
					正在识别当前页面
				</strong>
				<span class="miaomiao-chat-panel__reading-path" data-miaomiao-chat-page-path>
					/
				</span>
			</div>
		</div>

		<div class="miaomiao-chat-panel__quicklist">
			<button
				type="button"
				class="miaomiao-chat-panel__quick"
				data-miaomiao-chat-prompt="先帮我把这一页讲白，再提炼 3 个最重要的点。"
			>
				先讲白这页
			</button>
			<button
				type="button"
				class="miaomiao-chat-panel__quick"
				data-miaomiao-chat-prompt="从当前页面里挑出最容易混淆的 3 个地方，分别解释。"
			>
				找容易混淆处
			</button>
			<button
				type="button"
				class="miaomiao-chat-panel__quick"
				data-miaomiao-chat-prompt="如果我要把这一页的内容真的用起来，最该先记住什么？"
			>
				问怎么用
			</button>
		</div>

		<div class="miaomiao-chat-panel__status" data-miaomiao-chat-status>
			喵喵会优先根据当前页面正文回答，如果这页信息不够，我会直接告诉你。
		</div>

		<div class="miaomiao-chat-panel__messages" data-miaomiao-chat-messages></div>

		<form class="miaomiao-chat-panel__composer" data-miaomiao-chat-form>
			<label class="miaomiao-chat-panel__composer-shell">
				<span class="miaomiao-chat-panel__composer-label">继续追问这页</span>
				<textarea
					class="miaomiao-chat-panel__input"
					data-miaomiao-chat-input
					rows="3"
					placeholder="例如：这篇里最关键的概念是什么？如果我要写代码，先记住哪几件事？"
					aria-label="给喵喵发送消息"
				></textarea>
			</label>

			<div class="miaomiao-chat-panel__actions">
				<p class="miaomiao-chat-panel__hint">Ctrl/Cmd + Enter 发送。切换页面后，喵喵会自动跟着读新页面。</p>
				<div class="miaomiao-chat-panel__buttons">
					<button
						type="button"
						class="miaomiao-chat-panel__ghost"
						data-miaomiao-chat-reset
					>
						新对话
					</button>
					<button
						type="submit"
						class="miaomiao-chat-panel__send"
						data-miaomiao-chat-send
					>
						发送
					</button>
				</div>
			</div>
		</form>
	</section>
</div>

<style lang="stylus">
  .miaomiao-chat-shell
    position fixed
    left 1.4rem
    bottom 3.75rem
    z-index 1380
    pointer-events none

  .miaomiao-chat-shell > *
    pointer-events auto

  .miaomiao-chat-fab
    display inline-flex
    align-items center
    gap .72rem
    min-width 3.75rem
    height 3.6rem
    padding 0 1rem 0 .8rem
    border-radius 1.2rem
    border 1px solid rgba(255, 192, 216, .24)
    background linear-gradient(180deg, rgba(255,255,255,.86), rgba(255,243,248,.72)), radial-gradient(circle at top right, rgba(255, 192, 216, .24), transparent 9rem), radial-gradient(circle at bottom left, rgba(118,156,255,.12), transparent 10rem)
    box-shadow 0 28px 64px rgba(120, 82, 101, .16), inset 0 1px 0 rgba(255,255,255,.84)
    backdrop-filter blur(18px) saturate(1.04)
    -webkit-backdrop-filter blur(18px) saturate(1.04)
    color rgba(88, 37, 62, .94)
    transition transform .22s ease, box-shadow .22s ease, border-color .22s ease

  .miaomiao-chat-fab:hover,
  .miaomiao-chat-fab:focus-visible
    transform translateY(-2px)
    border-color rgba(255, 192, 216, .4)
    box-shadow 0 34px 72px rgba(120,82,101,.2), 0 0 28px rgba(255,192,216,.14)

  .miaomiao-chat-fab__icon
    display inline-flex
    align-items center
    justify-content center
    width 2rem
    height 2rem
    border-radius 999px
    background linear-gradient(135deg, rgba(255, 208, 225, .9), rgba(255, 183, 212, .8))
    box-shadow inset 0 1px 0 rgba(255,255,255,.7)

  .miaomiao-chat-fab__text
    display grid
    gap .08rem
    text-align left

  .miaomiao-chat-fab__text strong
    font-family var(--owen-font-ui)
    font-size .86rem
    font-weight 800
    letter-spacing .02em

  .miaomiao-chat-fab__text span
    font-family var(--owen-font-ui)
    font-size .68rem
    letter-spacing .14em
    text-transform uppercase
    color rgba(150, 77, 113, .68)

  .miaomiao-chat-panel
    position fixed
    left 1.4rem
    bottom calc(3.75rem + 4.35rem)
    z-index 1450
    width unquote("min(28rem, calc(100vw - 2rem))")
    max-width unquote("calc(100vw - 2rem)")
    height unquote("min(41rem, calc(100vh - 7rem))")
    display grid
    grid-template-rows auto auto auto auto minmax(0, 1fr) auto
    gap .82rem
    padding 1rem
    border-radius 1.55rem
    border 1px solid rgba(255, 192, 216, .22)
    background linear-gradient(180deg, rgba(255,255,255,.9), rgba(255,247,250,.8)), radial-gradient(circle at top right, rgba(255, 192, 216, .2), transparent 16rem), radial-gradient(circle at bottom left, rgba(118,156,255,.1), transparent 18rem)
    box-shadow 0 38px 92px rgba(120,82,101,.18), inset 0 1px 0 rgba(255,255,255,.86)
    backdrop-filter blur(22px) saturate(1.05)
    -webkit-backdrop-filter blur(22px) saturate(1.05)
    overflow hidden

  .miaomiao-chat-panel[hidden]
    display none !important

  .miaomiao-chat-panel__header
    display flex
    align-items flex-start
    justify-content space-between
    gap 1rem

  .miaomiao-chat-panel__eyebrow
    font-family var(--owen-font-ui)
    font-size .72rem
    font-weight 700
    letter-spacing .16em
    text-transform uppercase
    color rgba(181, 87, 127, .82)

  .miaomiao-chat-panel__title
    margin-top .16rem
    font-family var(--owen-font-display)
    font-size 1.24rem
    font-weight 720
    letter-spacing -.04em
    color rgba(68, 28, 49, .96)

  .miaomiao-chat-panel__note
    margin-top .26rem
    font-family var(--owen-font-reading)
    font-size .86rem
