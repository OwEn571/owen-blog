---
import { Icon } from "astro-icon/components";
---

<div class="python-lab-fab-shell" data-python-lab data-state="closed">
	<button
		type="button"
		class="python-lab-fab"
		data-python-lab-toggle
		aria-expanded="false"
		aria-controls="python-lab-panel"
		aria-label="打开 Python Lab"
	>
		<span class="python-lab-fab__icon">
			<Icon name="mdi:language-python" />
		</span>
		<span class="python-lab-fab__label">Python Lab</span>
	</button>

	<section
		id="python-lab-panel"
		class="python-lab-panel"
		data-python-lab-panel
		hidden
		aria-label="Floating Python Lab"
	>
		<div class="python-lab-panel__header">
			<div class="python-lab-panel__copy">
				<p class="python-lab-panel__eyebrow">Floating Workspace</p>
				<h3 class="python-lab-panel__title">Python Lab</h3>
				<p class="python-lab-panel__note">随时呼出、编写、运行，再收回。</p>
			</div>
			<button
				type="button"
				class="python-lab-panel__close"
				data-python-lab-close
				aria-label="收起 Python Lab"
			>
				<Icon name="mdi:close" />
			</button>
		</div>

		<div class="python-lab-panel__status" data-python-lab-status>
			点击运行时会加载 Monaco 与浏览器内 Python 运行时。
		</div>

		<div class="python-lab-panel__editor-frame">
			<textarea
				class="python-lab-panel__fallback"
				data-python-lab-fallback
				aria-label="Python Lab editor"
				spellcheck="false"
				autocapitalize="off"
				autocorrect="off"
			></textarea>
			<div class="python-lab-panel__editor" data-python-lab-editor hidden></div>
		</div>

		<div class="python-lab-panel__actions">
			<button type="button" class="python-lab-panel__run" data-python-lab-run>
				运行代码
			</button>
			<button type="button" class="python-lab-panel__ghost" data-python-lab-clear>
				清空输出
			</button>
		</div>

		<pre class="python-lab-panel__output" data-python-lab-output aria-live="polite">等待运行…</pre>

		<textarea data-python-lab-source hidden>
from math import sqrt

nums = [1, 4, 9, 16, 25]
print([sqrt(n) for n in nums])
		</textarea>
	</section>
</div>

<script is:inline>
	(() => {
		const current = document.currentScript;
		const root = current?.previousElementSibling;
		if (!(root instanceof HTMLElement) || root.dataset.pythonLabBootstrap === "true") {
			return;
		}

		root.dataset.pythonLabBootstrap = "true";

		const toggle = root.querySelector("[data-python-lab-toggle]");
		const panel = root.querySelector("[data-python-lab-panel]");
		const close = root.querySelector("[data-python-lab-close]");
		const fallback = root.querySelector("[data-python-lab-fallback]");

		if (
			!(toggle instanceof HTMLButtonElement) ||
			!(panel instanceof HTMLElement) ||
			!(close instanceof HTMLButtonElement)
		) {
			return;
		}

		const setOpen = (open) => {
			panel.hidden = !open;
			root.dataset.state = open ? "open" : "closed";
			toggle.setAttribute("aria-expanded", open ? "true" : "false");

			if (open && fallback instanceof HTMLTextAreaElement) {
				window.setTimeout(() => fallback.focus(), 0);
			}
		};

		toggle.addEventListener("click", () => {
			setOpen(panel.hidden);
		});

		close.addEventListener("click", () => {
			setOpen(false);
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && root.dataset.state === "open") {
				setOpen(false);
			}
		});
	})();
</script>

<style lang="stylus">
  .python-lab-fab-shell
    position fixed
    right clamp(1rem, 3vw, 2rem)
    bottom clamp(5.5rem, 12vh, 8.5rem)
    z-index 119
    display flex
    flex-direction column
    align-items flex-end
    gap 1rem
    pointer-events none

  .python-lab-fab,
  .python-lab-panel
    pointer-events auto

  .python-lab-fab
    display inline-flex
    align-items center
    gap .72rem
    min-height 3.35rem
    padding .72rem 1rem
    border-radius 999px
    border 1px solid rgba(118, 156, 255, .18)
    background linear-gradient(180deg, rgba(255,255,255,.72), rgba(247,250,255,.58)), radial-gradient(circle at top right, rgba(118,156,255,.15), transparent 8rem)
    box-shadow 0 22px 52px rgba(15, 23, 42, .14), inset 0 1px 0 rgba(255,255,255,.72)
    backdrop-filter blur(18px) saturate(1.04)
    -webkit-backdrop-filter blur(18px) saturate(1.04)
    color rgba(15, 23, 42, .88)
    transition transform .22s ease, box-shadow .22s ease, border-color .22s ease
    position relative
    overflow hidden

  .python-lab-fab::after
    content ""
    position absolute
    inset -1px
    border-radius inherit
    pointer-events none
    opacity 0
    box-shadow 0 0 0 1px rgba(118, 156, 255, .2), 0 0 26px rgba(118, 156, 255, .18), 0 0 54px rgba(132, 115, 255, .12)
    transition opacity .22s ease

  .python-lab-fab:hover,
  .python-lab-fab:focus-visible
    transform translateY(-2px) scale(1.02)
    border-color rgba(118, 156, 255, .3)
    box-shadow 0 0 26px rgba(118, 156, 255, .16), 0 24px 56px rgba(15, 23, 42, .16)

  .python-lab-fab-shell[data-state="open"] .python-lab-fab::after,
  .python-lab-fab:hover::after,
  .python-lab-fab:focus-visible::after
    opacity 1

  .python-lab-fab__icon
    display inline-flex
    align-items center
    justify-content center
    width 2rem
    height 2rem
    border-radius 999px
    background rgba(118, 156, 255, .12)
    color rgba(70, 97, 186, .92)
    font-size 1.1rem

  .python-lab-fab__label
    font-size .88rem
    font-weight 650
    letter-spacing .02em

  .python-lab-panel
    width 34rem
    max-width calc(100vw - 1.5rem)
    max-height calc(100vh - 7rem)
    display grid
    gap .9rem
    padding 1rem
    border-radius 1.55rem
    border 1px solid rgba(118, 156, 255, .18)
    background linear-gradient(180deg, rgba(255,255,255,.74), rgba(246,250,255,.58)), radial-gradient(circle at top right, rgba(118,156,255,.16), transparent 16rem)
    box-shadow 0 32px 88px rgba(15, 23, 42, .22), inset 0 1px 0 rgba(255,255,255,.72)
    backdrop-filter blur(22px) saturate(1.06)
    -webkit-backdrop-filter blur(22px) saturate(1.06)
    overflow hidden
    position relative
    transition transform .24s ease, box-shadow .24s ease, border-color .24s ease

  .python-lab-panel::after
    content ""
    position absolute
    inset -1px
    border-radius inherit
    pointer-events none
    opacity .66
    box-shadow 0 0 0 1px rgba(118, 156, 255, .16), 0 0 38px rgba(118, 156, 255, .14), 0 0 82px rgba(132, 115, 255, .1)

  .python-lab-fab-shell[data-state="open"] .python-lab-panel
    transform translateY(-2px)
    border-color rgba(118, 156, 255, .24)
    box-shadow 0 0 34px rgba(118, 156, 255, .14), 0 36px 96px rgba(15, 23, 42, .24), inset 0 1px 0 rgba(255,255,255,.72)

  .python-lab-panel__header
    display flex
    align-items flex-start
    justify-content space-between
    gap 1rem

  .python-lab-panel__eyebrow
    font-size .72rem
    letter-spacing .16em
    text-transform uppercase
    color rgba(70, 97, 186, .78)

  .python-lab-panel__title
    margin-top .18rem
    font-size 1.18rem
    font-weight 700
    color rgba(15, 23, 42, .92)

  .python-lab-panel__note
    margin-top .24rem
    font-size .84rem
    color rgba(15, 23, 42, .56)

  .python-lab-panel__close
    display inline-flex
    align-items center
    justify-content center
    width 2.2rem
    height 2.2rem
    border-radius 999px
    border 1px solid rgba(118, 156, 255, .14)
    background rgba(118, 156, 255, .08)
    color rgba(70, 97, 186, .88)

  .python-lab-panel__status
    min-height 2.4rem
    padding .78rem .9rem
    border-radius 1rem
    border 1px solid rgba(118, 156, 255, .12)
    background rgba(15, 23, 42, .04)
    font-size .83rem
    color rgba(15, 23, 42, .62)

  .python-lab-panel__editor-frame
    min-height 18rem
    border-radius 1.2rem
    border 1px solid rgba(118, 156, 255, .14)
    background rgba(9, 12, 19, .94)
    overflow hidden
    display grid
    align-items stretch

  .python-lab-panel__editor
    width 100%
    min-height 18rem
    height min(24rem, 46vh)
    grid-area 1 / 1

  .python-lab-panel__fallback
    width 100%
    min-height 18rem
    height min(24rem, 46vh)
    grid-area 1 / 1
    resize none
    padding 1rem 1.05rem
    border none
    outline none
    background transparent
    color rgba(227, 236, 255, .88)
    font-size .9rem
    line-height 1.72
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    white-space pre
    overflow auto
    caret-color rgba(214, 226, 255, .94)

  .python-lab-panel__fallback::selection
    background rgba(118, 156, 255, .24)

  .python-lab-panel__actions
    display flex
    gap .75rem

  .python-lab-panel__run,
  .python-lab-panel__ghost
    min-height 2.7rem
    padding 0 1rem
    border-radius .95rem
    border 1px solid rgba(118, 156, 255, .16)
    font-size .86rem
    font-weight 640
    transition transform .22s ease, box-shadow .22s ease, border-color .22s ease

  .python-lab-panel__run
    background linear-gradient(135deg, rgba(93, 129, 255, .96), rgba(132, 115, 255, .92))
    color white
    box-shadow 0 18px 38px rgba(88, 115, 255, .24)

  .python-lab-panel__ghost
    background rgba(118, 156, 255, .08)
    color rgba(70, 97, 186, .9)

  .python-lab-panel__run:hover,
  .python-lab-panel__ghost:hover,
  .python-lab-panel__close:hover
    transform translateY(-1px) scale(1.015)
    border-color rgba(118, 156, 255, .26)
    box-shadow 0 0 18px rgba(118, 156, 255, .14), 0 12px 30px rgba(15, 23, 42, .12)

  .python-lab-panel__output
    min-height 8rem
    max-height 12rem
    overflow auto
    padding 1rem
    border-radius 1rem
    border 1px solid rgba(118, 156, 255, .12)
    background rgba(9, 12, 19, .9)
    color rgba(227, 236, 255, .84)
    font-size .86rem
    line-height 1.65
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    white-space pre-wrap
    word-break break-word

  :root.dark .python-lab-fab
    background linear-gradient(180deg, rgba(11,14,22,.78), rgba(5,8,14,.58)), radial-gradient(circle at top right, rgba(118,156,255,.16), transparent 8rem)
    color rgba(236, 241, 255, .9)
    box-shadow 0 24px 58px rgba(0, 0, 0, .32), inset 0 1px 0 rgba(255,255,255,.08)

  :root.dark .python-lab-fab__icon
    background rgba(118, 156, 255, .14)
    color rgba(221, 232, 255, .92)

  :root.dark .python-lab-panel
    background linear-gradient(180deg, rgba(11,14,22,.86), rgba(5,8,14,.76)), radial-gradient(circle at top right, rgba(118,156,255,.16), transparent 16rem)
    box-shadow 0 36px 92px rgba(0, 0, 0, .38), inset 0 1px 0 rgba(255,255,255,.08)

  :root.dark .python-lab-panel__title
    color rgba(248, 250, 255, .94)

  :root.dark .python-lab-panel__note,
  :root.dark .python-lab-panel__status
    color rgba(227, 236, 255, .66)

  :root.dark .python-lab-panel__status
    background rgba(255, 255, 255, .04)

  :root.dark .python-lab-panel__ghost
    background rgba(118, 156, 255, .12)
    color rgba(225, 234, 255, .9)

  @media (max-width: 820px)
    .python-lab-fab-shell
      right 1rem
      left 1rem
      bottom 1rem
      align-items stretch

    .python-lab-fab
      justify-content center

    .python-lab-panel
      width 100%
      max-height calc(100vh - 6rem)

    .python-lab-panel__editor
      height 42vh
