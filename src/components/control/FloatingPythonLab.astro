---
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

const pythonLabUid = `python-lab-${Math.random().toString(36).slice(2, 10)}`;
const pythonLabPanelId = `${pythonLabUid}-panel`;
const pythonLabButtonId = `${pythonLabUid}-button`;
---

<div class="python-lab-shell" data-python-lab id={pythonLabUid}>
	<button
		id={pythonLabButtonId}
		type="button"
		class="python-lab-fab"
		data-python-lab-toggle
		aria-expanded="false"
		aria-controls={pythonLabPanelId}
		aria-label="打开 Python Lab"
	>
		<span class="python-lab-fab__icon">
			<Icon name="mdi:language-python" />
		</span>
		<span class="python-lab-fab__label">Python Lab</span>
	</button>

	<section
		id={pythonLabPanelId}
		class="python-lab-panel"
		data-python-lab-panel
		hidden
		aria-hidden="true"
		aria-label="Python Lab"
	>
		<div class="python-lab-panel__header">
			<div class="python-lab-panel__copy">
				<p class="python-lab-panel__eyebrow">Floating Workspace</p>
				<h3 class="python-lab-panel__title">Python Lab</h3>
				<p class="python-lab-panel__note">默认轻量编辑器，先保证可写、可拖、可运行。</p>
			</div>
			<button
				type="button"
				class="python-lab-panel__close"
				data-python-lab-close
				aria-label="收起 Python Lab"
			>
				<Icon name="mdi:close" />
			</button>
		</div>

		<div class="python-lab-panel__dragbar" data-python-lab-drag-handle aria-hidden="true">
			<span class="python-lab-panel__dragbar-grip"></span>
		</div>

		<div class="python-lab-panel__status" data-python-lab-status>
			轻量编辑器已就绪，首次运行时再加载浏览器内 Python。
		</div>

		<div class="python-lab-panel__editor-frame">
			<div class="python-lab-panel__editor-topbar" aria-hidden="true">
				<div class="python-lab-panel__editor-badge">Python 3</div>
				<div class="python-lab-panel__editor-hint">Tab 缩进 · Shift+Tab 退缩进 · Ctrl/Cmd+Enter 运行</div>
			</div>
			<div class="python-lab-panel__editor-shell">
				<div class="python-lab-panel__line-numbers" data-python-lab-gutter aria-hidden="true"></div>
				<div class="python-lab-panel__editor-stack">
					<div class="python-lab-panel__line-highlight" data-python-lab-line-highlight aria-hidden="true"></div>
					<pre class="python-lab-panel__highlight" data-python-lab-highlight aria-hidden="true"></pre>
					<textarea
						class="python-lab-panel__editor"
						data-python-lab-editor
						aria-label="Python Lab editor"
						spellcheck="false"
						autocapitalize="off"
						autocorrect="off"
						wrap="off"
					></textarea>
				</div>
			</div>
		</div>

		<div class="python-lab-panel__actions">
			<button type="button" class="python-lab-panel__run" data-python-lab-run>
				运行代码
			</button>
			<button type="button" class="python-lab-panel__ghost" data-python-lab-reset>
				恢复示例
			</button>
			<button type="button" class="python-lab-panel__ghost" data-python-lab-clear>
				清空输出
			</button>
		</div>

		<pre class="python-lab-panel__output" data-python-lab-output aria-live="polite">等待运行…</pre>

		<textarea data-python-lab-source hidden>
from math import sqrt

nums = [1, 4, 9, 16, 25]
print([sqrt(n) for n in nums])
		</textarea>
	</section>
</div>

<style lang="stylus">
  .python-lab-shell
    position relative
    width 3.5rem
    height 3.5rem
    filter drop-shadow(0 0 16px rgba(118, 156, 255, .08))

  .python-lab-fab
    display inline-flex
    align-items center
    justify-content center
    width 3.5rem
    height 3.5rem
    padding 0
    border-radius 1.15rem
    border 1px solid rgba(118, 156, 255, .18)
    background linear-gradient(180deg, rgba(255,255,255,.74), rgba(247,250,255,.58)), radial-gradient(circle at top right, rgba(118,156,255,.15), transparent 8rem)
    box-shadow 0 22px 52px rgba(15, 23, 42, .14), inset 0 1px 0 rgba(255,255,255,.72)
    backdrop-filter blur(18px) saturate(1.04)
    -webkit-backdrop-filter blur(18px) saturate(1.04)
    color rgba(15, 23, 42, .88)
    transition transform .22s ease, box-shadow .22s ease, border-color .22s ease
    position relative
    overflow hidden

  .python-lab-fab:hover,
  .python-lab-fab:focus-visible
    transform translateY(-2px) scale(1.02)
    border-color rgba(118, 156, 255, .3)
    box-shadow 0 0 26px rgba(118, 156, 255, .16), 0 24px 56px rgba(15, 23, 42, .16)

  .python-lab-fab__icon
    display inline-flex
    align-items center
    justify-content center
    width 2rem
    height 2rem
    border-radius 999px
    background rgba(118, 156, 255, .12)
    color rgba(70, 97, 186, .92)
    font-size 1.1rem

  .python-lab-fab__label
    display none

  .python-lab-panel
    position fixed
    z-index 1400
    width unquote("min(30rem, calc(100vw - 2rem))")
    max-width unquote("calc(100vw - 2rem)")
    height unquote("min(42rem, calc(100vh - 2rem))")
    max-height unquote("calc(100vh - 2rem)")
    display grid
    grid-template-rows auto auto auto minmax(18rem, 1fr) auto minmax(6.25rem, auto)
    gap .85rem
    padding 1rem
    border-radius 1.55rem
    border 1px solid rgba(118, 156, 255, .18)
    background linear-gradient(180deg, rgba(255,255,255,.76), rgba(246,250,255,.6)), radial-gradient(circle at top right, rgba(118,156,255,.16), transparent 16rem)
    box-shadow 0 32px 88px rgba(15, 23, 42, .22), inset 0 1px 0 rgba(255,255,255,.72)
    backdrop-filter blur(22px) saturate(1.06)
    -webkit-backdrop-filter blur(22px) saturate(1.06)
    overflow hidden
    transform-origin bottom right
    transition transform .22s ease, box-shadow .22s ease, border-color .22s ease, opacity .22s ease

  .python-lab-panel[hidden]
    display none !important

  .python-lab-panel[data-state="open"]
    box-shadow 0 0 34px rgba(118, 156, 255, .14), 0 36px 96px rgba(15, 23, 42, .24), inset 0 1px 0 rgba(255,255,255,.72)

  .python-lab-panel[data-dragging]
    transition none

  .python-lab-panel__header
    display flex
    align-items flex-start
    justify-content space-between
    gap 1rem
    user-select none

  .python-lab-panel__eyebrow
    font-family var(--owen-font-ui)
    font-size .72rem
    font-weight 600
    letter-spacing .16em
    text-transform uppercase
    color rgba(70, 97, 186, .78)

  .python-lab-panel__title
    margin-top .16rem
    font-family var(--owen-font-display)
    font-size 1.18rem
    font-weight 700
    letter-spacing -.04em
    color rgba(15, 23, 42, .92)

  .python-lab-panel__note
    margin-top .24rem
    font-family var(--owen-font-reading)
    font-size .84rem
    line-height 1.7
    color rgba(15, 23, 42, .58)

  .python-lab-panel__close
    display inline-flex
    align-items center
    justify-content center
    width 2.2rem
    height 2.2rem
    border-radius 999px
    border 1px solid rgba(118, 156, 255, .14)
    background rgba(118, 156, 255, .08)
    color rgba(70, 97, 186, .88)
    transition transform .18s ease, box-shadow .18s ease

  .python-lab-panel__close:hover
    transform translateY(-1px) scale(1.015)
    box-shadow 0 10px 24px rgba(15, 23, 42, .12)

  .python-lab-panel__dragbar
    display flex
    align-items center
    justify-content center
    min-height 1.1rem
    margin-top -.15rem
    cursor grab
    user-select none
    touch-action none

  .python-lab-panel[data-dragging] .python-lab-panel__dragbar
    cursor grabbing

  .python-lab-panel__dragbar-grip
    width 4.4rem
    height .34rem
    border-radius 999px
    background linear-gradient(90deg, rgba(118, 156, 255, .24), rgba(132, 115, 255, .16))
    box-shadow inset 0 1px 0 rgba(255,255,255,.56), 0 0 0 1px rgba(118, 156, 255, .08)

  .python-lab-panel__status
    min-height 2.4rem
    padding .78rem .9rem
    border-radius 1rem
    border 1px solid rgba(118, 156, 255, .12)
    background rgba(15, 23, 42, .04)
    font-family var(--owen-font-reading)
    font-size .83rem
    line-height 1.65
    color rgba(15, 23, 42, .62)

  .python-lab-panel__editor-frame
    min-height 0
    height 100%
    border-radius 1.2rem
    border 1px solid rgba(118, 156, 255, .14)
    background rgba(9, 12, 19, .94)
    overflow hidden
    position relative
    display grid
    grid-template-rows auto minmax(0, 1fr)

  .python-lab-panel__editor-topbar
    display flex
    align-items center
    justify-content space-between
    gap .75rem
    min-height 2.5rem
    padding .65rem .9rem
    border-bottom 1px solid rgba(118, 156, 255, .12)
    background linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02))

  .python-lab-panel__editor-badge
    display inline-flex
    align-items center
    justify-content center
    min-height 1.55rem
    padding 0 .65rem
    border-radius .7rem
    border 1px solid rgba(118, 156, 255, .18)
    background rgba(118, 156, 255, .1)
    font-family var(--owen-font-ui)
    font-size .72rem
    font-weight 650
    letter-spacing .08em
    text-transform uppercase
    color rgba(219, 230, 255, .9)

  .python-lab-panel__editor-hint
    font-family var(--owen-font-ui)
    font-size .72rem
    letter-spacing .04em
    color rgba(219, 230, 255, .54)

  .python-lab-panel__editor-shell
    min-height 0
    display grid
    grid-template-columns auto minmax(0, 1fr)

  .python-lab-panel__editor-stack
    position relative
    min-height 0
    height 100%
    overflow hidden

  .python-lab-panel__line-highlight
    position absolute
    left 0
    right 0
    z-index 0
    height 1.72em
    background linear-gradient(90deg, rgba(118, 156, 255, .12), rgba(118, 156, 255, .03))
    box-shadow inset 0 1px 0 rgba(255,255,255,.04), inset 0 -1px 0 rgba(255,255,255,.03)
    pointer-events none
    transition transform .14s ease, opacity .14s ease
    opacity .92

  .python-lab-panel__line-numbers
    min-width 3rem
    padding 1rem .5rem 1rem .85rem
    border-right 1px solid rgba(118, 156, 255, .1)
    background rgba(255,255,255,.03)
    color rgba(206, 218, 242, .38)
    font-size .78rem
    line-height 1.72
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    text-align right
    user-select none
    overflow hidden
    white-space pre
    pointer-events none

  .python-lab-panel__highlight
    position absolute
    inset 0
    z-index 1
    margin 0
    padding 1rem 1.05rem
    overflow auto
    border none
    outline none
    background transparent
    color rgba(227, 236, 255, .9)
    font-size .92rem
    line-height 1.72
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    white-space pre
    pointer-events none
    tab-size 4
    scrollbar-width none

  .python-lab-panel__highlight::-webkit-scrollbar
    display none

  .python-lab-panel__editor
    width 100%
    height 100%
    min-height 0
    resize none
    padding 1rem 1.05rem
    border none
    outline none
    background transparent
    position relative
    z-index 2
    color transparent
    -webkit-text-fill-color transparent
    text-shadow none
    font-size .92rem
    line-height 1.72
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    white-space pre
    overflow auto
    caret-color rgba(214, 226, 255, .94)
    tab-size 4
    scrollbar-gutter stable

  .python-lab-panel__editor::selection
    background rgba(118, 156, 255, .24)

  .python-lab-panel__editor:focus
    outline none

  :global(.python-lab-autocomplete)
    position fixed
    z-index 1800
    min-width 14rem
    max-width unquote("min(20rem, calc(100vw - 1.5rem))")
    max-height unquote("min(18rem, calc(100vh - 1.5rem))")
    overflow auto
    padding .42rem
    border-radius 1rem
    border 1px solid rgba(118, 156, 255, .16)
    background linear-gradient(180deg, rgba(14, 18, 28, .96), rgba(8, 11, 18, .92))
    box-shadow 0 24px 60px rgba(0, 0, 0, .34), inset 0 1px 0 rgba(255,255,255,.08)
    backdrop-filter blur(16px) saturate(1.04)
    -webkit-backdrop-filter blur(16px) saturate(1.04)

  :global(.python-lab-autocomplete[hidden])
    display none !important

  :global(.python-lab-autocomplete__item)
    display grid
    grid-template-columns minmax(0, 1fr) auto
    align-items center
    gap .9rem
    width 100%
    min-height 3.2rem
    padding .72rem .8rem
    border-radius .82rem
    border 1px solid transparent
    background transparent
    color rgba(234, 240, 255, .92)
    text-align left
    transition transform .16s ease, background .16s ease, border-color .16s ease, box-shadow .16s ease

  :global(.python-lab-autocomplete__item:hover),
  :global(.python-lab-autocomplete__item.is-active)
    background rgba(118, 156, 255, .14)
    border-color rgba(118, 156, 255, .2)
    box-shadow inset 0 1px 0 rgba(255,255,255,.06), 0 10px 22px rgba(0, 0, 0, .18)
    transform translateY(-1px)

  :global(.python-lab-autocomplete__copy)
    min-width 0
    display grid
    gap .18rem

  :global(.python-lab-autocomplete__label)
    min-width 0
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    font-size .82rem
    font-weight 600
    line-height 1.5
    color inherit
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

  :global(.python-lab-autocomplete__meta)
    font-family var(--owen-font-ui)
    font-size .67rem
    letter-spacing .08em
    text-transform uppercase
    color rgba(188, 204, 245, .56)

  :global(.python-lab-autocomplete__doc)
    min-width 0
    font-family var(--owen-font-reading)
    font-size .72rem
    line-height 1.45
    color rgba(196, 208, 238, .68)
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

  :global(.python-lab-signature)
    position fixed
    z-index 1790
    min-width 16rem
    max-width unquote("min(26rem, calc(100vw - 1.5rem))")
    padding .7rem .78rem
    border-radius 1rem
    border 1px solid rgba(118, 156, 255, .16)
    background linear-gradient(180deg, rgba(12, 16, 25, .96), rgba(8, 11, 18, .92))
    box-shadow 0 22px 52px rgba(0, 0, 0, .3), inset 0 1px 0 rgba(255,255,255,.08)
    backdrop-filter blur(14px) saturate(1.04)
    -webkit-backdrop-filter blur(14px) saturate(1.04)

  :global(.python-lab-signature[hidden])
    display none !important

  :global(.python-lab-signature__title)
    display block
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    font-size .8rem
    line-height 1.55
    color rgba(235, 241, 255, .92)
    white-space pre-wrap

  :global(.python-lab-signature__title .is-active)
    color rgba(255, 222, 120, .96)
    font-weight 700

  :global(.python-lab-signature__meta)
    display block
    margin-top .36rem
    font-family var(--owen-font-ui)
    font-size .66rem
    letter-spacing .08em
    text-transform uppercase
    color rgba(186, 204, 246, .5)

  :global(.python-lab-signature__doc)
    display block
    margin-top .32rem
    font-family var(--owen-font-reading)
    font-size .76rem
    line-height 1.5
    color rgba(200, 211, 238, .7)

  :global(.python-lab-hover)
    position fixed
    z-index 1785
    min-width 13rem
    max-width unquote("min(24rem, calc(100vw - 1.5rem))")
    padding .72rem .8rem
    border-radius 1rem
    border 1px solid rgba(118, 156, 255, .15)
    background linear-gradient(180deg, rgba(10, 14, 22, .96), rgba(7, 10, 17, .92))
    box-shadow 0 20px 48px rgba(0, 0, 0, .28), inset 0 1px 0 rgba(255,255,255,.08)
    backdrop-filter blur(14px) saturate(1.04)
    -webkit-backdrop-filter blur(14px) saturate(1.04)

  :global(.python-lab-hover[hidden])
    display none !important

  :global(.python-lab-hover__title)
    display block
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    font-size .79rem
    font-weight 650
    line-height 1.45
    color rgba(235, 241, 255, .94)

  :global(.python-lab-hover__meta)
    display block
    margin-top .25rem
    font-family var(--owen-font-ui)
    font-size .66rem
    letter-spacing .08em
    text-transform uppercase
    color rgba(186, 204, 246, .5)

  :global(.python-lab-hover__doc)
    display block
    margin-top .34rem
    font-family var(--owen-font-reading)
    font-size .75rem
    line-height 1.5
    color rgba(200, 211, 238, .7)

  :global(.python-lab-token-keyword)
    color rgba(141, 175, 255, .96)
    font-weight 650

  :global(.python-lab-token-builtin)
    color rgba(120, 224, 227, .94)

  :global(.python-lab-token-string)
    color rgba(255, 186, 144, .94)

  :global(.python-lab-token-comment)
    color rgba(150, 164, 191, .58)
    font-style italic

  :global(.python-lab-token-number)
    color rgba(255, 141, 183, .92)

  :global(.python-lab-token-decorator)
    color rgba(186, 162, 255, .94)

  :global(.python-lab-token-function),
  :global(.python-lab-token-call)
    color rgba(255, 222, 120, .94)

  :global(.python-lab-token-class)
    color rgba(255, 157, 219, .94)

  :global(.python-lab-token-constant)
    color rgba(255, 212, 133, .92)

  .python-lab-panel__actions
    display flex
    gap .7rem
    flex-wrap wrap

  .python-lab-panel__run,
  .python-lab-panel__ghost
    min-height 2.7rem
    padding 0 1rem
    border-radius .95rem
    border 1px solid rgba(118, 156, 255, .16)
    font-size .86rem
    font-weight 640
    transition transform .18s ease, box-shadow .18s ease, border-color .18s ease

  .python-lab-panel__run
    background linear-gradient(135deg, rgba(93, 129, 255, .96), rgba(132, 115, 255, .92))
    color white
    box-shadow 0 18px 38px rgba(88, 115, 255, .24)

  .python-lab-panel__ghost
    background rgba(118, 156, 255, .08)
    color rgba(70, 97, 186, .9)

  .python-lab-panel__run:hover,
  .python-lab-panel__ghost:hover
    transform translateY(-1px) scale(1.01)
    border-color rgba(118, 156, 255, .26)
    box-shadow 0 0 18px rgba(118, 156, 255, .14), 0 12px 30px rgba(15, 23, 42, .12)

  .python-lab-panel__run[disabled]
    opacity .76
    cursor wait

  .python-lab-panel__output
    min-height 6.25rem
    max-height 10rem
    overflow auto
    padding 1rem
    border-radius 1rem
    border 1px solid rgba(118, 156, 255, .12)
    background rgba(9, 12, 19, .9)
    color rgba(227, 236, 255, .84)
    font-size .86rem
    line-height 1.65
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    white-space pre-wrap
    word-break break-word

  .python-lab-panel__editor,
  .python-lab-panel__output
    scrollbar-width thin
    scrollbar-color rgba(126, 98, 141, .34) transparent

  .python-lab-panel__editor::-webkit-scrollbar,
  .python-lab-panel__output::-webkit-scrollbar
    width .72rem
    height .72rem

  .python-lab-panel__editor::-webkit-scrollbar-track,
  .python-lab-panel__output::-webkit-scrollbar-track
    background transparent

  .python-lab-panel__editor::-webkit-scrollbar-thumb,
  .python-lab-panel__output::-webkit-scrollbar-thumb
    border .18rem solid transparent
    border-radius 999px
    background rgba(126, 98, 141, .28)
    background-clip padding-box

  :root:not(.dark) .python-lab-fab
    border-color rgba(236, 174, 198, .2)
    background linear-gradient(180deg, rgba(255,255,255,.9), rgba(255,244,248,.7)), radial-gradient(circle at top right, rgba(255,188,210,.18), transparent 8rem)
    color rgba(87, 48, 66, .92)
    box-shadow 0 22px 54px rgba(120, 82, 101, .14), inset 0 1px 0 rgba(255,255,255,.86)

  :root:not(.dark) .python-lab-fab__icon
    background rgba(255, 220, 233, .58)
    color rgba(160, 78, 115, .92)

  :root:not(.dark) .python-lab-panel
    border-color rgba(236, 174, 198, .22)
    background linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,244,248,.78)), radial-gradient(circle at top right, rgba(255,188,210,.18), transparent 16rem)
    box-shadow 0 34px 92px rgba(120, 82, 101, .2), inset 0 1px 0 rgba(255,255,255,.86)

  :root:not(.dark) .python-lab-panel__eyebrow
    color rgba(160, 78, 115, .72)

  :root:not(.dark) .python-lab-panel__title
    color rgba(83, 48, 64, .94)

  :root:not(.dark) .python-lab-panel__note,
  :root:not(.dark) .python-lab-panel__status
    color rgba(107, 72, 87, .72)

  :root:not(.dark) .python-lab-panel__status
    border-color rgba(236, 174, 198, .18)
    background rgba(255, 245, 249, .82)

  :root:not(.dark) .python-lab-panel__dragbar-grip
    background linear-gradient(90deg, rgba(232, 146, 182, .34), rgba(244, 164, 196, .24))
    box-shadow inset 0 1px 0 rgba(255,255,255,.86), 0 0 0 1px rgba(236, 174, 198, .16)

  :root:not(.dark) .python-lab-panel__close
    border-color rgba(236, 174, 198, .16)
    background rgba(255, 224, 236, .54)
    color rgba(160, 78, 115, .88)

  :root:not(.dark) .python-lab-panel__editor-frame
    border-color rgba(236, 174, 198, .18)
    background linear-gradient(180deg, rgba(255,255,255,.94), rgba(255,246,250,.88)), radial-gradient(circle at top right, rgba(255,188,210,.14), transparent 12rem)
    box-shadow inset 0 1px 0 rgba(255,255,255,.92), 0 18px 42px rgba(120, 82, 101, .08)

  :root:not(.dark) .python-lab-panel__editor-topbar
    border-bottom-color rgba(236, 174, 198, .16)
    background linear-gradient(180deg, rgba(255,255,255,.62), rgba(255,246,250,.36))

  :root:not(.dark) .python-lab-panel__editor-badge
    border-color rgba(236, 174, 198, .18)
    background rgba(255, 224, 236, .54)
    color rgba(160, 78, 115, .9)

  :root:not(.dark) .python-lab-panel__editor-hint
    color rgba(120, 82, 101, .58)

