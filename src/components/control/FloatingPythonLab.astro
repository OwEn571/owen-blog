---
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";
---

<div class="python-lab-fab-shell" data-python-lab data-state="closed">
	<button
		type="button"
		class="python-lab-fab"
		data-python-lab-toggle
		data-ui-control="python-lab"
		aria-expanded="false"
		aria-controls="python-lab-panel"
		aria-label="打开 Python Lab"
	>
		<span class="python-lab-fab__icon">
			<Icon name="mdi:language-python" />
		</span>
		<span class="python-lab-fab__label">Python Lab</span>
	</button>

	<section
		id="python-lab-panel"
		class="python-lab-panel"
		data-python-lab-panel
		data-ui-panel="python-lab"
		hidden
		aria-label="Floating Python Lab"
	>
		<div class="python-lab-panel__header" data-python-lab-drag-handle>
			<div class="python-lab-panel__copy">
				<p class="python-lab-panel__eyebrow">Floating Workspace</p>
				<h3 class="python-lab-panel__title">Python Lab</h3>
				<p class="python-lab-panel__note">随时呼出、编写、运行，再收回。</p>
			</div>
			<button
				type="button"
				class="python-lab-panel__close"
				data-python-lab-close
				data-ui-control-close="python-lab"
				aria-label="收起 Python Lab"
			>
				<Icon name="mdi:close" />
			</button>
		</div>

		<div
			class="python-lab-panel__status"
			data-python-lab-status
			data-python-lab-drag-handle
		>
			点击运行时会加载 Monaco 与浏览器内 Python 运行时。
		</div>

		<div class="python-lab-panel__editor-frame">
			<div class="python-lab-panel__loading" data-python-lab-loading>
				<div class="python-lab-panel__loading-spinner" aria-hidden="true"></div>
				<p class="python-lab-panel__loading-title">Preparing Python Lab</p>
				<p class="python-lab-panel__loading-copy">正在加载编辑器核心，稍等片刻。</p>
			</div>
			<textarea
				class="python-lab-panel__fallback"
				data-python-lab-fallback
				aria-label="Python Lab editor"
				spellcheck="false"
				autocapitalize="off"
				autocorrect="off"
			></textarea>
			<div class="python-lab-panel__editor" data-python-lab-editor hidden></div>
		</div>

		<div class="python-lab-panel__actions">
			<button type="button" class="python-lab-panel__run" data-python-lab-run>
				运行代码
			</button>
			<button type="button" class="python-lab-panel__ghost" data-python-lab-clear>
				清空输出
			</button>
		</div>

		<pre class="python-lab-panel__output" data-python-lab-output aria-live="polite">等待运行…</pre>

		<textarea data-python-lab-source hidden>
from math import sqrt

nums = [1, 4, 9, 16, 25]
print([sqrt(n) for n in nums])
		</textarea>
	</section>
</div>

<style lang="stylus">
  .python-lab-fab-shell
    filter drop-shadow(0 0 16px rgba(118, 156, 255, .08))

  .python-lab-fab
    border-radius 1.22rem
    background linear-gradient(180deg, rgba(255,255,255,.82), rgba(247,250,255,.62)), radial-gradient(circle at top right, rgba(118,156,255,.14), transparent 8rem)
    box-shadow 0 20px 48px rgba(15, 23, 42, .14), inset 0 1px 0 rgba(255,255,255,.78)

  .python-lab-panel
    border-radius 1.72rem
    background linear-gradient(180deg, rgba(255,255,255,.82), rgba(246,250,255,.64)), radial-gradient(circle at top right, rgba(118,156,255,.14), transparent 16rem)
    box-shadow 0 34px 92px rgba(15, 23, 42, .22), inset 0 1px 0 rgba(255,255,255,.78)

  .python-lab-panel__eyebrow
    font-family var(--owen-font-ui)
    font-weight 600
    letter-spacing .18em

  .python-lab-panel__title
    font-family var(--owen-font-display)
    font-size 1.24rem
    letter-spacing -.04em

  .python-lab-panel__note,
  .python-lab-panel__status
    font-family var(--owen-font-reading)
    line-height 1.72

  :root.dark .python-lab-fab
    background linear-gradient(180deg, rgba(15,19,30,.76), rgba(9,13,21,.36)), radial-gradient(circle at top right, rgba(118,156,255,.16), transparent 8rem)
    box-shadow 0 22px 58px rgba(0, 0, 0, .26), inset 0 1px 0 rgba(255,255,255,.08)

  :root.dark .python-lab-panel
    background linear-gradient(180deg, rgba(14,18,28,.82), rgba(8,12,20,.42)), radial-gradient(circle at top right, rgba(118,156,255,.16), transparent 16rem)
    box-shadow 0 38px 104px rgba(0, 0, 0, .32), inset 0 1px 0 rgba(255,255,255,.08)
</style>

<script is:inline define:vars={{ PYTHON_PLAYGROUND_URL: url("/scripts/python-playground.js") }}>
	(() => {
		const root = document.querySelector("[data-python-lab]");
		if (!(root instanceof HTMLElement) || root.dataset.pythonLabBootstrap === "true") {
			return;
		}

		if (root.parentElement !== document.body) {
			document.body.appendChild(root);
		}

		root.dataset.pythonLabBootstrap = "true";

		const toggle = root.querySelector("[data-python-lab-toggle]");
		const panel = root.querySelector("[data-python-lab-panel]");
		const close = root.querySelector("[data-python-lab-close]");
		const fallback = root.querySelector("[data-python-lab-fallback]");

		if (
			!(toggle instanceof HTMLButtonElement) ||
			!(panel instanceof HTMLElement) ||
			!(close instanceof HTMLButtonElement)
		) {
			return;
		}

		const setOpen = (open) => {
			panel.hidden = !open;
			root.dataset.state = open ? "open" : "closed";
			toggle.setAttribute("aria-expanded", open ? "true" : "false");
			root.style.zIndex = "";

			if (open && fallback instanceof HTMLTextAreaElement) {
				window.setTimeout(() => fallback.focus(), 0);
			}
		};

		const ensureRuntimeScript = () => {
			if (root.dataset.pythonLabBound === "true") {
				return;
			}

			if (document.querySelector('script[data-python-lab-runtime="true"]')) {
				return;
			}

			const script = document.createElement("script");
			script.src = PYTHON_PLAYGROUND_URL;
			script.dataset.pythonLabRuntime = "true";
			document.body.appendChild(script);
		};

		window.__owenEnsurePythonLabRuntime = ensureRuntimeScript;
		window.__owenBootstrapPythonLabFallback = setOpen;

		if (toggle.dataset.owenBound !== "true") {
			toggle.dataset.owenBound = "true";
			toggle.addEventListener("click", (event) => {
				event.preventDefault();
				event.stopPropagation();
				if (root.dataset.pythonLabBound === "true") {
					return;
				}
				const open = root.dataset.state === "open";
				if (!open) {
					ensureRuntimeScript();
				}
				setOpen(!open);
			});
		}

		if (close.dataset.owenBound !== "true") {
			close.dataset.owenBound = "true";
			close.addEventListener("click", (event) => {
				event.preventDefault();
				event.stopPropagation();
				if (root.dataset.pythonLabBound === "true") {
					return;
				}
				setOpen(false);
			});
		}

		document.addEventListener(
			"mousedown",
			(event) => {
				const target = event.target;
				if (
					!(target instanceof Element) ||
					root.contains(target) ||
					panel.contains(target)
				) {
					return;
				}
				setOpen(false);
			},
			true,
		);
	})();
</script>

