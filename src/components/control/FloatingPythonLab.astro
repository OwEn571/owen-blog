  :root.dark .python-lab-panel__status
    color rgba(227, 236, 255, .66)

  :root.dark .python-lab-panel__status
    background rgba(255, 255, 255, .04)

  :root.dark .python-lab-panel__ghost
    background rgba(118, 156, 255, .12)
    color rgba(225, 234, 255, .9)

  @keyframes python-lab-spin
    to
      transform rotate(360deg)

  @media (max-width: 820px)
    .python-lab-fab-shell
      right 1rem
      bottom unquote("calc(var(--utility-rail-bottom, 5.75rem) + (var(--utility-rail-size, 3.5rem) + var(--utility-rail-gap, .9rem)) * 2 + .2rem)")
      --python-lab-anchor-right 1rem
      --python-lab-anchor-bottom unquote("calc(var(--utility-rail-bottom, 5.75rem) + (var(--utility-rail-size, 3.5rem) + var(--utility-rail-gap, .9rem)) * 2 + .2rem)")
      width 3.5rem
      height 3.5rem

    .python-lab-fab
      width 3.5rem
      height 3.5rem

    .python-lab-panel
      width unquote("min(24rem, calc(100vw - 2rem))")
      max-width 30rem
      height unquote("min(36rem, calc(100vh - 7rem))")
      max-height calc(100vh - 7rem)
      left var(--python-lab-panel-left, auto)
      top var(--python-lab-panel-top, auto)
      right var(--python-lab-panel-right, var(--python-lab-anchor-right, 1rem))
      bottom var(--python-lab-panel-bottom, calc(var(--python-lab-anchor-bottom, 5.75rem) - .15rem))
