---
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

const pythonLabUid = `python-lab-${Math.random().toString(36).slice(2, 10)}`;
const pythonLabPanelId = `${pythonLabUid}-panel`;
const pythonLabButtonId = `${pythonLabUid}-button`;
---

<div class="python-lab-shell" data-python-lab id={pythonLabUid}>
	<button
		id={pythonLabButtonId}
		type="button"
		class="python-lab-fab"
		data-python-lab-toggle
		aria-expanded="false"
		aria-controls={pythonLabPanelId}
		aria-label="打开 Python Lab"
	>
		<span class="python-lab-fab__icon">
			<Icon name="mdi:language-python" />
		</span>
		<span class="python-lab-fab__label">Python Lab</span>
	</button>

	<section
		id={pythonLabPanelId}
		class="python-lab-panel"
		data-python-lab-panel
		hidden
		aria-hidden="true"
		aria-label="Python Lab"
	>
		<div class="python-lab-panel__header">
			<div class="python-lab-panel__copy">
				<p class="python-lab-panel__eyebrow">Floating Workspace</p>
				<h3 class="python-lab-panel__title">Python Lab</h3>
				<p class="python-lab-panel__note">默认轻量编辑器，先保证可写、可拖、可运行。</p>
			</div>
			<button
				type="button"
				class="python-lab-panel__close"
				data-python-lab-close
				aria-label="收起 Python Lab"
			>
				<Icon name="mdi:close" />
			</button>
		</div>

		<div class="python-lab-panel__dragbar" data-python-lab-drag-handle aria-hidden="true">
			<span class="python-lab-panel__dragbar-grip"></span>
		</div>

		<div class="python-lab-panel__status" data-python-lab-status>
			轻量编辑器已就绪，首次运行时再加载浏览器内 Python。
		</div>

		<div class="python-lab-panel__editor-frame">
			<div class="python-lab-panel__editor-topbar" aria-hidden="true">
				<div class="python-lab-panel__editor-badge">Python 3</div>
				<div class="python-lab-panel__editor-hint">Tab 缩进 · Shift+Tab 退缩进 · Ctrl/Cmd+Enter 运行</div>
			</div>
			<div class="python-lab-panel__editor-shell">
				<div class="python-lab-panel__line-numbers" data-python-lab-gutter aria-hidden="true"></div>
				<textarea
					class="python-lab-panel__editor"
					data-python-lab-editor
					aria-label="Python Lab editor"
					spellcheck="false"
					autocapitalize="off"
					autocorrect="off"
				></textarea>
			</div>
		</div>

		<div class="python-lab-panel__actions">
			<button type="button" class="python-lab-panel__run" data-python-lab-run>
				运行代码
			</button>
			<button type="button" class="python-lab-panel__ghost" data-python-lab-reset>
				恢复示例
			</button>
			<button type="button" class="python-lab-panel__ghost" data-python-lab-clear>
				清空输出
			</button>
		</div>

		<pre class="python-lab-panel__output" data-python-lab-output aria-live="polite">等待运行…</pre>

		<textarea data-python-lab-source hidden>
from math import sqrt

nums = [1, 4, 9, 16, 25]
print([sqrt(n) for n in nums])
		</textarea>
	</section>
</div>

<style lang="stylus">
  .python-lab-shell
    position relative
    width 3.5rem
    height 3.5rem
    filter drop-shadow(0 0 16px rgba(118, 156, 255, .08))

  .python-lab-fab
    display inline-flex
    align-items center
    justify-content center
    width 3.5rem
    height 3.5rem
    padding 0
    border-radius 1.15rem
    border 1px solid rgba(118, 156, 255, .18)
    background linear-gradient(180deg, rgba(255,255,255,.74), rgba(247,250,255,.58)), radial-gradient(circle at top right, rgba(118,156,255,.15), transparent 8rem)
    box-shadow 0 22px 52px rgba(15, 23, 42, .14), inset 0 1px 0 rgba(255,255,255,.72)
    backdrop-filter blur(18px) saturate(1.04)
    -webkit-backdrop-filter blur(18px) saturate(1.04)
    color rgba(15, 23, 42, .88)
    transition transform .22s ease, box-shadow .22s ease, border-color .22s ease
    position relative
    overflow hidden

  .python-lab-fab:hover,
  .python-lab-fab:focus-visible
    transform translateY(-2px) scale(1.02)
    border-color rgba(118, 156, 255, .3)
    box-shadow 0 0 26px rgba(118, 156, 255, .16), 0 24px 56px rgba(15, 23, 42, .16)

  .python-lab-fab__icon
    display inline-flex
    align-items center
    justify-content center
    width 2rem
    height 2rem
    border-radius 999px
    background rgba(118, 156, 255, .12)
    color rgba(70, 97, 186, .92)
    font-size 1.1rem

  .python-lab-fab__label
    display none

  .python-lab-panel
    position fixed
    z-index 1400
    width unquote("min(30rem, calc(100vw - 2rem))")
    max-width unquote("calc(100vw - 2rem)")
    height unquote("min(42rem, calc(100vh - 2rem))")
    max-height unquote("calc(100vh - 2rem)")
    display grid
    grid-template-rows auto auto auto minmax(18rem, 1fr) auto minmax(6.25rem, auto)
    gap .85rem
    padding 1rem
    border-radius 1.55rem
    border 1px solid rgba(118, 156, 255, .18)
    background linear-gradient(180deg, rgba(255,255,255,.76), rgba(246,250,255,.6)), radial-gradient(circle at top right, rgba(118,156,255,.16), transparent 16rem)
    box-shadow 0 32px 88px rgba(15, 23, 42, .22), inset 0 1px 0 rgba(255,255,255,.72)
    backdrop-filter blur(22px) saturate(1.06)
    -webkit-backdrop-filter blur(22px) saturate(1.06)
    overflow hidden
    transform-origin bottom right
    transition transform .22s ease, box-shadow .22s ease, border-color .22s ease, opacity .22s ease

  .python-lab-panel[hidden]
    display none !important

  .python-lab-panel[data-state="open"]
    box-shadow 0 0 34px rgba(118, 156, 255, .14), 0 36px 96px rgba(15, 23, 42, .24), inset 0 1px 0 rgba(255,255,255,.72)

  .python-lab-panel[data-dragging]
    transition none

  .python-lab-panel__header
    display flex
    align-items flex-start
    justify-content space-between
    gap 1rem
    user-select none

  .python-lab-panel__eyebrow
    font-family var(--owen-font-ui)
    font-size .72rem
    font-weight 600
    letter-spacing .16em
    text-transform uppercase
    color rgba(70, 97, 186, .78)

  .python-lab-panel__title
    margin-top .16rem
    font-family var(--owen-font-display)
    font-size 1.18rem
    font-weight 700
    letter-spacing -.04em
    color rgba(15, 23, 42, .92)

  .python-lab-panel__note
    margin-top .24rem
    font-family var(--owen-font-reading)
    font-size .84rem
    line-height 1.7
    color rgba(15, 23, 42, .58)

  .python-lab-panel__close
    display inline-flex
    align-items center
    justify-content center
    width 2.2rem
    height 2.2rem
    border-radius 999px
    border 1px solid rgba(118, 156, 255, .14)
    background rgba(118, 156, 255, .08)
    color rgba(70, 97, 186, .88)
    transition transform .18s ease, box-shadow .18s ease

  .python-lab-panel__close:hover
    transform translateY(-1px) scale(1.015)
    box-shadow 0 10px 24px rgba(15, 23, 42, .12)

  .python-lab-panel__dragbar
    display flex
    align-items center
    justify-content center
    min-height 1.1rem
    margin-top -.15rem
    cursor grab
    user-select none
    touch-action none

  .python-lab-panel[data-dragging] .python-lab-panel__dragbar
    cursor grabbing

  .python-lab-panel__dragbar-grip
    width 4.4rem
    height .34rem
    border-radius 999px
    background linear-gradient(90deg, rgba(118, 156, 255, .24), rgba(132, 115, 255, .16))
    box-shadow inset 0 1px 0 rgba(255,255,255,.56), 0 0 0 1px rgba(118, 156, 255, .08)

  .python-lab-panel__status
    min-height 2.4rem
    padding .78rem .9rem
    border-radius 1rem
    border 1px solid rgba(118, 156, 255, .12)
    background rgba(15, 23, 42, .04)
    font-family var(--owen-font-reading)
    font-size .83rem
    line-height 1.65
    color rgba(15, 23, 42, .62)

  .python-lab-panel__editor-frame
    min-height 0
    height 100%
    border-radius 1.2rem
    border 1px solid rgba(118, 156, 255, .14)
    background rgba(9, 12, 19, .94)
    overflow hidden
    position relative
    display grid
    grid-template-rows auto minmax(0, 1fr)

  .python-lab-panel__editor-topbar
    display flex
    align-items center
    justify-content space-between
    gap .75rem
    min-height 2.5rem
    padding .65rem .9rem
    border-bottom 1px solid rgba(118, 156, 255, .12)
    background linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02))

  .python-lab-panel__editor-badge
    display inline-flex
    align-items center
    justify-content center
    min-height 1.55rem
    padding 0 .65rem
    border-radius .7rem
    border 1px solid rgba(118, 156, 255, .18)
    background rgba(118, 156, 255, .1)
    font-family var(--owen-font-ui)
    font-size .72rem
    font-weight 650
    letter-spacing .08em
    text-transform uppercase
    color rgba(219, 230, 255, .9)

  .python-lab-panel__editor-hint
    font-family var(--owen-font-ui)
    font-size .72rem
    letter-spacing .04em
    color rgba(219, 230, 255, .54)

  .python-lab-panel__editor-shell
    min-height 0
    display grid
    grid-template-columns auto minmax(0, 1fr)

  .python-lab-panel__line-numbers
    min-width 3rem
    padding 1rem .5rem 1rem .85rem
    border-right 1px solid rgba(118, 156, 255, .1)
    background rgba(255,255,255,.03)
    color rgba(206, 218, 242, .38)
    font-size .78rem
    line-height 1.72
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    text-align right
    user-select none
    overflow hidden
    white-space pre
    pointer-events none

  .python-lab-panel__editor
    width 100%
    height 100%
    min-height 0
    resize none
    padding 1rem 1.05rem
    border none
    outline none
    background transparent
    color rgba(227, 236, 255, .9)
    font-size .92rem
    line-height 1.72
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    white-space pre
    overflow auto
    caret-color rgba(214, 226, 255, .94)
    tab-size 4
    scrollbar-gutter stable

  .python-lab-panel__editor::selection
    background rgba(118, 156, 255, .24)

  .python-lab-panel__actions
    display flex
    gap .7rem
    flex-wrap wrap

  .python-lab-panel__run,
  .python-lab-panel__ghost
    min-height 2.7rem
    padding 0 1rem
    border-radius .95rem
    border 1px solid rgba(118, 156, 255, .16)
    font-size .86rem
    font-weight 640
    transition transform .18s ease, box-shadow .18s ease, border-color .18s ease

  .python-lab-panel__run
    background linear-gradient(135deg, rgba(93, 129, 255, .96), rgba(132, 115, 255, .92))
    color white
    box-shadow 0 18px 38px rgba(88, 115, 255, .24)

  .python-lab-panel__ghost
    background rgba(118, 156, 255, .08)
    color rgba(70, 97, 186, .9)

  .python-lab-panel__run:hover,
  .python-lab-panel__ghost:hover
    transform translateY(-1px) scale(1.01)
    border-color rgba(118, 156, 255, .26)
    box-shadow 0 0 18px rgba(118, 156, 255, .14), 0 12px 30px rgba(15, 23, 42, .12)

  .python-lab-panel__run[disabled]
    opacity .76
    cursor wait

  .python-lab-panel__output
    min-height 6.25rem
    max-height 10rem
    overflow auto
    padding 1rem
    border-radius 1rem
    border 1px solid rgba(118, 156, 255, .12)
    background rgba(9, 12, 19, .9)
    color rgba(227, 236, 255, .84)
    font-size .86rem
    line-height 1.65
    font-family "SF Mono", "JetBrains Mono Variable", Menlo, Monaco, ui-monospace, monospace
    white-space pre-wrap
    word-break break-word

  .python-lab-panel__editor,
  .python-lab-panel__output
    scrollbar-width thin
    scrollbar-color rgba(126, 98, 141, .34) transparent

  .python-lab-panel__editor::-webkit-scrollbar,
  .python-lab-panel__output::-webkit-scrollbar
    width .72rem
    height .72rem

  .python-lab-panel__editor::-webkit-scrollbar-track,
  .python-lab-panel__output::-webkit-scrollbar-track
    background transparent

  .python-lab-panel__editor::-webkit-scrollbar-thumb,
  .python-lab-panel__output::-webkit-scrollbar-thumb
    border .18rem solid transparent
    border-radius 999px
    background rgba(126, 98, 141, .28)
    background-clip padding-box

  :root:not(.dark) .python-lab-fab
