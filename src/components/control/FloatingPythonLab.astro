    box-shadow inset 0 1px 0 rgba(255,255,255,.12), 0 0 0 1px rgba(118, 156, 255, .12)

  :root.dark .python-lab-panel__ghost
    background rgba(118, 156, 255, .12)
    color rgba(225, 234, 255, .9)

  @media (max-width: 820px)
    .python-lab-panel
      width unquote("min(24rem, calc(100vw - 2rem))")
      height unquote("min(36rem, calc(100vh - 5.5rem))")
      max-height unquote("calc(100vh - 5.5rem)")
</style>

<script
	is:inline
	define:vars={{
		PYTHON_LAB_SCRIPT_URL: url("/scripts/python-lab.js"),
		PYTHON_LAB_UID: pythonLabUid,
	}}
>
	(() => {
		const root = document.getElementById(PYTHON_LAB_UID);
		if (!(root instanceof HTMLElement) || root.dataset.pythonLabLoader === "true") {
			return;
		}

		root.dataset.pythonLabLoader = "true";

		const boot = () => {
			if (typeof window.__owenInitPythonLab === "function") {
				window.__owenInitPythonLab(root);
				return;
			}

			let script = document.querySelector('script[data-python-lab-script="true"]');
			if (!(script instanceof HTMLScriptElement)) {
				script = document.createElement("script");
				script.src = PYTHON_LAB_SCRIPT_URL;
				script.dataset.pythonLabScript = "true";
				document.body.appendChild(script);
			}

			script.addEventListener(
				"load",
				() => {
					window.__owenInitPythonLab?.(root);
				},
				{ once: true },
			);
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", boot, { once: true });
		} else {
			boot();
		}
	})();
</script>
