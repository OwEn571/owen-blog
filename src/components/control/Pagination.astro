---
import type { Page } from "astro";
import { Icon } from "astro-icon/components";

import { url } from "../../utils/url-utils";

interface Props {
	page: Page;
	class?: string;
	style?: string;
	baseUrl?: string;
}

const { page, style, baseUrl = "/" } = Astro.props;

const HIDDEN = -1;

const className = Astro.props.class;

const ADJ_DIST = 2;
const VISIBLE = ADJ_DIST * 2 + 1;

// for test
let count = 1;
let l = page.currentPage;
let r = page.currentPage;
while (0 < l - 1 && r + 1 <= page.lastPage && count + 2 <= VISIBLE) {
	count += 2;
	l--;
	r++;
}
while (0 < l - 1 && count < VISIBLE) {
	count++;
	l--;
}
while (r + 1 <= page.lastPage && count < VISIBLE) {
	count++;
	r++;
}

const pages: number[] = [];
if (l > 1) {
	pages.push(1);
}
if (l === 3) {
	pages.push(2);
}
if (l > 3) {
	pages.push(HIDDEN);
}
for (let i = l; i <= r; i++) {
	pages.push(i);
}
if (r < page.lastPage - 2) {
	pages.push(HIDDEN);
}
if (r === page.lastPage - 2) {
	pages.push(page.lastPage - 1);
}
if (r < page.lastPage) {
	pages.push(page.lastPage);
}

const normalizedBaseUrl = (() => {
	if (baseUrl === "/") {
		return "/";
	}
	let normalized = baseUrl.startsWith("/") ? baseUrl : `/${baseUrl}`;
	if (!normalized.endsWith("/")) {
		normalized = `${normalized}/`;
	}
	return normalized;
})();

const getPageUrl = (p: number) => {
	if (normalizedBaseUrl === "/") {
		return p === 1 ? "/" : `/${p}/`;
	}
	return p === 1 ? normalizedBaseUrl : `${normalizedBaseUrl}${p}/`;
};
---

<div
	class:list={[
		className,
		"premium-pagination flex flex-row flex-wrap gap-3 justify-center items-center",
	]}
	style={style}
>
	<a
		href={page.url.prev || ""}
		aria-label={page.url.prev ? "Previous Page" : null}
		class:list={[
			"premium-pagination-nav shrink-0 overflow-hidden rounded-full text-[var(--primary)] w-11 h-11",
			{ disabled: page.url.prev == undefined },
		]}
	>
		<Icon
			name="material-symbols:chevron-left-rounded"
			class="text-[1.75rem]"
		/>
	</a>
	<div
		class="premium-pagination-track flex flex-row rounded-full items-center text-neutral-700 dark:text-neutral-300 font-bold"
	>
		{
			pages.map((p) => {
				if (p == HIDDEN) {
					return (
						<span class="premium-pagination-gap" aria-hidden="true">
							<Icon
								name="material-symbols:more-horiz"
								class="text-[1.25rem] text-[var(--deep-text)] opacity-60"
							/>
						</span>
					);
				}
				if (p == page.currentPage) {
					return (
						<div
							class="premium-pagination-current shrink-0 h-11 min-w-11 px-3 rounded-full inline-flex items-center justify-center
                    font-bold"
						>
							{p}
						</div>
					);
				}
				return (
					<a
						href={url(getPageUrl(p))}
						aria-label={`Page ${p}`}
						class="premium-pagination-link shrink-0 w-11 h-11 rounded-full overflow-hidden active:scale-[0.92]"
					>
						{p}
					</a>
				);
			})
		}
	</div>
	<a
		href={page.url.next || ""}
		aria-label={page.url.next ? "Next Page" : null}
		class:list={[
			"premium-pagination-nav shrink-0 overflow-hidden rounded-full text-[var(--primary)] w-11 h-11",
			{ disabled: page.url.next == undefined },
		]}
	>
		<Icon
			name="material-symbols:chevron-right-rounded"
			class="text-[1.75rem]"
		/>
	</a>
</div>

<style>
	.premium-pagination-track {
		min-height: 3.2rem;
		padding: 0.4rem;
		gap: 0.35rem;
		align-items: center;
		border: 1px solid rgba(118, 156, 255, 0.12);
		background:
			linear-gradient(
				180deg,
				rgba(255, 255, 255, 0.7),
				rgba(247, 250, 255, 0.42)
			),
			radial-gradient(
				circle at top right,
				rgba(118, 156, 255, 0.08),
				transparent 10rem
			);
		box-shadow:
			0 18px 46px rgba(15, 23, 42, 0.08),
			0 0 20px rgba(118, 156, 255, 0.06);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
	}

	.premium-pagination-link,
	.premium-pagination-nav,
	.premium-pagination-current,
	.premium-pagination-gap {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid transparent;
		background: transparent;
		color: var(--deep-text);
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			background-color 220ms ease,
			box-shadow 220ms ease,
			color 220ms ease;
	}

	.premium-pagination-gap {
		width: 2.75rem;
		height: 2.75rem;
		justify-content: center;
	}

	.premium-pagination-link:hover,
	.premium-pagination-nav:hover {
		border-color: rgba(118, 156, 255, 0.16);
		color: var(--primary);
		box-shadow:
			0 0 14px rgba(118, 156, 255, 0.12),
			0 0 28px rgba(118, 156, 255, 0.08);
		transform: translateY(-1px) scale(1.03);
	}

	.premium-pagination-link.disabled,
	.premium-pagination-nav.disabled {
		opacity: 0.34;
		pointer-events: none;
	}

	.premium-pagination-current {
		border: 1px solid rgba(118, 156, 255, 0.18);
		background:
			linear-gradient(
				180deg,
				rgba(118, 156, 255, 0.16),
				rgba(118, 156, 255, 0.08)
			),
			linear-gradient(
				180deg,
				rgba(255, 255, 255, 0.34),
				rgba(255, 255, 255, 0.08)
			);
		color: var(--primary);
		box-shadow:
			0 0 16px rgba(118, 156, 255, 0.16),
			0 0 34px rgba(118, 156, 255, 0.12);
	}

	:root.dark .premium-pagination-track {
		border-color: rgba(118, 156, 255, 0.16);
		background:
			linear-gradient(
				180deg,
				rgba(9, 12, 19, 0.62),
				rgba(5, 8, 14, 0.34)
			),
			radial-gradient(
				circle at top right,
				rgba(118, 156, 255, 0.12),
				transparent 10rem
			);
		box-shadow:
			0 20px 52px rgba(0, 0, 0, 0.24),
			0 0 24px rgba(118, 156, 255, 0.08);
	}

	:root.dark .premium-pagination-link,
	:root.dark .premium-pagination-nav {
		color: rgba(232, 238, 248, 0.82);
	}

	:root.dark .premium-pagination-link:hover,
	:root.dark .premium-pagination-nav:hover {
		border-color: rgba(118, 156, 255, 0.18);
		color: rgba(206, 220, 255, 0.98);
		box-shadow:
			0 0 16px rgba(118, 156, 255, 0.16),
			0 0 34px rgba(118, 156, 255, 0.12);
	}

	:root.dark .premium-pagination-current {
		border-color: rgba(118, 156, 255, 0.22);
		background:
			linear-gradient(
				180deg,
				rgba(118, 156, 255, 0.18),
				rgba(118, 156, 255, 0.1)
			),
			linear-gradient(
				180deg,
				rgba(255, 255, 255, 0.08),
				rgba(255, 255, 255, 0.03)
			);
		color: rgba(228, 236, 255, 0.98);
	}
</style>
