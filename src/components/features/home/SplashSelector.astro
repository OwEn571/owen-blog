---
import { Icon } from "astro-icon/components";

import TypewriterText from "@components/atoms/typewriter-text/TypewriterText.astro";
import { profileConfig, siteConfig } from "@/config";

import { homeSections } from "./entry-data";

const splashTitle = profileConfig.name || siteConfig.title;
---

<div id="splash-selector" class="splash-shell" data-state="opening" data-theme="dark" role="dialog" aria-modal="true" aria-label="开屏入口选择">
	<div class="splash-backdrop">
		<video
			class="splash-video"
			muted
			loop
			playsinline
			preload="none"
			poster="/assets/opening/qidian-splash-poster.jpg"
			data-poster-dark="/assets/opening/qidian-splash-poster.jpg"
			data-poster-light="/assets/opening/sakura-field-day-poster.svg"
			disableRemotePlayback
			data-splash-video
			aria-hidden="true"
		>
			<source data-src-dark="/assets/opening/qidian-splash.mp4" data-src-light="/assets/opening/sakura-field-day.mp4" type="video/mp4" />
		</video>
		<div class="splash-backdrop-overlay"></div>
	</div>
	<div class="splash-panel">
		<div class="splash-topbar">
			<div class="splash-dots" aria-hidden="true">
				<span></span>
				<span></span>
				<span></span>
			</div>
			<button
				type="button"
				class="splash-theme-toggle"
				data-splash-theme-toggle
				aria-label="切换日间与夜间主题"
			>
				<span class="splash-theme-toggle__icon splash-theme-toggle__icon--sun">
					<Icon name="material-symbols:light-mode-rounded" class="text-[1rem]" />
				</span>
				<span class="splash-theme-toggle__label">Theme Shift</span>
				<span class="splash-theme-toggle__icon splash-theme-toggle__icon--moon">
					<Icon name="material-symbols:dark-mode-outline-rounded" class="text-[1rem]" />
				</span>
			</button>
		</div>

		<div class="splash-copy">
			<p class="splash-kicker">Opening Screen</p>
			<h1 class="splash-title"><TypewriterText text={`${splashTitle} 的内容入口`} speed={94} deleteSpeed={42} pauseTime={4200} showCaret={true} class="splash-title__typed" /></h1>
			<p class="splash-description">
				先从这里选择你想进入的界面。四个分区保持同一套引擎，但拥有不同的内容节奏和观看方式。
			</p>
		</div>

		<div class="splash-grid">
			{
				homeSections.map((section, index) => (
					<a
						href={section.href}
						class="splash-choice"
						style={`--splash-accent: ${section.accent}; --splash-delay: ${index * 90}ms;`}
						data-splash-target
						data-no-swup
					>
						<div class="splash-choice-top">
							<span class="splash-choice-eyebrow">{section.eyebrow}</span>
							<div class="splash-choice-icon">
								<Icon name={section.icon} class="text-[1.55rem]" />
							</div>
						</div>
						<h2 class="splash-choice-title">{section.title}</h2>
						<p class="splash-choice-description">{section.description}</p>
						<div class="splash-choice-footer">
							<span>{section.note}</span>
							<span class="splash-choice-enter">
								进入
								<Icon name="material-symbols:arrow-forward-rounded" class="text-base" />
							</span>
						</div>
					</a>
				))
			}
		</div>
	</div>
</div>

<script is:inline>
	(() => {
		const root = document.getElementById("splash-selector");
		if (!root) return;

		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const optionLinks = root.querySelectorAll("[data-splash-target]");
		const themeToggle = root.querySelector("[data-splash-theme-toggle]");
		const video = root.querySelector("[data-splash-video]");
		const videoSource = video?.querySelector("source");
		const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
		const shouldReduceVideo =
			prefersReducedMotion ||
			Boolean(connection?.saveData) ||
			/(?:^|slow-)?2g/i.test(connection?.effectiveType || "");
		let isNavigating = false;
		let isVideoActivated = false;
		let isThemeSwitching = false;
		let themeObserver;

		const resolveTheme = () =>
			document.documentElement.classList.contains("dark") ? "dark" : "light";

		const applyThemeAssets = (reloadVideo = false) => {
			const theme = resolveTheme();
			root.dataset.theme = theme;

			if (!(video instanceof HTMLVideoElement) || !(videoSource instanceof HTMLSourceElement)) {
				return;
			}

			const nextPoster =
				theme === "dark" ? video.dataset.posterDark : video.dataset.posterLight;
			if (nextPoster) {
				video.poster = nextPoster;
			} else {
				video.removeAttribute("poster");
			}

			const nextSrc =
				theme === "dark" ? videoSource.dataset.srcDark : videoSource.dataset.srcLight;
			if (!nextSrc || (!reloadVideo && !isVideoActivated)) {
				return;
			}

			if (videoSource.getAttribute("src") !== nextSrc) {
				videoSource.src = nextSrc;
				video.load();
			}

			if (!shouldReduceVideo && isVideoActivated) {
				video.play().catch(() => {});
			}
		};

		const lockPage = () => {
			document.documentElement.classList.add("splash-active");
			document.body.classList.add("splash-active");
		};

		const unlockPage = () => {
			document.documentElement.classList.remove("splash-active");
			document.body.classList.remove("splash-active");
		};

		const restoreSplash = () => {
			isNavigating = false;
			applyThemeAssets(isVideoActivated);
			root.dataset.state = "ready";
			lockPage();
			if (!shouldReduceVideo && isVideoActivated) {
				video?.play?.().catch(() => {});
			}
		};

		const activateVideo = () => {
			if (
				shouldReduceVideo ||
				isVideoActivated ||
				!(video instanceof HTMLVideoElement) ||
				!(videoSource instanceof HTMLSourceElement)
			) {
				return;
			}

			isVideoActivated = true;
			applyThemeAssets(true);
		};

		const scheduleVideoActivation = () => {
			if (shouldReduceVideo) {
				return;
			}

			if ("requestIdleCallback" in window) {
				window.requestIdleCallback(activateVideo, { timeout: 2200 });
				return;
			}

			window.setTimeout(activateVideo, 1400);
		};

		const preloadRoute = (href) => {
			if (!href) return;

			if (!document.head.querySelector(`link[rel="prefetch"][href="${href}"]`)) {
				const link = document.createElement("link");
				link.rel = "prefetch";
				link.as = "document";
				link.href = href;
				document.head.appendChild(link);
			}
		};

		const navigateTo = (href) => {
			if (!href || isNavigating) return;
			isNavigating = true;
			root.dataset.state = "navigating";

			window.location.assign(href);
		};

		const toggleTheme = () => {
			if (isThemeSwitching) {
				return;
			}

			isThemeSwitching = true;
			const nextTheme = resolveTheme() === "dark" ? "light" : "dark";
			const dark = nextTheme === "dark";

			window.dispatchEvent(
				new CustomEvent("owen:theme-transition", {
					detail: { phase: "start", theme: nextTheme, dark },
				}),
			);

			window.setTimeout(() => {
				document.documentElement.classList.toggle("dark", dark);
				document.documentElement.setAttribute(
					"data-theme",
					dark ? "github-dark" : "github-light",
				);
				localStorage.setItem("theme", nextTheme);
				window.dispatchEvent(
					new CustomEvent("owen:theme-applied", {
						detail: { theme: nextTheme, dark },
					}),
				);
			}, prefersReducedMotion ? 0 : 210);

			window.setTimeout(() => {
				window.dispatchEvent(
					new CustomEvent("owen:theme-transition", {
						detail: { phase: "end", theme: nextTheme, dark },
					}),
				);
				isThemeSwitching = false;
			}, prefersReducedMotion ? 0 : 760);
		};

		applyThemeAssets(false);
		themeObserver = new MutationObserver(() => {
			applyThemeAssets(isVideoActivated);
		});
		themeObserver.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ["class"],
		});

		lockPage();
		if (shouldReduceVideo) {
			if (video instanceof HTMLVideoElement) {
				video.pause();
				video.removeAttribute("autoplay");
			}
			root.dataset.state = "ready";
		} else {
			requestAnimationFrame(() => {
				root.dataset.state = "ready";
			});
			scheduleVideoActivation();
		}

		optionLinks.forEach((link) => {
			const href = link.getAttribute("href");
			if (href) {
				link.addEventListener("pointerenter", () => preloadRoute(href), {
					passive: true,
				});
				link.addEventListener("focus", () => preloadRoute(href));
				link.addEventListener("pointerenter", activateVideo, {
					passive: true,
				});
			}

			link.addEventListener("click", (event) => {
				event.preventDefault();
				navigateTo(href);
			});
		});

		if (themeToggle instanceof HTMLButtonElement) {
			themeToggle.addEventListener("click", () => {
				toggleTheme();
			});
		}

		window.addEventListener("pagehide", () => {
			themeObserver?.disconnect?.();
			unlockPage();
		});

		window.addEventListener("pageshow", () => {
			restoreSplash();
		});

		document.addEventListener("visibilitychange", () => {
			if (!(video instanceof HTMLVideoElement)) {
				return;
			}

			if (document.hidden) {
				video.pause();
				return;
			}

			if (!shouldReduceVideo && isVideoActivated) {
				video.play().catch(() => {});
			}
		});
	})();
</script>

<style>
	.splash-shell {
		position: fixed;
		inset: 0;
		z-index: 180;
		display: block;
		color-scheme: dark;
		overflow-x: hidden;
		overflow-y: auto;
		overscroll-behavior: contain;
		-webkit-overflow-scrolling: touch;
		touch-action: pan-y pinch-zoom;
	}

	.splash-backdrop {
		position: absolute;
		inset: 0;
		overflow: hidden;
		background: #02050c;
	}

	.splash-video {
		position: absolute;
		inset: -2%;
		width: 104%;
		height: 104%;
		object-fit: cover;
		opacity: 0.94;
		filter: brightness(0.88) saturate(1.36) contrast(1.14);
		transform: scale(1.02);
		transform-origin: center;
		pointer-events: none;
	}

	.splash-backdrop-overlay {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 16% 20%, rgba(90, 128, 255, 0.2), transparent 24rem),
			radial-gradient(circle at 78% 26%, rgba(183, 123, 255, 0.14), transparent 22rem),
			radial-gradient(circle at 68% 78%, rgba(136, 170, 255, 0.12), transparent 20rem),
			linear-gradient(180deg, rgba(2, 4, 10, 0.18), rgba(2, 4, 10, 0.62)),
			radial-gradient(circle at center, transparent 48%, rgba(2, 4, 10, 0.34) 100%);
	}

	.splash-panel {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-rows: auto auto 1fr;
		width: 100%;
		min-height: 100dvh;
		margin: 0;
		padding:
			max(1rem, env(safe-area-inset-top))
			clamp(1rem, 2vw, 2.2rem)
			max(1rem, env(safe-area-inset-bottom));
		border-radius: 0;
		background:
			linear-gradient(180deg, rgba(2, 4, 10, 0.16), rgba(2, 4, 10, 0.46)),
			radial-gradient(circle at top left, rgba(255, 255, 255, 0.04), transparent 20rem);
		border: none;
		box-shadow: none;
		overflow: visible;
		isolation: isolate;
	}

	.splash-topbar,
	.splash-choice-top,
	.splash-choice-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
	}

	.splash-dots {
		display: inline-flex;
		gap: 0.45rem;
	}

	.splash-status,
	.splash-theme-toggle {
		display: inline-flex;
		align-items: center;
		min-height: 2.4rem;
		padding: 0 0.95rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: rgba(255, 255, 255, 0.7);
		font-size: 0.82rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.splash-theme-toggle {
		gap: 0.55rem;
		cursor: pointer;
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease,
			background-color 220ms ease;
	}

	.splash-theme-toggle:hover,
	.splash-theme-toggle:focus-visible {
		transform: translateY(-1px) scale(1.01);
		border-color: rgba(255, 255, 255, 0.2);
		box-shadow:
			0 0 18px rgba(118, 156, 255, 0.12),
			0 14px 34px rgba(2, 4, 10, 0.16);
	}

	.splash-theme-toggle__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.45rem;
		height: 1.45rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.08);
	}

	.splash-theme-toggle__label {
		font-size: 0.78rem;
		letter-spacing: 0.16em;
	}

	.splash-dots span {
		width: 0.72rem;
		height: 0.72rem;
		border-radius: 999px;
		background: rgba(15, 23, 42, 0.18);
	}

	.splash-dots span:nth-child(1) {
		background: rgba(255, 95, 86, 0.92);
	}

	.splash-dots span:nth-child(2) {
		background: rgba(255, 189, 46, 0.92);
	}

	.splash-dots span:nth-child(3) {
		background: rgba(39, 201, 63, 0.92);
	}

	.splash-copy {
		max-width: 56rem;
		margin-top: clamp(2.5rem, 9vh, 7rem);
	}

	.splash-kicker,
	.splash-choice-eyebrow {
		font-size: 0.76rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
	}

	.splash-title {
		margin-top: 0.65rem;
		max-width: min(100%, 18ch);
		font-family: var(--owen-font-display, "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", system-ui, sans-serif);
		font-size: clamp(2.9rem, 5.2vw, 5.55rem);
		line-height: 0.9;
		font-weight: 720;
		letter-spacing: -0.072em;
		color: rgba(247, 250, 255, 0.96);
		text-wrap: pretty;
		text-shadow: 0 14px 34px rgba(2, 4, 10, 0.34);
	}

	.splash-title__typed {
		min-height: 1em;
	}

	.splash-description {
		margin-top: 1rem;
		max-width: 42rem;
		font-family: var(--owen-font-reading, "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", system-ui, sans-serif);
		font-size: 1.02rem;
		line-height: 1.88;
		letter-spacing: 0.01em;
		color: rgba(232, 238, 248, 0.72);
	}

	.splash-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		align-self: end;
		margin-top: auto;
		padding-top: clamp(2rem, 5vh, 4rem);
	}

	.splash-choice {
		position: relative;
		display: flex;
		flex-direction: column;
		min-height: 16rem;
		padding: 1.35rem;
		border-radius: 1.9rem;
		border: 1px solid rgb(var(--splash-accent) / 0.1);
		background:
			linear-gradient(180deg, rgba(8, 12, 20, 0.46), rgba(5, 8, 14, 0.28)),
			radial-gradient(circle at top right, rgb(var(--splash-accent) / 0.24), transparent 12rem);
		box-shadow:
			0 24px 72px rgba(0, 0, 0, 0.24),
			0 0 18px rgb(var(--splash-accent) / 0.06);
		backdrop-filter: blur(34px) saturate(1.12);
		-webkit-backdrop-filter: blur(34px) saturate(1.12);
		transition:
			transform 320ms ease,
			box-shadow 320ms ease,
			border-color 320ms ease,
			background-color 320ms ease;
		overflow: hidden;
		will-change: transform, box-shadow;
	}

	.splash-choice::before {
		content: "";
		position: absolute;
		inset: auto -15% -40% auto;
		width: 9rem;
		height: 9rem;
		border-radius: 999px;
		background: radial-gradient(circle, rgb(var(--splash-accent) / 0.38), transparent 72%);
		opacity: 0;
		transform: scale(0.8);
		transition:
			opacity 320ms ease,
			transform 420ms ease;
		pointer-events: none;
	}

	.splash-choice::after {
		content: "";
		position: absolute;
		inset: -0.2rem;
		border-radius: inherit;
		opacity: 0;
		pointer-events: none;
		box-shadow:
			0 0 0 1px rgb(var(--splash-accent) / 0.12),
			0 0 20px rgb(var(--splash-accent) / 0.18),
			0 0 44px rgb(var(--splash-accent) / 0.14),
			0 0 88px rgb(var(--splash-accent) / 0.08);
		transition: opacity 300ms ease;
	}

	.splash-choice:hover {
		transform: translateY(-4px) scale(1.014);
		border-color: rgb(var(--splash-accent) / 0.24);
		box-shadow:
			0 28px 84px rgba(0, 0, 0, 0.24),
			0 0 18px rgb(var(--splash-accent) / 0.22),
			0 0 36px rgb(var(--splash-accent) / 0.18),
			0 0 88px rgb(var(--splash-accent) / 0.12),
			0 0 128px rgb(var(--splash-accent) / 0.06);
	}

	.splash-choice:focus-visible {
		transform: translateY(-4px) scale(1.014);
		border-color: rgb(var(--splash-accent) / 0.28);
		box-shadow:
			0 28px 84px rgba(0, 0, 0, 0.26),
			0 0 20px rgb(var(--splash-accent) / 0.24),
			0 0 42px rgb(var(--splash-accent) / 0.2),
			0 0 96px rgb(var(--splash-accent) / 0.14),
			0 0 136px rgb(var(--splash-accent) / 0.08);
	}

	.splash-choice:hover::before {
		opacity: 1;
		transform: scale(1);
	}

	.splash-choice:hover::after,
	.splash-choice:focus-visible::after {
		opacity: 1;
	}

	.splash-choice-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 999px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.06));
		color: rgba(248, 250, 255, 0.98);
		border: 1px solid rgba(255, 255, 255, 0.12);
		box-shadow: none;
		transition:
			transform 260ms ease,
			box-shadow 260ms ease,
			background-color 260ms ease;
	}

	.splash-choice-icon :global(svg) {
		filter: none;
	}

	.splash-choice:hover .splash-choice-icon {
		transform: scale(1.08);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.08));
		box-shadow: none;
	}

	.splash-choice-title {
		margin-top: auto;
		padding-top: 1.8rem;
		font-family: var(--owen-font-display, "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", system-ui, sans-serif);
		font-size: clamp(1.72rem, 3vw, 2.26rem);
		line-height: 1;
		font-weight: 710;
		letter-spacing: -0.05em;
		color: rgba(247, 250, 255, 0.94);
	}

	.splash-choice-description {
		margin-top: 0.85rem;
		font-family: var(--owen-font-reading, "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", system-ui, sans-serif);
		font-size: 0.97rem;
		line-height: 1.78;
		letter-spacing: 0.008em;
		color: rgba(223, 231, 244, 0.66);
	}

	.splash-choice:hover .splash-choice-title {
		color: rgba(255, 255, 255, 0.99);
		text-shadow: 0 0 22px rgb(var(--splash-accent) / 0.16);
	}

	.splash-choice-footer {
		margin-top: 1.2rem;
		font-size: 0.92rem;
		color: rgba(223, 231, 244, 0.46);
	}

	.splash-choice-enter {
		display: inline-flex;
		align-items: center;
		gap: 0.2rem;
		font-weight: 600;
		color: rgb(var(--splash-accent) / 0.96);
	}


	.splash-shell[data-theme="light"] {
		color-scheme: light;
	}

	.splash-shell[data-theme="light"] .splash-backdrop {
		background: linear-gradient(180deg, #fffdfd 0%, #fff2f7 100%);
	}

	.splash-shell[data-theme="light"] .splash-video {
		opacity: 0.97;
		filter: brightness(1.04) saturate(1.08) contrast(1.02);
		transform: scale(1.015);
	}

	.splash-shell[data-theme="light"] .splash-backdrop-overlay {
		background:
			radial-gradient(circle at 16% 20%, rgba(255, 186, 209, 0.34), transparent 24rem),
			radial-gradient(circle at 78% 26%, rgba(229, 198, 255, 0.28), transparent 22rem),
			radial-gradient(circle at 68% 78%, rgba(255, 222, 232, 0.28), transparent 20rem),
			linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 241, 247, 0.66)),
			radial-gradient(circle at center, transparent 48%, rgba(255, 255, 255, 0.16) 100%);
	}

	.splash-shell[data-theme="light"] .splash-panel {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 244, 248, 0.42)),
			radial-gradient(circle at top left, rgba(255, 255, 255, 0.44), transparent 20rem);
	}

	.splash-shell[data-theme="light"] .splash-status,
	.splash-shell[data-theme="light"] .splash-theme-toggle {
		background: rgba(255, 255, 255, 0.62);
		border-color: rgba(255, 180, 204, 0.22);
		color: rgba(136, 72, 101, 0.7);
