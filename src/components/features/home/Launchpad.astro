---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";

import PostCard from "@components/features/posts/PostCard.astro";

import { homeSections } from "./entry-data";

interface Props {
	recentPosts?: CollectionEntry<"posts">[];
}

const { recentPosts = [] } = Astro.props as Props;

const overviewCards = [
	{
		title: "首页是总览，不再代替开屏",
		copy: "真正的四入口选择现在放在全屏开屏层里，首页则负责承接内容、说明结构和展示最近更新。",
	},
	{
		title: "四个分区共享一套引擎",
		copy: "Study、Lab、Lounge 和 Archive 会共用底层引擎，但每个分区都拥有独立的节奏与展示逻辑。",
	},
];
---

<div class="section-page home-shell">
	<section class="section-hero section-hero--home">
		<div class="home-hero-copy">
			<p class="section-kicker">Personal System</p>
			<h1 class="section-title">
				Study、Lab、Lounge 与 Archive，用同一套内容引擎展开。
			</h1>
			<p class="section-description">
				首页现在只做总览与承接，不再代替开屏。你进入站点时先通过全屏开屏选择方向，回到首页时看到的是整个系统的结构概览。
			</p>
			<div class="home-actions">
				<a href="/study/" class="home-primary-action">
					进入 Study
					<Icon name="material-symbols:arrow-forward-rounded" class="text-lg" />
				</a>
				<a href="/archive/" class="home-secondary-action">浏览 Archive</a>
			</div>
		</div>

		<div class="card-base home-viewport">
			<div class="home-viewport-top">
				<div class="home-viewport-dots" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</div>
				<span class="home-viewport-label">Interface Map</span>
			</div>

			<div class="home-viewport-list">
				{
					homeSections.map((section) => (
						<a
							href={section.href}
							class="home-viewport-row"
							style={`--home-accent: ${section.accent};`}
						>
							<div class="home-viewport-icon">
								<Icon name={section.icon} class="text-[1.2rem]" />
							</div>
							<div class="home-viewport-text">
								<strong>{section.title}</strong>
								<span>{section.note}</span>
							</div>
							<Icon
								name="material-symbols:arrow-forward-rounded"
								class="home-viewport-arrow text-lg"
							/>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class="surface-grid home-entry-grid">
		{
			homeSections.map((section) => (
				<a
					href={section.href}
					class="card-base surface-card home-entry-card"
					style={`--home-accent: ${section.accent};`}
				>
					<div class="surface-card-top">
						<span class="surface-kicker">{section.eyebrow}</span>
						<div class="surface-icon">
							<Icon name={section.icon} class="text-[1.25rem]" />
						</div>
					</div>
					<h2 class="surface-title">{section.title}</h2>
					<p class="surface-copy">{section.description}</p>
					<span class="surface-link">
						{section.note}
						<Icon name="material-symbols:arrow-forward-rounded" class="text-base" />
					</span>
				</a>
			))
		}
	</section>

	<section class="surface-grid home-overview-grid">
		{
			overviewCards.map((item) => (
				<article class="card-base surface-card home-overview-card">
					<span class="surface-kicker">Blueprint</span>
					<h2 class="surface-title">{item.title}</h2>
					<p class="surface-copy">{item.copy}</p>
				</article>
			))
		}
	</section>

	<section class="home-latest">
			<div class="home-latest-head">
				<div>
					<p class="section-kicker">Recent Notes</p>
					<h2 class="home-latest-title">最近 Study 文章</h2>
				</div>
			<a href="/study/" class="home-secondary-action home-head-action">查看全部</a>
		</div>

		{
			recentPosts.length > 0 ? (
				<div class="flex flex-col gap-4">
					{recentPosts.map((entry, index) => (
						<PostCard
							entry={entry}
							class:list={["onload-animation", "home-preview-card"]}
							style={`--i: ${index}; --interval: 90ms;`}
						/>
					))}
				</div>
			) : (
				<div class="card-base surface-card home-empty">
					<h3 class="surface-title">最近文章会显示在这里</h3>
					<p class="surface-copy">你继续写文章之后，首页会自动展示最近更新，开屏负责分流，首页负责总览。</p>
				</div>
			)
		}
	</section>
</div>

<style>
	.home-hero-copy {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.home-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 1.6rem;
	}

	.home-primary-action,
	.home-secondary-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		min-height: 3.1rem;
		padding: 0 1.15rem;
		border-radius: 999px;
		font-weight: 600;
		transition:
			transform 220ms ease,
			background-color 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease,
			color 220ms ease;
	}

	.home-primary-action {
		background: linear-gradient(180deg, rgba(15, 23, 42, 0.94), rgba(30, 41, 59, 0.92));
		color: white;
		box-shadow: 0 20px 48px rgba(15, 23, 42, 0.14);
	}

	.home-secondary-action {
		border: 1px solid rgba(15, 23, 42, 0.08);
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.62));
		color: rgba(15, 23, 42, 0.78);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.62);
	}

	.home-primary-action:hover,
	.home-secondary-action:hover {
		transform: translateY(-1px);
	}

	:root.dark .home-primary-action {
		background: rgba(255, 255, 255, 0.92);
		color: rgba(15, 23, 42, 0.92);
	}

	:root.dark .home-secondary-action {
		background: rgba(255, 255, 255, 0.06);
		border-color: rgba(255, 255, 255, 0.08);
		color: rgba(255, 255, 255, 0.8);
	}

	.home-viewport {
		padding: 1.15rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.72));
	}

	:root.dark .home-viewport {
		background:
			linear-gradient(180deg, rgba(20, 23, 32, 0.96), rgba(15, 18, 25, 0.82));
	}

	.home-viewport-top,
	.surface-card-top,
	.home-latest-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
	}

	.home-viewport-dots {
		display: inline-flex;
		gap: 0.4rem;
	}

	.home-viewport-dots span {
		width: 0.68rem;
		height: 0.68rem;
		border-radius: 999px;
		background: rgba(15, 23, 42, 0.18);
	}

	.home-viewport-dots span:nth-child(1) {
		background: rgba(255, 95, 86, 0.92);
	}

	.home-viewport-dots span:nth-child(2) {
		background: rgba(255, 189, 46, 0.92);
	}

	.home-viewport-dots span:nth-child(3) {
		background: rgba(39, 201, 63, 0.92);
	}

	.home-viewport-label {
		font-size: 0.8rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(15, 23, 42, 0.45);
	}

	:root.dark .home-viewport-label {
		color: rgba(255, 255, 255, 0.45);
	}

	.home-viewport-list {
		display: grid;
		gap: 0.8rem;
		margin-top: 1.1rem;
	}

	.home-viewport-row {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		padding: 1rem 1.05rem;
		border-radius: 1.3rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.58)),
			radial-gradient(circle at right center, rgba(var(--home-accent), 0.15), transparent 9rem);
		border: 1px solid rgba(15, 23, 42, 0.05);
		transition:
			transform 220ms ease,
			background-color 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.54);
	}

	.home-viewport-row:hover {
		transform: translateX(4px);
		box-shadow:
			0 18px 34px rgba(15, 23, 42, 0.07),
			inset 0 1px 0 rgba(255, 255, 255, 0.62);
	}

	:root.dark .home-viewport-row {
		background:
			radial-gradient(circle at right center, rgba(var(--home-accent), 0.16), transparent 9rem),
			rgba(255, 255, 255, 0.05);
		border-color: rgba(255, 255, 255, 0.08);
	}

	.home-viewport-icon,
	.surface-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.8rem;
		height: 2.8rem;
		border-radius: 999px;
		background: rgba(var(--home-accent), 0.16);
		color: rgba(var(--home-accent), 0.96);
	}

	.home-viewport-text {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		min-width: 0;
	}

	.home-viewport-text strong {
		font-size: 1rem;
		color: rgba(15, 23, 42, 0.9);
	}

	.home-viewport-text span {
		font-size: 0.9rem;
		color: rgba(15, 23, 42, 0.55);
	}

	:root.dark .home-viewport-text strong {
		color: rgba(255, 255, 255, 0.88);
	}

	:root.dark .home-viewport-text span {
		color: rgba(255, 255, 255, 0.55);
	}

	.home-viewport-arrow {
		margin-left: auto;
		color: rgba(var(--home-accent), 0.96);
	}

	.home-entry-card {
		--home-accent: 104 140 255;
		min-height: 14.75rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.72)),
			radial-gradient(circle at top right, rgba(var(--home-accent), 0.18), transparent 10rem);
	}

	:root.dark .home-entry-card {
		background:
			radial-gradient(circle at top right, rgba(var(--home-accent), 0.17), transparent 12rem),
			linear-gradient(180deg, rgba(19, 22, 31, 0.94), rgba(15, 18, 25, 0.8));
	}

	.home-overview-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.home-overview-card {
		min-height: 11rem;
	}

	.home-latest {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.home-latest-title {
		margin-top: 0.35rem;
		font-size: clamp(1.65rem, 3vw, 2.1rem);
		line-height: 1.05;
		font-weight: 700;
		letter-spacing: -0.04em;
		color: rgba(15, 23, 42, 0.9);
	}

	:root.dark .home-latest-title {
		color: rgba(255, 255, 255, 0.9);
	}

	.home-head-action {
		min-height: 2.6rem;
	}

	@media (min-width: 960px) {
		.home-viewport {
			padding: 1.2rem;
		}
	}

	@media (max-width: 860px) {
		.home-overview-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.home-actions,
		.home-latest-head {
			flex-direction: column;
			align-items: flex-start;
		}

		.home-entry-card {
			min-height: auto;
		}
	}
</style>
