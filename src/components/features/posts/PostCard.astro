---
import { render } from "astro:content";
import { Icon } from "astro-icon/components";

import { getFileDirFromPath, getPostUrl, getTagUrl } from "@/utils/url-utils";

import { siteConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import Image from "../../atoms/Image/Image.astro";
import PostMetadata from "./PostMeta.astro";
import type { PostCardProps } from "./types";

const {
	entry,
	style,
	preferUpdatedDate = false,
}: PostCardProps = Astro.props as PostCardProps;
const className = Astro.props.class;

const {
	title,
	published,
	updated,
	tags,
	category,
	image,
	description,
	pinned,
} = entry.data;

const url = getPostUrl(entry);
const hasCover = image !== undefined && image !== null && image !== "";
const coverWidth = "28%";

const { remarkPluginFrontmatter } = await render(entry);
---

<div
	class:list={[
		"apple-post-card card-base flex flex-col-reverse md:flex-col w-full rounded-[var(--radius-large)] overflow-hidden relative border border-transparent",
		className,
	]}
	style={style}
>
	<div
		class:list={[
			"pl-6 md:pl-8 pr-6 md:pr-4 pt-6 md:pt-8 pb-6 md:pb-8 relative",
			{
				"w-full md:w-[calc(100%_-_3.25rem_-_0.75rem)]": !hasCover,
				"w-full md:w-[calc(100%_-_var(--coverWidth)_-_0.75rem)]": hasCover,
			},
		]}
	>
		<a
			href={url}
			data-no-swup
			class="post-card-title transition group w-full block font-bold mb-3 text-[1.82rem] md:text-[2.05rem] leading-[1.03] tracking-[-0.05em] text-90
        hover:text-[var(--primary)] dark:hover:text-[var(--primary)]
        active:text-[var(--title-active)] dark:active:text-[var(--title-active)]
        before:w-1 before:h-6 before:rounded-md before:bg-[var(--primary)]
        before:absolute
        before:top-[2.35rem] before:left-[1.05rem] before:hidden md:before:block"
		>
			{
				pinned && (
					<Icon
						name="mdi:pin"
						class="inline text-[var(--primary)] text-2xl mr-2 -translate-y-0.5"
					/>
				)
			}
			{title}
			<Icon
				class="inline text-[2rem] text-[var(--primary)] md:hidden translate-y-0.5 absolute"
				name="material-symbols:chevron-right-rounded"
			/>
			<Icon
				class="text-[var(--primary)] text-[2rem] transition hidden md:inline absolute translate-y-0.5 opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0"
				name="material-symbols:chevron-right-rounded"
			/>
		</a>

		<PostMetadata
			published={published}
			updated={updated}
			tags={tags}
			category={category || ""}
			hideTagsForMobile={true}
			hideUpdateDate={true}
			preferUpdatedDate={preferUpdatedDate}
			className="mb-4"
			showOnlyBasicMeta={true}
			words={remarkPluginFrontmatter.words}
			showWordCount={true}
		/>

		<div
			class:list={[
				"post-card-description transition text-75 mb-4 pr-4 text-[0.98rem] leading-7",
				{ "line-clamp-3 md:line-clamp-2": !description },
			]}
		>
			{description || remarkPluginFrontmatter.excerpt}
		</div>

		<div class="post-card-tags flex flex-wrap gap-2 mt-2">
			{
				tags && tags.length > 0 ? (
					tags.map((tag) => (
						<a
							href={getTagUrl(tag)}
							data-no-swup
							class:list={[
								siteConfig.tagStyle?.useNewStyle
									? "link-lg transition text-50 text-xs font-medium px-2.5 py-1 rounded-full hover:text-[var(--primary)] dark:hover:text-[var(--primary)] active:text-[var(--primary)] dark:active:text-[var(--primary)] group/tag whitespace-nowrap"
									: "btn-regular h-7 text-xs px-2.5 rounded-full",
							]}
							aria-label={`View all posts tagged with ${tag.trim()}`}
						>
							<span class="transition-transform group-hover/tag:translate-x-0.5">
								# {tag.trim()}
							</span>
						</a>
					))
				) : (
					<span class="text-xs text-50">{i18n(I18nKey.noTags)}</span>
				)
			}
		</div>
	</div>

	{
		hasCover && (
			<a
				href={url}
				data-no-swup
				aria-label={title}
				class:list={[
					"group",
					"post-card-cover",
					"max-h-[20vh] md:max-h-none mx-4 mt-4 -mb-2 md:mb-0 md:mx-0 md:mt-0",
					"md:w-[var(--coverWidth)] relative md:absolute md:top-3 md:bottom-3 md:right-3 rounded-[1.35rem] overflow-hidden active:scale-95",
				]}
			>
				<div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/30 group-active:bg-black/50 transition" />
				<div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center ">
					<Icon
						name="material-symbols:chevron-right-rounded"
						class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-5xl"
					/>
				</div>
				<Image
					src={image}
					basePath={getFileDirFromPath(entry.filePath || "")}
					alt="Cover Image of the Post"
					loading="eager"
					class="w-full h-full"
				/>
			</a>
		)
	}

	{
		!hasCover && (
			<a
				href={url}
				data-no-swup
				aria-label={title}
				class="!hidden md:!flex btn-regular w-[3.25rem]
         absolute right-3 top-3 bottom-3 rounded-xl bg-[var(--enter-btn-bg)]
         hover:bg-[var(--enter-btn-bg-hover)] active:bg-[var(--enter-btn-bg-active)] active:scale-95
        "
			>
				<Icon
					name="material-symbols:chevron-right-rounded"
					class="transition text-[var(--primary)] text-4xl mx-auto"
				/>
			</a>
		)
	}
</div>
<style define:vars={{ coverWidth }}></style>
<style>
	.apple-post-card {
		position: relative;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.72));
		border-color: rgba(118, 156, 255, 0.12);
		box-shadow:
			0 24px 56px rgba(15, 23, 42, 0.08),
			0 0 18px rgba(118, 156, 255, 0.06);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		transition:
			transform 280ms ease,
			box-shadow 280ms ease,
			border-color 280ms ease;
	}

	.apple-post-card::before {
		content: "";
		position: absolute;
		inset: 0 0 auto;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(118, 156, 255, 0.78), transparent);
		opacity: 0.72;
		pointer-events: none;
	}

	:root.dark .apple-post-card {
		background:
			linear-gradient(180deg, rgba(22, 24, 31, 0.94), rgba(17, 19, 26, 0.82));
		border-color: rgba(118, 156, 255, 0.14);
		box-shadow:
			0 30px 64px rgba(0, 0, 0, 0.22),
			0 0 18px rgba(118, 156, 255, 0.08);
	}

	.apple-post-card:hover {
		transform: translateY(-3px) scale(1.008);
		border-color: rgba(118, 156, 255, 0.2);
		box-shadow:
			0 34px 70px rgba(15, 23, 42, 0.12),
			0 0 18px rgba(118, 156, 255, 0.14),
			0 0 36px rgba(118, 156, 255, 0.12),
			0 0 72px rgba(118, 156, 255, 0.06);
	}

	:root.dark .apple-post-card:hover {
		box-shadow:
			0 36px 76px rgba(0, 0, 0, 0.28),
			0 0 18px rgba(118, 156, 255, 0.16),
			0 0 40px rgba(118, 156, 255, 0.14),
			0 0 80px rgba(118, 156, 255, 0.08);
	}

	.apple-post-card :global(img) {
		transition:
			transform 320ms ease,
			filter 320ms ease;
	}

	.apple-post-card:hover :global(img) {
		transform: scale(1.03);
		filter: saturate(1.05) contrast(1.02);
	}

	.post-card-title {
		max-width: 100%;
		font-family: var(--owen-font-display);
		text-wrap: balance;
	}

	.post-card-description {
		font-family: var(--owen-font-reading);
		color: color-mix(in srgb, var(--text-primary) 70%, transparent);
	}

	.post-card-tags {
		padding-top: 0.15rem;
	}

	.post-card-cover::after {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent 28%),
			radial-gradient(circle at top left, rgba(255, 255, 255, 0.22), transparent 40%);
		z-index: 1;
	}

	:root:not(.dark) .apple-post-card {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 247, 250, 0.74)),
			radial-gradient(circle at top right, rgba(255, 196, 218, 0.14), transparent 16rem);
		border-color: rgba(236, 174, 198, 0.18);
		box-shadow:
			0 28px 68px rgba(120, 82, 101, 0.12),
			0 0 20px rgba(255, 196, 218, 0.08);
	}

	:root:not(.dark) .apple-post-card::before {
		background: linear-gradient(90deg, transparent, rgba(236, 174, 198, 0.9), transparent);
	}

	:root:not(.dark) .apple-post-card:hover {
		border-color: rgba(236, 174, 198, 0.28);
		box-shadow:
			0 34px 78px rgba(120, 82, 101, 0.16),
			0 0 20px rgba(255, 196, 218, 0.14),
			0 0 42px rgba(255, 196, 218, 0.1);
	}
</style>
