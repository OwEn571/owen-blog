---
/**
 * FloatingTOC - 悬浮目录组件
 * 带圆形进度环的悬浮按钮式目录
 */

import { Icon } from "astro-icon/components";

import { siteConfig } from "../../../config";

interface Props {
	fallbackForSidebar?: boolean;
}

const tocDepth = siteConfig.toc.depth;
const useJapaneseBadge = siteConfig.toc.useJapaneseBadge;
const { fallbackForSidebar = false } = Astro.props;
---

<div
	class="floating-toc-wrapper"
	data-depth={tocDepth}
	data-japanese-badge={useJapaneseBadge}
	data-sidebar-fallback={fallbackForSidebar ? "true" : "false"}
>
	<button
		id="floating-toc-btn"
		class="floating-toc-btn btn-card"
		aria-label="Table of Contents"
	>
		<svg
			class="progress-ring"
			width="100%"
			height="100%"
			viewBox="0 0 100 100"
		>
			<circle
				class="progress-ring-circle"
				cx="50"
				cy="50"
				r="40"
				fill="transparent"></circle>
		</svg>
		<div class="btn-icon">
			<Icon
				name="material-symbols:format-list-bulleted-rounded"
				class="text-2xl"
			/>
		</div>
	</button>
	<div id="floating-toc-panel" class="floating-toc-panel">
		<div class="floating-toc-panel-content" id="floating-toc-content"></div>
	</div>
</div>

<style>
	.floating-toc-wrapper {
		position: relative;
		z-index: 1;
		pointer-events: auto;
		display: none;
	}

	.floating-toc-wrapper.active-toc {
		display: block;
	}

	.floating-toc-btn {
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 1.15rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--primary);
		position: relative;
		border: 1px solid color-mix(in srgb, var(--primary) 18%, var(--line-color));
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--card-bg) 92%, rgba(255, 255, 255, 0.16)), color-mix(in srgb, var(--card-bg) 78%, transparent)),
			radial-gradient(circle at top, color-mix(in srgb, var(--primary) 12%, transparent), transparent 72%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.18),
			0 18px 34px rgba(15, 23, 42, 0.12);
	}

	.floating-toc-btn.active {
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--card-bg) 96%, rgba(255, 255, 255, 0.16)), color-mix(in srgb, var(--card-bg) 80%, transparent)),
			radial-gradient(circle at center, color-mix(in srgb, var(--primary) 18%, transparent), transparent 70%);
	}

	.progress-ring {
		position: absolute;
		top: 0;
		left: 0;
		transform: rotate(-90deg);
		pointer-events: none;
		z-index: 0;
	}

	.progress-ring-circle {
		stroke: var(--primary);
		stroke-width: 5;
		stroke-dasharray: 251.2;
		stroke-dashoffset: 251.2;
		transition: stroke-dashoffset 0.1s linear;
		stroke-linecap: round;
	}

	.btn-icon {
		z-index: 1;
		position: relative;
	}

	.floating-toc-panel {
		position: absolute;
		bottom: 4.5rem;
		right: 0;
		width: 19rem;
		max-height: 60vh;
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--card-bg) 96%, rgba(255, 255, 255, 0.08)), color-mix(in srgb, var(--card-bg) 86%, transparent)),
			radial-gradient(circle at top, color-mix(in srgb, var(--primary) 10%, transparent), transparent 68%);
		border: 1px solid color-mix(in srgb, var(--primary) 14%, var(--line-color));
		border-radius: 1.25rem;
		box-shadow:
			0 28px 60px rgba(15, 23, 42, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(24px) saturate(1.04);
		-webkit-backdrop-filter: blur(24px) saturate(1.04);
		overflow: hidden;
		opacity: 0;
		visibility: hidden;
		transform: translateY(10px) scale(0.95);
		transition: all 0.2s ease;
		pointer-events: none;
	}

	.floating-toc-panel.show {
		opacity: 1;
		visibility: visible;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}

	.floating-toc-panel-content {
		padding: 0.82rem;
		max-height: 60vh;
		overflow-y: auto;
		overflow-x: hidden;
	}

	.floating-toc-panel-content::-webkit-scrollbar {
		width: 4px;
	}

	.floating-toc-panel-content::-webkit-scrollbar-track {
		background: transparent;
	}

	.floating-toc-panel-content::-webkit-scrollbar-thumb {
		background: var(--line-color);
		border-radius: 2px;
	}

	@media (max-width: 1920px) {
		.floating-toc-btn {
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.18),
				0 18px 34px rgba(15, 23, 42, 0.12);
		}
	}

	@media (max-width: 768px) {
		.floating-toc-wrapper {
			opacity: 0.6;
		}

		.floating-toc-wrapper:active,
		.floating-toc-wrapper.active {
			opacity: 1;
		}

		.floating-toc-panel {
			width: 85vw;
			max-width: 20rem;
			right: 0;
			bottom: 4.5rem;
		}
	}

	:global(.floating-toc-item) {
		display: flex;
		align-items: center;
		padding: 0.62rem 0.74rem;
		color: color-mix(in srgb, var(--text-secondary) 88%, transparent);
		text-decoration: none;
		font-size: 0.88rem;
		line-height: 1.5;
		border-radius: 0.95rem;
		border: 1px solid transparent;
		transition:
			background-color 0.2s ease,
			border-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	:global(.floating-toc-text) {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	:global(.floating-toc-parent .floating-toc-text) {
		-webkit-line-clamp: 1;
	}

	:global(.floating-toc-group) {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		padding: 0.28rem;
		border-radius: 1rem;
		border: 1px solid transparent;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent);
	}

	:global(.floating-toc-group.is-active-group) {
		border-color: color-mix(in srgb, var(--primary) 12%, transparent);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--primary) 8%, transparent), transparent),
			linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent);
	}

	:global(.floating-toc-group-header) {
		display: flex;
		align-items: stretch;
		gap: 0.45rem;
	}

	:global(.floating-toc-group-header .floating-toc-item) {
		flex: 1 1 auto;
		min-width: 0;
	}

	:global(.floating-toc-children) {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		margin-left: 0.95rem;
		padding-left: 0.7rem;
		border-left: 1px solid color-mix(in srgb, var(--primary) 14%, transparent);
	}

	:global(.floating-toc-parent) {
		flex: 1;
		font-weight: 620;
	}

	:global(.floating-toc-toggle) {
		width: 1.55rem;
		min-width: 1.55rem;
		height: 1.55rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--primary) 10%, transparent);
		background: color-mix(in srgb, var(--primary) 8%, transparent);
		color: color-mix(in srgb, var(--primary) 86%, white 14%);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		align-self: center;
		flex-shrink: 0;
		margin-left: auto;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			background-color 0.2s ease,
			color 0.2s ease;
	}

	:global(.floating-toc-toggle:hover) {
		background: color-mix(in srgb, var(--primary) 14%, transparent);
		border-color: color-mix(in srgb, var(--primary) 18%, transparent);
	}

	:global(.floating-toc-toggle.expanded) {
		transform: rotate(180deg);
	}

	:global(.floating-toc-toggle-icon) {
		font-size: 0.86rem;
		line-height: 1;
		transform: translateY(-1px);
		opacity: 0.76;
	}

	:global(.floating-toc-item:hover) {
		background-color: color-mix(in srgb, var(--primary) 8%, transparent);
		border-color: color-mix(in srgb, var(--primary) 10%, transparent);
		color: var(--primary);
	}

	:global(.floating-toc-item.active) {
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--primary) 11%, transparent), color-mix(in srgb, var(--primary) 7%, transparent));
		border-color: color-mix(in srgb, var(--primary) 16%, transparent);
		color: var(--primary);
		font-weight: 500;
	}

	:global(.floating-toc-badge) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.35rem;
		height: 1.35rem;
		padding: 0 0.18rem;
		background: color-mix(in srgb, var(--primary) 14%, transparent);
		color: var(--primary);
		border-radius: 0.45rem;
		font-size: 0.72rem;
		font-weight: 700;
		margin-right: 0.55rem;
		flex-shrink: 0;
	}

	:global(.floating-toc-dot) {
		width: 0.5rem;
		height: 0.5rem;
		background: color-mix(in srgb, var(--primary) 18%, var(--line-divider));
		border-radius: 50%;
		margin-right: 0.75rem;
		margin-left: 0.375rem;
		flex-shrink: 0;
	}

	:global(.floating-toc-dot-small) {
		width: 0.35rem;
		height: 0.35rem;
		background: color-mix(in srgb, var(--primary) 14%, var(--line-divider));
		border-radius: 50%;
		margin-right: 0.75rem;
		margin-left: 0.45rem;
		flex-shrink: 0;
	}

	:global(.floating-toc-item.active .floating-toc-dot),
	:global(.floating-toc-item.active .floating-toc-dot-small) {
		background: var(--primary);
	}

	:global(.floating-toc-text) {
		min-width: 0;
		flex: 1;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
</style>

<style>
	/* Owen TOC refinement */
	.floating-toc-btn {
		border-radius: 1.22rem;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.22),
			0 22px 52px rgba(15, 23, 42, 0.14),
			0 0 20px color-mix(in srgb, var(--primary) 10%, transparent);
	}

	.floating-toc-panel {
		border-radius: 1.45rem;
		box-shadow:
			0 32px 70px rgba(15, 23, 42, 0.18),
			0 0 26px color-mix(in srgb, var(--primary) 8%, transparent),
			inset 0 1px 0 rgba(255, 255, 255, 0.14);
	}

	:global(.floating-toc-group) {
		border-radius: 1.08rem;
	}

	:global(.floating-toc-item) {
		font-family: var(--owen-font-reading);
	}

	:global(.floating-toc-text) {
		font-weight: 530;
		letter-spacing: 0.004em;
	}

	:global(.floating-toc-toggle) {
		width: 1.9rem;
		min-width: 1.9rem;
		height: 1.9rem;
		border-radius: 0.72rem;
		background:
			linear-gradient(180deg, color-mix(in srgb, white 72%, transparent), color-mix(in srgb, var(--primary) 7%, transparent)),
			color-mix(in srgb, var(--primary) 8%, transparent);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.5),
			0 10px 24px color-mix(in srgb, var(--primary) 8%, transparent);
	}

	:global(.floating-toc-toggle-icon) {
		font-size: 0.9rem;
		transform: none;
	}

	:global(.floating-toc-group.is-active-group) {
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
	}
</style>

<script>
import { findTOCGroupParentId, groupTOCItems } from "./utils/toc-groups";
import { findActiveHeadingIndex } from "./hooks/useTocHighlight";
import {
	throttle,
	updateProgressRing,
} from "./hooks/useTocScroll";
import {
	generateTOCItems,
	getTOCConfig,
	scrollToHeading,
} from "./utils/toc-utils";

type FloatingTOCItem = {
	id: string;
	text: string;
	level: number;
	depth: number;
	badge?: string;
};

type FloatingTOCGroup = {
	parent: FloatingTOCItem;
	children: FloatingTOCItem[];
};

interface FloatingTOCState {
	btn: HTMLElement | null;
	panel: HTMLElement | null;
	content: HTMLElement | null;
	wrapper: HTMLElement | null;
	isOpen: boolean;
	observer: MutationObserver | null;
	headings: HTMLElement[];
	tocGroups: FloatingTOCGroup[];
	manualExpandedGroups: Set<string>;
	manualCollapsedGroups: Set<string>;
	autoExpandedGroup: string | null;
}

class FloatingTOC {
	state: FloatingTOCState;
	navbarOffset = 80;
	handleScroll = throttle(() => {
		this.updateProgress();
		this.updateActiveHeading();
	}, 50);
	handleDocumentClick = (e: Event) => {
		if (this.state.isOpen && !this.state.wrapper?.contains(e.target as Node)) {
			this.close();
		}
	};
	handleKeyDown = (e: KeyboardEvent) => {
		if (e.key === "Escape" && this.state.isOpen) {
			this.close();
		}
	};
	handleSwupPageView = () => {
		setTimeout(() => this.reinit(), 200);
	};

	constructor() {
		this.state = {
			btn: document.getElementById("floating-toc-btn"),
			panel: document.getElementById("floating-toc-panel"),
			content: document.getElementById("floating-toc-content"),
			wrapper: document.querySelector(".floating-toc-wrapper"),
			isOpen: false,
			observer: null,
			headings: [],
			tocGroups: [],
			manualExpandedGroups: new Set(),
			manualCollapsedGroups: new Set(),
			autoExpandedGroup: null,
		};
		this.init();
	}

	isGroupExpanded(groupId: string) {
		return (
			this.state.manualExpandedGroups.has(groupId) ||
			(this.state.autoExpandedGroup === groupId &&
				!this.state.manualCollapsedGroups.has(groupId))
		);
	}

	expandGroupManually(groupId: string) {
		this.state.manualCollapsedGroups.delete(groupId);
		this.state.manualExpandedGroups.add(groupId);
	}

	collapseGroupManually(groupId: string) {
		this.state.manualExpandedGroups.delete(groupId);
		this.state.manualCollapsedGroups.add(groupId);
	}

	setAutoExpandedGroup(groupId: string | null) {
		if (this.state.autoExpandedGroup === groupId) {
			return;
		}

		this.state.autoExpandedGroup = groupId;
		this.syncExpandedGroups();
	}

	syncExpandedGroups() {
		this.state.content?.querySelectorAll<HTMLElement>("[data-floating-group]").forEach((group) => {
			const groupId = group.dataset.floatingGroup || "";
			group.classList.toggle("is-active-group", this.isGroupExpanded(groupId));
		});

		this.state.content?.querySelectorAll<HTMLElement>("[data-floating-children]").forEach((container) => {
			const groupId = container.dataset.floatingChildren || "";
			container.hidden = !this.isGroupExpanded(groupId);
		});

		this.state.content?.querySelectorAll<HTMLButtonElement>("[data-floating-toggle]").forEach((button) => {
			const groupId = button.dataset.floatingToggle || "";
			const expanded = this.isGroupExpanded(groupId);
			button.classList.toggle("expanded", expanded);
			button.setAttribute("aria-expanded", expanded ? "true" : "false");
		});
	}

	init() {
		window.addEventListener("scroll", this.handleScroll, { passive: true });
		window.addEventListener("resize", this.handleScroll, { passive: true });

		this.bindEvents();
		this.generateTOC();
		this.observeContent();
		this.updateProgress();
	}

	observeContent() {
		const contentWrapper = document.getElementById("post-container");
		if (contentWrapper) {
			this.state.observer = new MutationObserver(() => {
				this.generateTOC();
				this.updateProgress();
			});
			this.state.observer.observe(contentWrapper, {
				childList: true,
				subtree: true,
			});
		}
	}

	updateProgress() {
		const circle = this.state.btn?.querySelector(
			".progress-ring-circle"
		) as SVGCircleElement | null;
		if (!circle) {return;}

		const scrollTop = window.scrollY || document.documentElement.scrollTop;
		const docHeight =
			document.documentElement.scrollHeight -
			document.documentElement.clientHeight;
		const progress = docHeight > 0 ? scrollTop / docHeight : 0;
		updateProgressRing(circle, progress);
	}

	updateActiveHeading() {
		const { content, headings } = this.state;
		if (!content || headings.length === 0) {return;}

		const activeIndex = findActiveHeadingIndex(headings, window.scrollY, 150);
		const activeHeading = headings[activeIndex];
		if (activeHeading?.id) {
			this.syncAutoExpandedGroup(activeHeading.id);
		} else {
			this.setAutoExpandedGroup(null);
		}
		const links = Array.from(
			content.querySelectorAll(".floating-toc-item")
		) as HTMLAnchorElement[];

		links.forEach((link, index) => {
			if (index === activeIndex) {
				link.classList.add("active");
				if (this.state.isOpen) {
					const panelRect = content.getBoundingClientRect();
					const linkRect = link.getBoundingClientRect();
					if (
						linkRect.top < panelRect.top ||
						linkRect.bottom > panelRect.bottom
					) {
						link.scrollIntoView({ block: "nearest" });
					}
				}
			} else {
				link.classList.remove("active");
			}
		});
	}

	syncAutoExpandedGroup(headingId: string) {
		const parentId = findTOCGroupParentId(this.state.tocGroups, headingId);
		if (!parentId) {
			this.setAutoExpandedGroup(null);
			return;
		}

		const targetGroup = this.state.tocGroups.find((group) => group.parent.id === parentId);
		if (!targetGroup || targetGroup.children.length === 0) {
			this.setAutoExpandedGroup(null);
			return;
		}

		this.setAutoExpandedGroup(parentId);
	}

		renderItem(item: FloatingTOCItem) {
		const badge =
			item.depth === 0
				? `<span class="floating-toc-badge">${item.badge || ""}</span>`
				: item.depth === 1
					? '<span class="floating-toc-dot"></span>'
					: '<span class="floating-toc-dot-small"></span>';

		return `<a href="#${item.id}" class="floating-toc-item ${item.depth === 0 ? "floating-toc-parent" : "floating-toc-child"}" style="${item.depth > 0 ? `padding-left:${0.75 + item.depth * 0.7}rem;` : ""}" data-level="${item.depth}">${badge}<span class="floating-toc-text">${item.text}</span></a>`;
	}

		renderGroup(group: FloatingTOCGroup) {
		return `<div class="floating-toc-group" data-floating-group="${group.parent.id}">
			<div class="floating-toc-group-header">
				${this.renderItem(group.parent)}
				${
					group.children.length > 0
						? `<button
							type="button"
							class="floating-toc-toggle"
							data-floating-toggle="${group.parent.id}"
							aria-label="展开子目录"
							aria-expanded="false"
						>
							<span class="floating-toc-toggle-icon">⌄</span>
						</button>`
						: ""
				}
			</div>
			${
				group.children.length > 0
					? `<div class="floating-toc-children" data-floating-children="${group.parent.id}" hidden>
						${group.children.map((item) => this.renderItem(item)).join("")}
					</div>`
					: ""
			}
		</div>`;
	}

	generateTOC() {
		const container = document.getElementById("post-container");
		const { wrapper } = this.state;

		if (!container) {
			wrapper?.classList.remove("active-toc");
			wrapper?.classList.add("no-toc");
			return;
		}

		const allHeadings = container.querySelectorAll(
			"h1[id], h2[id], h3[id], h4[id], h5[id], h6[id]"
		);

		if (allHeadings.length === 0) {
			wrapper?.classList.remove("active-toc");
			wrapper?.classList.add("no-toc");
			this.state.headings = [];
			return;
		}

		wrapper?.classList.remove("no-toc");
		wrapper?.classList.add("active-toc");

		const headings = Array.from(allHeadings) as HTMLElement[];
		const config = getTOCConfig();
		const tocItems = generateTOCItems(
			headings.map((h) => ({
				id: h.id,
				text: (h.textContent || "").replace(/#+\s*$/, ""),
				level: parseInt(h.tagName[1], 10),
			})),
			config
		);

		this.state.tocGroups = groupTOCItems(tocItems);
		this.state.manualExpandedGroups = new Set();
		this.state.manualCollapsedGroups = new Set();
		this.state.autoExpandedGroup = null;
		this.state.headings = tocItems.map((item) =>
			document.getElementById(item.id)!
		);

		const html = this.state.tocGroups
			.map((group) => this.renderGroup(group))
			.join("");

		if (this.state.content) {
			this.state.content.innerHTML = html;
		}
		this.syncExpandedGroups();
		this.updateActiveHeading();
	}

	bindEvents() {
		const { btn, content } = this.state;

		btn?.addEventListener("click", (e) => {
			e.stopPropagation();
			this.toggle();
		});

		document.addEventListener("click", this.handleDocumentClick);

		content?.addEventListener("click", (e) => {
			const toggle = (e.target as Element).closest("[data-floating-toggle]");
			if (toggle instanceof HTMLButtonElement) {
				e.preventDefault();
				e.stopPropagation();
				const groupId = toggle.dataset.floatingToggle || "";
				if (!groupId) {
					return;
				}

				if (this.isGroupExpanded(groupId)) {
					this.collapseGroupManually(groupId);
				} else {
					this.expandGroupManually(groupId);
				}

				this.syncExpandedGroups();
				return;
			}

			const link = (e.target as Element).closest("a");
			if (link instanceof HTMLAnchorElement) {
				e.preventDefault();
				const id = link.getAttribute("href")?.slice(1);
				if (id) {
					const groupId = findTOCGroupParentId(this.state.tocGroups, id);
					if (groupId) {
						this.expandGroupManually(groupId);
						this.syncExpandedGroups();
					}
					scrollToHeading(id, this.navbarOffset);
					this.close();
				}
			}
		});

		document.addEventListener("keydown", this.handleKeyDown);

		if (window.swup) {
			window.swup.hooks.on("page:view", this.handleSwupPageView);
		}
	}

	toggle() {
		this.state.isOpen ? this.close() : this.open();
	}

	open() {
		this.state.isOpen = true;
		this.state.panel?.classList.add("show");
		this.state.btn?.classList.add("active");
		this.state.wrapper?.classList.add("active");
	}

	close() {
		this.state.isOpen = false;
		this.state.panel?.classList.remove("show");
		this.state.btn?.classList.remove("active");
		this.state.wrapper?.classList.remove("active");
	}

	reinit() {
		if (this.state.observer) {
			this.state.observer.disconnect();
		}
		this.close();
		this.generateTOC();
		this.observeContent();
		this.updateProgress();
	}

	destroy() {
		this.state.observer?.disconnect();
		window.removeEventListener("scroll", this.handleScroll);
		window.removeEventListener("resize", this.handleScroll);
		document.removeEventListener("click", this.handleDocumentClick);
		document.removeEventListener("keydown", this.handleKeyDown);
		if (window.swup) {
			window.swup.hooks.off("page:view", this.handleSwupPageView);
		}
	}
}

const mountFloatingTOC = () => {
	const floatingWindow = window as Window & {
		__owenBlogFloatingTOC?: FloatingTOC;
	};
	floatingWindow.__owenBlogFloatingTOC?.destroy?.();
	floatingWindow.__owenBlogFloatingTOC = new FloatingTOC();
};

document.addEventListener("DOMContentLoaded", mountFloatingTOC);
document.addEventListener("swup:page:view", mountFloatingTOC);
</script>
