---
/**
 * SidebarTOC - 侧边栏目录组件
 * 基于 Web Component 实现，支持 IntersectionObserver 滚动监听
 */

import type { MarkdownHeading } from "astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const { class: className } = Astro.props;
---

<table-of-contents class:list={[className, "group"]} id="toc">
</table-of-contents>

<script>
import { groupTOCItems, findTOCGroupParentId } from "./utils/toc-groups";
import {
	extractHeadings,
	generateTOCItems,
	getTOCConfig,
	scrollToHeading,
} from "./utils/toc-utils";

import {
	calculateActiveHeadingRange,
	isInRange,
} from "./hooks/useTocHighlight";

import {
	throttle,
	calculateActiveIndicatorPosition,
} from "./hooks/useTocScroll";

class TableOfContents extends HTMLElement {
	tocEl: HTMLElement | null = null;
	visibleClass = "visible";
	observer: IntersectionObserver;
	anchorNavTarget: HTMLElement | null = null;
	headingIdxMap = new Map<string, number>();
	headings: HTMLElement[] = [];
	sections: HTMLElement[] = [];
	tocEntries: HTMLAnchorElement[] = [];
	active: boolean[] = [];
	activeIndicator: HTMLElement | null = null;
	manualExpandedGroups = new Set<string>();
	manualCollapsedGroups = new Set<string>();
	autoExpandedGroup: string | null = null;
	tocGroups: Array<{ parent: { id: string; level: number; depth: number; text: string; badge?: string }; children: Array<{ id: string; level: number; depth: number; text: string; badge?: string }> }> = [];
	navbarHeight = 80;

	constructor() {
		super();
		this.observer = new IntersectionObserver(
			this.markVisibleSection.bind(this),
			{ threshold: 0 },
		);
	}

	markVisibleSection = (entries: IntersectionObserverEntry[]) => {
		entries.forEach((entry) => {
			const id = (entry.target as HTMLElement).children[0]?.getAttribute("id");
			const idx = id ? this.headingIdxMap.get(id) : undefined;
			if (idx !== undefined) {
				this.active[idx] = entry.isIntersecting;
			}

			if (
				entry.isIntersecting &&
				this.anchorNavTarget === (entry.target as HTMLElement).firstChild
			) {
				this.anchorNavTarget = null;
			}
		});

		if (!this.active.includes(true)) {
			this.fallback();
		}
		this.update();
	};

	getActiveHeadingIds = () =>
		this.tocEntries
			.map((entry, index) => (this.active[index] ? decodeURIComponent(entry.hash?.substring(1) || "") : null))
			.filter((id): id is string => !!id);

	isGroupExpanded = (groupId: string) =>
		this.manualExpandedGroups.has(groupId) ||
		(this.autoExpandedGroup === groupId && !this.manualCollapsedGroups.has(groupId));

	expandGroupManually = (groupId: string) => {
		this.manualCollapsedGroups.delete(groupId);
		this.manualExpandedGroups.add(groupId);
	};

	collapseGroupManually = (groupId: string) => {
		this.manualExpandedGroups.delete(groupId);
		this.manualCollapsedGroups.add(groupId);
	};

	setAutoExpandedGroup = (groupId: string | null) => {
		if (this.autoExpandedGroup === groupId) {
			return;
		}

		this.autoExpandedGroup = groupId;
		this.syncExpandedGroups();
	};

	syncExpandedGroups = () => {
		this.querySelectorAll<HTMLElement>("[data-toc-children]").forEach((container) => {
			const groupId = container.dataset.tocChildren || "";
			const expanded = this.isGroupExpanded(groupId);
			container.hidden = !expanded;
		});

		this.querySelectorAll<HTMLButtonElement>("[data-toc-toggle]").forEach((button) => {
			const groupId = button.dataset.tocToggle || "";
			const expanded = this.isGroupExpanded(groupId);
			button.classList.toggle("expanded", expanded);
			button.setAttribute("aria-expanded", expanded ? "true" : "false");
		});
	};

	syncAutoExpandedGroup = (headingIds: string[]) => {
		const currentId =
			headingIds[headingIds.length - 1] || headingIds[0] || null;
		if (!currentId) {
			this.setAutoExpandedGroup(null);
			return;
		}

		const groupId = findTOCGroupParentId(this.tocGroups, currentId);
		if (!groupId) {
			this.setAutoExpandedGroup(null);
			return;
		}

		const targetGroup = this.tocGroups.find((group) => group.parent.id === groupId);
		if (!targetGroup || targetGroup.children.length === 0) {
			this.setAutoExpandedGroup(null);
			return;
		}

		this.setAutoExpandedGroup(groupId);
	};

	toggleActiveHeading = () => {
		this.syncAutoExpandedGroup(this.getActiveHeadingIds());

		const { min, max } = calculateActiveHeadingRange(this.active);

		this.tocEntries.forEach((entry, i) => {
			if (this.active[i]) {
				entry.classList.add(this.visibleClass);
			} else {
				entry.classList.remove(this.visibleClass);
			}
		});

		if (min > max) {
			this.activeIndicator?.setAttribute("style", "opacity: 0");
		} else {
			const minEntry = this.tocEntries[min];
			const maxEntry = this.tocEntries[max];
			if (minEntry && maxEntry && this.tocEl) {
				const { top, height } = calculateActiveIndicatorPosition(
					this.tocEl,
					minEntry,
					maxEntry,
				);
				this.activeIndicator?.setAttribute(
					"style",
					`top: ${top}px; height: ${height}px`,
				);
			}
		}
	};

	scrollToActiveHeading = throttle(() => {
		if (this.anchorNavTarget || !this.tocEl) return;

		const activeEntries = this.tocEntries.filter((entry) =>
			entry.classList.contains(this.visibleClass),
		);
		if (activeEntries.length === 0) return;

		const topmost = activeEntries[0];
		const bottommost = activeEntries[activeEntries.length - 1];
		const tocHeight = this.tocEl.clientHeight;

		const visibleHeight =
			bottommost.getBoundingClientRect().bottom -
			topmost.getBoundingClientRect().top;

		let top: number;
		if (visibleHeight < 0.9 * tocHeight) {
			top = (topmost as HTMLElement).offsetTop - 32;
		} else {
			top = (bottommost as HTMLElement).offsetTop - tocHeight * 0.8;
		}

		this.tocEl.scrollTo({ top, left: 0, behavior: "auto" });
	}, 100);

	update = () => {
		requestAnimationFrame(() => {
			this.toggleActiveHeading();
			this.scrollToActiveHeading();
		});
	};

	fallback = () => {
		if (!this.sections.length) return;

		for (let i = 0; i < this.sections.length; i++) {
			const rect = this.sections[i].getBoundingClientRect();
			if (
				isInRange(rect.top, 0, window.innerHeight) ||
				isInRange(rect.bottom, 0, window.innerHeight) ||
				(rect.top < 0 && rect.bottom > window.innerHeight)
			) {
				this.active[i] = true;
			} else if (rect.top > window.innerHeight) {
				break;
			}
		}
	};

	handleClick = (event: Event) => {
		const toggleButton = (event.target as HTMLElement)?.closest?.("[data-toc-toggle]") as HTMLButtonElement | null;
		if (toggleButton) {
			event.preventDefault();
			event.stopPropagation();

			const groupId = toggleButton.dataset.tocToggle || "";
			if (!groupId) {
				return;
			}

			if (this.isGroupExpanded(groupId)) {
				this.collapseGroupManually(groupId);
			} else {
				this.expandGroupManually(groupId);
			}

			this.syncExpandedGroups();
			this.update();
			return;
		}

		const anchor = (event.composedPath() as EventTarget[]).find(
			(el) => el instanceof HTMLAnchorElement,
		) as HTMLAnchorElement | undefined;

		if (anchor) {
			event.preventDefault();
			const id = decodeURIComponent(anchor.hash?.substring(1) || "");
			scrollToHeading(id, this.navbarHeight);

			const groupId = findTOCGroupParentId(this.tocGroups, id);
			if (groupId) {
				this.expandGroupManually(groupId);
				this.syncExpandedGroups();
			}

			const idx = this.headingIdxMap.get(id);
			this.anchorNavTarget = idx !== undefined ? this.headings[idx] : null;
		}
	};

	connectedCallback() {
		const element =
			document.querySelector(".custom-md") ||
			document.querySelector(".prose") ||
			document.querySelector(".markdown-content");
		let initialized = false;

		const tryInit = () => {
			if (!initialized) {
				initialized = true;
				this.init();
			}
		};

		if (element) {
			element.addEventListener("animationend", tryInit, { once: true });
			setTimeout(tryInit, 300);
		} else {
			tryInit();
			setTimeout(tryInit, 300);
		}
	}

	init() {
		this.sections.forEach((section) => {
			if (section instanceof HTMLElement) {
				this.observer.unobserve(section);
			}
		});
		this.observer.disconnect();
		this.tocEl?.removeEventListener("click", this.handleClick);
		this.headingIdxMap.clear();
		this.headings = [];
		this.sections = [];
		this.tocEntries = [];
		this.active = [];
		this.anchorNavTarget = null;

		this.regenerateTOC();
		this.tocEl = this;

		this.tocEl.addEventListener("click", this.handleClick, {
			capture: true,
		});

		this.activeIndicator = this.querySelector("#active-indicator");

		this.tocEntries = Array.from(
			this.querySelectorAll<HTMLAnchorElement>("a[href^='#']"),
		);

		if (this.tocEntries.length === 0) return;

		this.sections = new Array(this.tocEntries.length);
		this.headings = new Array(this.tocEntries.length);

		for (let i = 0; i < this.tocEntries.length; i++) {
			const id = decodeURIComponent(
				this.tocEntries[i].hash?.substring(1) || "",
			);
			const heading = document.getElementById(id);
			const section = heading?.parentElement;
			if (heading instanceof HTMLElement && section instanceof HTMLElement) {
				this.headings[i] = heading;
				this.sections[i] = section;
				this.headingIdxMap.set(id, i);
			}
		}
		this.active = new Array(this.tocEntries.length).fill(false);

		this.sections.forEach((section) => this.observer.observe(section));

		this.fallback();
		this.update();
	}

	renderItem(item: { id: string; text: string; depth: number; badge?: string }) {
		const badgeContent =
			item.depth === 0
				? item.badge || ""
				: item.depth === 1
					? '<div class="toc-dot toc-dot-square"></div>'
					: '<div class="toc-dot toc-dot-small"></div>';

		const badgeClass =
			item.depth === 0
				? "toc-badge-parent"
				: item.depth === 1
					? "toc-badge-secondary"
					: "toc-badge-tertiary";

		return `<a
			href="#${item.id}"
			class="toc-link ${item.depth === 0 ? "toc-link-parent" : "toc-link-child"}"
			data-toc-depth="${item.depth}"
			style="${item.depth > 0 ? `--toc-indent:${Math.min(item.depth, 4)};` : ""}"
		>
			<div class="toc-badge ${badgeClass}">
				${badgeContent}
			</div>
			<div class="toc-label ${item.depth <= 1 ? "text-50" : "text-30"}">${item.text}</div>
		</a>`;
	}

	renderGroup(group: { parent: { id: string; text: string; depth: number; badge?: string }; children: Array<{ id: string; text: string; depth: number; badge?: string }> }) {
		return `<div class="toc-group" data-toc-group="${group.parent.id}">
			<div class="toc-group-header">
				${this.renderItem(group.parent)}
				${
					group.children.length > 0
						? `<button
							type="button"
							class="toc-toggle"
							data-toc-toggle="${group.parent.id}"
							aria-label="展开子目录"
							aria-expanded="false"
						>
							<span class="toc-toggle-icon">⌄</span>
						</button>`
						: ""
				}
			</div>
			${
				group.children.length > 0
					? `<div class="toc-children" data-toc-children="${group.parent.id}" hidden>
						${group.children.map((item) => this.renderItem(item)).join("")}
					</div>`
					: ""
			}
		</div>`;
	}

	regenerateTOC(retryCount = 0) {
		const isPostPage =
			window.location.pathname.includes("/posts/") ||
			document.querySelector(".custom-md, .markdown-content") !== null;

		if (!isPostPage) {
			this.innerHTML = "";
			delete this.dataset.loaded;
			return;
		}

		const headings = extractHeadings();

		if (headings.length === 0 && retryCount < 3) {
			setTimeout(() => this.regenerateTOC(retryCount + 1), 120);
			return;
		}
		if (headings.length === 0) {
			this.innerHTML = "";
			delete this.dataset.loaded;
			return;
		}

		const config = getTOCConfig();
		const tocItems = generateTOCItems(headings, config);
		this.tocGroups = groupTOCItems(tocItems);
		this.manualExpandedGroups = new Set();
		this.manualCollapsedGroups = new Set();
		this.autoExpandedGroup = null;

		const tocHTML = this.tocGroups.map((group) => this.renderGroup(group)).join("");

		this.innerHTML =
			tocHTML +
			'<div id="active-indicator" style="opacity: 0" class="-z-10 absolute bg-[var(--toc-btn-hover)] left-0 right-0 rounded-xl transition-all group-hover:bg-transparent border-2 border-[var(--toc-btn-hover)] group-hover:border-[var(--toc-btn-active)] border-dashed"></div>';
		this.dataset.loaded = "true";
		this.syncExpandedGroups();
	}

	disconnectedCallback() {
		this.sections.forEach((section) =>
			this.observer.unobserve(section),
		);
		this.observer.disconnect();
		this.tocEl?.removeEventListener("click", this.handleClick);
	}
}

if (!customElements.get("table-of-contents")) {
	customElements.define("table-of-contents", TableOfContents);
}
</script>

<style>
	table-of-contents#toc {
		max-height: 100%;
		overflow: auto;
		position: relative;
		scroll-behavior: smooth;
		display: block;
	}

	table-of-contents#toc::-webkit-scrollbar {
		display: none;
	}

	table-of-contents#toc .toc-group {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.125rem 0;
	}

	table-of-contents#toc .toc-group-header {
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	table-of-contents#toc .toc-children {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
		margin-left: 0.875rem;
		padding-left: 0.625rem;
		border-left: 1px solid color-mix(in srgb, var(--line-color) 78%, transparent);
	}

	table-of-contents#toc .toc-link {
		padding: 0.5rem 0.625rem;
		display: flex;
		gap: 0.5rem;
		position: relative;
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
		width: 100%;
		min-height: 2.25rem;
		border-radius: 0.875rem;
		align-items: center;
	}

	table-of-contents#toc .toc-link-child {
		padding-left: calc(0.75rem + (var(--toc-indent, 1) * 0.75rem));
	}

	table-of-contents#toc .toc-link:hover {
		background: var(--toc-btn-hover);
	}

	table-of-contents#toc .toc-badge {
		width: 1.25rem;
		height: 1.25rem;
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	table-of-contents#toc .toc-badge-parent {
		border-radius: 0.625rem;
		background: var(--toc-badge-bg);
		color: var(--btn-content);
		font-size: 0.75rem;
		font-weight: 700;
	}

	table-of-contents#toc .toc-badge-secondary,
	table-of-contents#toc .toc-badge-tertiary {
		background: transparent;
	}

	table-of-contents#toc .toc-dot {
		display: inline-flex;
	}

	table-of-contents#toc .toc-dot-square {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 0.1875rem;
		background: var(--toc-badge-bg);
	}

	table-of-contents#toc .toc-dot-small {
		width: 0.375rem;
		height: 0.375rem;
		border-radius: 0.125rem;
		background: rgb(255 255 255 / 0.14);
	}

	:global(.light) table-of-contents#toc .toc-dot-small {
		background: rgb(0 0 0 / 0.08);
	}

	table-of-contents#toc .toc-label {
		font-size: 0.875rem;
		line-height: 1.45;
	}

	table-of-contents#toc .toc-toggle {
		width: 1.9rem;
		min-width: 1.9rem;
		height: 1.9rem;
		align-self: center;
		border-radius: 0.78rem;
		border: 1px solid color-mix(in srgb, var(--primary) 20%, var(--line-color));
		color: var(--primary);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--card-bg) 86%, rgba(255, 255, 255, 0.22)), color-mix(in srgb, var(--card-bg) 74%, transparent)),
			radial-gradient(circle at top, color-mix(in srgb, var(--primary) 16%, transparent), transparent 72%);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			background-color 0.2s ease,
			box-shadow 0.2s ease;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.18),
			0 8px 20px rgba(15, 23, 42, 0.08);
	}

	table-of-contents#toc .toc-toggle:hover {
		border-color: color-mix(in srgb, var(--primary) 36%, transparent);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--card-bg) 92%, rgba(255, 255, 255, 0.24)), color-mix(in srgb, var(--card-bg) 82%, transparent)),
			radial-gradient(circle at center, color-mix(in srgb, var(--primary) 18%, transparent), transparent 74%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.24),
			0 0 0 1px color-mix(in srgb, var(--primary) 14%, transparent),
			0 10px 24px color-mix(in srgb, var(--primary) 12%, transparent);
	}

	table-of-contents#toc .toc-toggle.expanded {
		transform: rotate(180deg);
	}

	table-of-contents#toc .toc-toggle-icon {
		font-size: 0.92rem;
		line-height: 1;
		transform: translateY(-1px);
		opacity: 0.9;
	}

	:global(.dark) table-of-contents#toc .toc-toggle {
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.08),
			0 12px 24px rgba(0, 0, 0, 0.18);
	}
</style>
