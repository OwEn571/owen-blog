---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../../config";
import { url } from "../../../utils/url-utils";
import Image from "../../atoms/Image/Image.astro";
import TypewriterText from "../../atoms/typewriter-text/TypewriterText.astro";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
---

<div class="card-base p-3">
    <a aria-label="Go to Study Page" href={url('/study/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa7-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <Image src={profileConfig.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0 "></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{profileConfig.name}</div>
        <div class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"></div>
        
        <div class="text-center text-neutral-400 mb-2.5 transition">
            {profileConfig.typewriter?.enable ? (
                <TypewriterText 
                    text={profileConfig.bio || ""}
                    speed={profileConfig.typewriter.speed}
                    class="inline-block"
                />
            ) : (
                profileConfig.bio
            )}
        </div>
        
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {profileConfig.links.length > 1 && profileConfig.links.map(item =>
                <a rel="me" aria-label={item.name} href={item.url} target="_blank" 
                   class="btn-regular rounded-lg h-10 w-10 active:scale-90">
                    <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                </a>
            )}
            {profileConfig.links.length == 1 && 
                <a rel="me" aria-label={profileConfig.links[0].name} href={profileConfig.links[0].url} target="_blank"
                   class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
                    <Icon name={profileConfig.links[0].icon} class="text-[1.5rem]"></Icon>
                    {profileConfig.links[0].name}
                </a>
            }
        </div>
        
        <div class="umami-stats-container hidden">
            <hr class="my-2 border-t border-dashed border-black/10 dark:border-white/10 transition-colors duration-150" />
            <div class="profile-stats-pill">
                <Icon name="fa7-solid:eye" class="profile-stats-pill__icon" />
                <span class="site-stats-display">{i18n(I18nKey.profileStatsLoading)}</span>
            </div>
        </div>
    </div>
</div>

<script is:inline define:vars={{
    profileStatsPageViews: i18n(I18nKey.profileStatsPageViews),
    profileStatsVisits: i18n(I18nKey.profileStatsVisits),
    profileStatsUnavailable: i18n(I18nKey.profileStatsUnavailable)
}}>
    function generateStatsText(pageViews, visits) {
        return `${profileStatsPageViews} ${pageViews} · ${profileStatsVisits} ${visits}`;
    }

    async function fetchSiteStats(retries = 0) {
        const container = document.querySelector('.umami-stats-container');
        if (!(container instanceof HTMLElement)) {
            return;
        }

        try {
            let stats = null;

            if (window.oddmisc?.getSiteStats) {
                stats = await window.oddmisc.getSiteStats();
            } else if (window.__owenStatsClient?.getSiteStats) {
                stats = await window.__owenStatsClient.getSiteStats(window.location.pathname);
            } else if (retries < 8) {
                setTimeout(() => fetchSiteStats(retries + 1), 400);
                return;
            } else {
                container.classList.add('hidden');
                return;
            }

            const pageViews = stats.pageviews || 0;
            const visits = stats.visitors || stats.visits || 0;

            // 数据为 0 时隐藏
            if (pageViews === 0 && visits === 0) {
                container.classList.add('hidden');
                return;
            }

            container.classList.remove('hidden');
            document.querySelectorAll('.site-stats-display').forEach(el => {
                el.textContent = generateStatsText(pageViews, visits);
            });
        } catch (error) {
            console.error('Error fetching site stats:', error);
            container.classList.add('hidden');
        }
    }

    const scheduleSiteStatsFetch = () => fetchSiteStats();

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scheduleSiteStatsFetch);
    } else {
        scheduleSiteStatsFetch();
    }

    window.addEventListener('pageshow', scheduleSiteStatsFetch);
    document.addEventListener('owen-blog:page:loaded', scheduleSiteStatsFetch);
</script>

<style>
	.profile-stats-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.42rem;
		margin: 0.6rem auto 0;
		padding: 0.42rem 0.78rem;
		border-radius: 999px;
		border: 1px solid rgba(118, 156, 255, 0.12);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.6), rgba(247, 250, 255, 0.42)),
			radial-gradient(circle at top right, rgba(118, 156, 255, 0.08), transparent 10rem);
		box-shadow:
			0 12px 28px rgba(15, 23, 42, 0.06),
			inset 0 1px 0 rgba(255, 255, 255, 0.66);
		backdrop-filter: blur(18px) saturate(1.04);
		-webkit-backdrop-filter: blur(18px) saturate(1.04);
		color: rgba(15, 23, 42, 0.7);
		font-size: 0.8rem;
		line-height: 1.3;
	}

	.profile-stats-pill__icon {
		color: rgb(var(--primary));
		font-size: 0.82rem;
	}

	:root:not(.dark) .profile-stats-pill {
		border-color: rgba(255, 191, 214, 0.18);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(255, 243, 248, 0.52)),
			radial-gradient(circle at top right, rgba(255, 188, 210, 0.12), transparent 10rem);
		box-shadow:
			0 14px 30px rgba(176, 102, 136, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.78);
		color: rgba(98, 64, 79, 0.76);
	}

	:root:not(.dark) .profile-stats-pill__icon {
		color: rgba(181, 87, 127, 0.9);
	}

	:root.dark .profile-stats-pill {
		border-color: rgba(255, 255, 255, 0.08);
		background:
			linear-gradient(180deg, rgba(10, 14, 22, 0.56), rgba(5, 8, 14, 0.38)),
			radial-gradient(circle at top right, rgba(118, 156, 255, 0.12), transparent 10rem);
		box-shadow:
			0 16px 34px rgba(0, 0, 0, 0.2),
			inset 0 1px 0 rgba(255, 255, 255, 0.08);
		color: rgba(220, 230, 248, 0.72);
	}
</style>
