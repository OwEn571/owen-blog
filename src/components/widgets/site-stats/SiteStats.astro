---
import { Icon } from "astro-icon/components";

import { siteConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "../../../utils/content-utils";
import WidgetLayout from "../common/WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

// 从配置中获取站点开始日期
const siteStartDate = siteConfig.siteStartDate || "2025-01-01";

// 获取所有文章
const posts = await getSortedPosts();
const categories = await getCategoryList();
const tags = await getTagList();

// 计算总字数
let totalWords = 0;
for (const post of posts) {
	if (post.body) {
		let text = post.body;

		// 移除代码块
		text = text.replace(/```[\s\S]*?```/g, "");
		// 移除 ` 包裹的行内代码
		text = text.replace(/`[^`]+`/g, "");

		// 使用与 remark-content.mjs 完全一致的 CJK 正则
		const cjkPattern =
			/[\u4e00-\u9fa5\u3040-\u309f\u30a0-\u30ff\uac00-\ud7af\u3000-\u303f\uff00-\uffef]/g;

		const cjkMatches = text.match(cjkPattern);
		const cjkCount = cjkMatches ? cjkMatches.length : 0;

		// 计算非 CJK 单词数
		const nonCjkText = text.replace(cjkPattern, " ");

		// 按空白字符分割，计算单词数量
		const nonCjkWords = nonCjkText
			.split(/\s+/)
			.filter((word) => word.trim().length > 0);

		totalWords += cjkCount + nonCjkWords.length;
	}
}

// 格式化数字（添加千位分隔符）
function formatNumber(num: number): string {
	return num.toLocaleString();
}

// 获取最新文章日期（忽略置顶状态，只按发布日期排序）
const latestPost = posts.reduce((latest, post) => {
	if (!latest) {return post;}
	return post.data.published > latest.data.published ? post : latest;
}, posts[0]);

const lastPostDate = latestPost
	? latestPost.data.published.toISOString()
	: null;

const stats = [
	{
		icon: "material-symbols:article-outline",
		label: i18n(I18nKey.siteStatsPostCount),
		value: posts.length,
	},
	{
		icon: "material-symbols:folder-outline",
		label: i18n(I18nKey.siteStatsCategoryCount),
		value: categories.length,
	},
	{
		icon: "material-symbols:label-outline",
		label: i18n(I18nKey.siteStatsTagCount),
		value: tags.length,
	},
	{
		icon: "material-symbols:text-ad-outline-rounded",
		label: i18n(I18nKey.siteStatsTotalWords),
		value: totalWords,
		formatted: true,
	},
	{
		icon: "material-symbols:calendar-clock-outline",
		label: i18n(I18nKey.siteStatsRunningDays),
		value: 0, // 将由客户端更新
		suffix: i18n(I18nKey.siteStatsDays).replace("{days}", ""),
		dynamic: true,
		id: "running-days",
	},
	{
		icon: "material-symbols:ecg-heart-outline",
		label: i18n(I18nKey.siteStatsLastUpdate),
		value: 0, // 将由客户端更新
		suffix: i18n(I18nKey.siteStatsDaysAgo).replace("{days}", ""),
		dynamic: true,
		id: "last-update",
	},
];
---

<WidgetLayout
	name={i18n(I18nKey.siteStats)}
	id="site-stats"
	class={className}
	style={style}
>
	<div class="flex flex-col gap-1">
		{
			stats.map((stat) => (
				<div class="site-stats-row">
					<div class="site-stats-row__copy">
						<div class="site-stats-row__icon">
							<Icon name={stat.icon} />
						</div>
						<span class="site-stats-row__label">
							{stat.label}
						</span>
					</div>
					<div class="site-stats-row__value-group">
						<span
							class="site-stats-row__value"
							data-stat-id={stat.id}
						>
							{stat.formatted
								? formatNumber(stat.value)
								: stat.value}
						</span>
						{stat.suffix && (
							<span class="site-stats-row__suffix">
								{stat.suffix}
							</span>
						)}
					</div>
				</div>
			))
		}
	</div>
</WidgetLayout>

<script is:inline define:vars={{ siteStartDate, lastPostDate }}>
	function updateDynamicStats() {
		const today = new Date();

		// 更新运行天数
		const startDate = new Date(siteStartDate);
		const diffTime = Math.abs(today.getTime() - startDate.getTime());
		const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

		const runningDaysElements = document.querySelectorAll(
			'[data-stat-id="running-days"]',
		);
		if (runningDaysElements.length > 0) {
			runningDaysElements.forEach(element => {
				element.textContent = diffDays.toString();
			});
		}

		// 更新最后活动时间
		if (lastPostDate) {
			const lastPost = new Date(lastPostDate);
			const timeSinceLastPost = Math.abs(
				today.getTime() - lastPost.getTime(),
			);
			const daysSinceLastUpdate = Math.floor(
				timeSinceLastPost / (1000 * 60 * 60 * 24),
			);

			const lastUpdateElements = document.querySelectorAll(
				'[data-stat-id="last-update"]',
			);
			if (lastUpdateElements.length > 0) {
				lastUpdateElements.forEach(element => {
					element.textContent = daysSinceLastUpdate.toString();
				})
			}
		}
	}

	// 页面加载时更新
	updateDynamicStats();

	// 每小时更新一次（可选，因为天数变化较慢）
	setInterval(updateDynamicStats, 60 * 60 * 1000);
</script>

<style>
	.site-stats-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
		padding: 0.72rem 0.78rem;
		border-radius: 1rem;
		border: 1px solid rgba(118, 156, 255, 0.1);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.38), rgba(247, 250, 255, 0.16)),
			radial-gradient(circle at top right, rgba(118, 156, 255, 0.08), transparent 12rem);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.58),
			0 14px 34px rgba(15, 23, 42, 0.04);
		backdrop-filter: blur(18px) saturate(1.02);
		-webkit-backdrop-filter: blur(18px) saturate(1.02);
	}

	.site-stats-row__copy {
		display: flex;
		align-items: center;
		gap: 0.72rem;
		flex: 1;
		min-width: 0;
	}

	.site-stats-row__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.1rem;
		height: 2.1rem;
		border-radius: 0.9rem;
		background: rgba(118, 156, 255, 0.1);
		color: rgb(var(--primary));
		font-size: 1.05rem;
		box-shadow:
			0 0 0 1px rgba(118, 156, 255, 0.12),
			0 0 18px rgba(118, 156, 255, 0.08);
		flex-shrink: 0;
	}

	.site-stats-row__label {
		color: rgba(15, 23, 42, 0.72);
		font-weight: 560;
		font-size: 0.9rem;
		line-height: 1.35;
	}

	.site-stats-row__value-group {
		display: inline-flex;
		align-items: baseline;
		gap: 0.22rem;
		flex-shrink: 0;
	}

	.site-stats-row__value {
		color: rgba(15, 23, 42, 0.9);
		font-size: 1rem;
		font-weight: 720;
		letter-spacing: -0.02em;
	}

	.site-stats-row__suffix {
		color: rgba(15, 23, 42, 0.42);
		font-size: 0.78rem;
	}

	:root:not(.dark) .site-stats-row {
		border-color: rgba(255, 191, 214, 0.18);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(255, 243, 248, 0.52)),
			radial-gradient(circle at top right, rgba(255, 188, 210, 0.12), transparent 12rem);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.74),
			0 18px 40px rgba(176, 102, 136, 0.07);
	}

	:root:not(.dark) .site-stats-row__icon {
		background: rgba(255, 215, 229, 0.52);
		color: rgba(181, 87, 127, 0.92);
		box-shadow:
			0 0 0 1px rgba(255, 191, 214, 0.18),
			0 0 18px rgba(255, 188, 210, 0.12);
	}

	:root:not(.dark) .site-stats-row__label {
		color: rgba(98, 64, 79, 0.76);
	}

	:root:not(.dark) .site-stats-row__value {
		color: rgba(78, 46, 61, 0.94);
	}

	:root:not(.dark) .site-stats-row__suffix {
		color: rgba(120, 82, 101, 0.54);
	}

	:root.dark .site-stats-row {
		border-color: rgba(255, 255, 255, 0.06);
		background:
			linear-gradient(180deg, rgba(12, 16, 25, 0.56), rgba(7, 10, 16, 0.34)),
			radial-gradient(circle at top right, rgba(118, 156, 255, 0.12), transparent 12rem);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.08),
			0 18px 44px rgba(0, 0, 0, 0.16);
	}

	:root.dark .site-stats-row__label {
		color: rgba(222, 232, 250, 0.72);
	}

	:root.dark .site-stats-row__value {
		color: rgba(248, 250, 255, 0.94);
	}

	:root.dark .site-stats-row__suffix {
		color: rgba(222, 232, 250, 0.42);
	}
</style>
