---
interface Props {
	path: string;
}

const commentsPath = Astro.props.path;
---

<section class="owen-comments" data-owen-comments data-path={commentsPath}>
	<div class="owen-comments__header">
		<div class="owen-comments__copy">
			<p class="owen-comments__eyebrow">留言区</p>
			<h3 class="owen-comments__title">留言</h3>
			<p class="owen-comments__lead">
				欢迎纠错、补充、交流。昵称和评论内容必填；如果你愿意，也可以留下联系方式，仅站主可见。
			</p>
		</div>
		<div class="owen-comments__count">
			<strong data-comments-count>0</strong>
			<span>条</span>
		</div>
	</div>

	<form class="owen-comments__form" data-comments-form>
		<div class="owen-comments__grid">
			<label class="owen-comments__field">
				<span>昵称</span>
				<input
					type="text"
					name="author"
					maxlength="32"
					required
					placeholder="怎么称呼你？"
				/>
			</label>

			<label class="owen-comments__field">
				<span>联系方式</span>
				<input
					type="text"
					name="contact"
					maxlength="120"
					placeholder="邮箱 / 微信 / GitHub / 网站（可选，仅站主可见）"
				/>
			</label>

			<label class="owen-comments__field owen-comments__field--full">
				<span>评论内容</span>
				<textarea
					name="content"
					rows="5"
					maxlength="2000"
					required
					placeholder="可以写想法、纠错、补充或者一句简单反馈。"
				></textarea>
			</label>
		</div>

		<input
			class="owen-comments__honeypot"
			type="text"
			name="company"
			tabindex="-1"
			autocomplete="off"
			aria-hidden="true"
		/>

		<div class="owen-comments__actions">
			<div class="owen-comments__status-wrap">
				<p class="owen-comments__status" data-comments-status>正在加载评论...</p>
				<span class="owen-comments__length" data-comments-length>0 / 2000</span>
			</div>
			<button type="submit" class="owen-comments__submit" data-comments-submit>
				发布留言
			</button>
		</div>
	</form>

	<div class="owen-comments__list" data-comments-list></div>
</section>

<script is:inline define:vars={{ commentsApiUrl: "/api/comments.json" }}>
	(() => {
		function normalizePath(input) {
			let value = String(input || "").trim() || "/";
			value = value.split("?")[0].split("#")[0] || "/";
			if (!value.startsWith("/")) {
				value = `/${value}`;
			}
			value = value.replace(/\/{2,}/g, "/");
			if (!/\.[a-z0-9]+$/i.test(value) && !value.endsWith("/")) {
				value = `${value}/`;
			}
			return value || "/";
		}

		function formatDate(value) {
			try {
				return new Intl.DateTimeFormat("zh-CN", {
					dateStyle: "medium",
					timeStyle: "short",
				}).format(new Date(value));
			} catch {
				return value;
			}
		}

		function setStatus(root, message) {
			const status = root.querySelector("[data-comments-status]");
			if (status instanceof HTMLElement) {
				status.textContent = message;
			}
		}

		function updateDraftLength(root) {
			const textarea = root.querySelector('textarea[name="content"]');
			const counter = root.querySelector("[data-comments-length]");
			if (!(textarea instanceof HTMLTextAreaElement) || !(counter instanceof HTMLElement)) {
				return;
			}

			counter.textContent = `${textarea.value.length} / ${textarea.maxLength || 2000}`;
		}

		function updateCount(root, count) {
			const countEl = root.querySelector("[data-comments-count]");
			if (countEl instanceof HTMLElement) {
				countEl.textContent = String(count);
			}
		}

		function getAvatarLabel(name) {
			const normalized = String(name || "").trim().replace(/\s+/g, "");
			const [first = "匿"] = Array.from(normalized || "匿");
			return first.toUpperCase();
		}

		function createCommentCard(comment) {
			const article = document.createElement("article");
			article.className = "owen-comments__item";

			const avatar = document.createElement("div");
			avatar.className = "owen-comments__avatar";
			avatar.textContent = getAvatarLabel(comment.author);

			const body = document.createElement("div");
			body.className = "owen-comments__item-body";

			const head = document.createElement("div");
			head.className = "owen-comments__item-head";

			const authorGroup = document.createElement("div");
			authorGroup.className = "owen-comments__item-author-group";

			const author = document.createElement("strong");
			author.className = "owen-comments__item-author";
			author.textContent = comment.author || "匿名访客";

			const meta = document.createElement("div");
			meta.className = "owen-comments__item-meta";

			const time = document.createElement("time");
			time.className = "owen-comments__item-time";
			time.dateTime = comment.createdAt;
			time.textContent = formatDate(comment.createdAt);
			meta.append(time);

			authorGroup.append(author, meta);

			const content = document.createElement("p");
			content.className = "owen-comments__item-content";
			content.textContent = comment.content;

			head.append(authorGroup);
			body.append(head, content);
			article.append(avatar, body);
			return article;
		}

		function renderComments(root, items) {
			const list = root.querySelector("[data-comments-list]");
			if (!(list instanceof HTMLElement)) {
				return;
			}

			updateCount(root, items.length);
			list.innerHTML = "";

			if (!items.length) {
				const empty = document.createElement("div");
				empty.className = "owen-comments__empty";
				empty.innerHTML =
					"<strong>还没有留言</strong><span>这篇文章的评论区已经打开了，欢迎留下第一条反馈。</span>";
				list.append(empty);
				return;
			}

			items.forEach((comment) => {
				list.append(createCommentCard(comment));
			});
		}

		async function requestComments(path) {
			const response = await fetch(`${commentsApiUrl}?path=${encodeURIComponent(path)}`);
			const payload = await response.json().catch(() => ({ items: [] }));
			if (!response.ok) {
				throw new Error(payload.error || "评论加载失败。");
			}
			return payload;
		}

		async function submitComment(payload) {
			const response = await fetch(commentsApiUrl, {
				method: "POST",
				headers: {
					"Content-Type": "application/json",
				},
				body: JSON.stringify(payload),
			});
			const data = await response.json().catch(() => ({}));
			if (!response.ok) {
				throw new Error(data.error || "评论发送失败。");
			}
			return data;
		}

		async function initCommentRoot(root) {
			if (!(root instanceof HTMLElement) || root.dataset.commentsReady === "true") {
				return;
			}

			root.dataset.commentsReady = "true";
			const form = root.querySelector("[data-comments-form]");
			const submitButton = root.querySelector("[data-comments-submit]");
			const textarea = root.querySelector('textarea[name="content"]');
			const path = normalizePath(root.dataset.path || window.location.pathname);

			if (!(form instanceof HTMLFormElement) || !(submitButton instanceof HTMLButtonElement)) {
				return;
			}

			if (textarea instanceof HTMLTextAreaElement) {
				updateDraftLength(root);
				textarea.addEventListener("input", () => updateDraftLength(root));
			}

			const loadComments = async () => {
				setStatus(root, "正在加载评论...");
				try {
					const data = await requestComments(path);
					renderComments(root, Array.isArray(data.items) ? data.items : []);
					setStatus(
						root,
						data.items?.length ? "欢迎继续留言交流。" : "评论区已经准备好。",
					);
				} catch (error) {
					setStatus(root, error instanceof Error ? error.message : "评论加载失败。");
				}
			};

			form.addEventListener("submit", async (event) => {
				event.preventDefault();
				const formData = new FormData(form);
				const author = String(formData.get("author") || "").trim();
				const contact = String(formData.get("contact") || "").trim();
				const content = String(formData.get("content") || "").trim();
				const company = String(formData.get("company") || "").trim();

				if (!author || !content) {
					setStatus(root, "请先填写昵称和评论内容。");
					return;
				}

				submitButton.disabled = true;
				setStatus(root, "正在发布留言...");

				try {
					const data = await submitComment({
						path,
						author,
						contact,
						content,
						company,
					});
					renderComments(root, Array.isArray(data.items) ? data.items : []);
					form.reset();
					updateDraftLength(root);
					setStatus(root, "留言已发布。");
				} catch (error) {
					setStatus(root, error instanceof Error ? error.message : "评论发送失败。");
				} finally {
					submitButton.disabled = false;
				}
			});

			void loadComments();
		}

		function mountComments() {
			document.querySelectorAll("[data-owen-comments]").forEach((root) => {
				void initCommentRoot(root);
			});
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", mountComments, { once: true });
		} else {
			mountComments();
		}

		window.addEventListener("pageshow", mountComments);
		document.addEventListener("owen-blog:page:loaded", mountComments);
	})();
</script>

<style>
	.owen-comments {
		display: grid;
		gap: 1rem;
	}

	.owen-comments__header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.owen-comments__copy {
		display: grid;
		gap: 0.4rem;
	}

	.owen-comments__eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(190, 92, 132, 0.74);
	}

	.owen-comments__title {
		margin: 0;
		font-family: var(--owen-font-display);
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--text-normal);
	}

	.owen-comments__lead {
		margin: 0;
		max-width: 38rem;
		line-height: 1.75;
		color: var(--text-secondary);
	}

	.owen-comments__count {
		display: inline-grid;
		place-items: center;
		min-width: 3.4rem;
		padding: 0.55rem 0.8rem;
		border-radius: 1rem;
		border: 1px solid rgba(118, 156, 255, 0.12);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(247, 250, 255, 0.52)),
			radial-gradient(circle at top right, rgba(118, 156, 255, 0.1), transparent 10rem);
		box-shadow:
			0 14px 32px rgba(15, 23, 42, 0.05),
			inset 0 1px 0 rgba(255, 255, 255, 0.82);
	}

	.owen-comments__count strong {
		font-size: 1rem;
		color: var(--text-normal);
	}

	.owen-comments__count span {
		font-size: 0.72rem;
		color: var(--text-secondary);
	}

	.owen-comments__form {
		display: grid;
		gap: 1rem;
		padding: 1rem 1.05rem;
		border-radius: 1.3rem;
		border: 1px solid rgba(118, 156, 255, 0.12);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(247, 250, 255, 0.44)),
			radial-gradient(circle at top right, rgba(118, 156, 255, 0.1), transparent 12rem);
		box-shadow:
			0 18px 42px rgba(15, 23, 42, 0.05),
			inset 0 1px 0 rgba(255, 255, 255, 0.8);
	}

	.owen-comments__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.owen-comments__field {
		display: grid;
		gap: 0.4rem;
		font-size: 0.84rem;
		color: var(--text-secondary);
	}

	.owen-comments__field--full {
		grid-column: 1 / -1;
	}

	.owen-comments__field input,
	.owen-comments__field textarea {
		width: 100%;
		border-radius: 1rem;
		border: 1px solid rgba(118, 156, 255, 0.12);
		background: rgba(255, 255, 255, 0.74);
		padding: 0.86rem 0.95rem;
		color: var(--text-normal);
		outline: none;
		transition:
			border-color 0.18s ease,
			box-shadow 0.18s ease,
			transform 0.18s ease;
	}

	.owen-comments__field input:focus,
	.owen-comments__field textarea:focus {
		border-color: rgba(118, 156, 255, 0.28);
		box-shadow: 0 0 0 4px rgba(118, 156, 255, 0.12);
		transform: translateY(-1px);
	}

	.owen-comments__honeypot {
		position: absolute;
		left: -9999px;
		opacity: 0;
		pointer-events: none;
	}

	.owen-comments__actions {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.owen-comments__status-wrap {
		display: grid;
		gap: 0.24rem;
	}

	.owen-comments__status {
		margin: 0;
		font-size: 0.84rem;
		color: var(--text-secondary);
	}

	.owen-comments__length {
		font-size: 0.74rem;
		color: rgba(109, 122, 145, 0.8);
	}

	.owen-comments__submit {
		border: none;
		border-radius: 1rem;
		padding: 0.82rem 1.18rem;
		font-weight: 700;
		color: white;
		background: linear-gradient(135deg, rgba(104, 126, 255, 0.96), rgba(181, 87, 127, 0.92));
		box-shadow: 0 18px 36px rgba(104, 126, 255, 0.18);
		cursor: pointer;
		transition:
			transform 0.18s ease,
			opacity 0.18s ease,
			box-shadow 0.18s ease;
	}

	.owen-comments__submit:hover:not(:disabled) {
		transform: translateY(-1px);
		box-shadow: 0 22px 42px rgba(104, 126, 255, 0.24);
	}

	.owen-comments__submit:disabled {
		opacity: 0.62;
		cursor: progress;
	}

	.owen-comments__list {
		display: grid;
		gap: 0.9rem;
	}

	.owen-comments__empty,
	.owen-comments__item {
		border-radius: 1.28rem;
		border: 1px solid rgba(118, 156, 255, 0.12);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.68), rgba(247, 250, 255, 0.42)),
			radial-gradient(circle at top right, rgba(118, 156, 255, 0.08), transparent 12rem);
		box-shadow:
			0 16px 36px rgba(15, 23, 42, 0.05),
			inset 0 1px 0 rgba(255, 255, 255, 0.78);
	}

	.owen-comments__empty {
		display: grid;
		gap: 0.35rem;
		padding: 1.1rem;
		text-align: center;
		color: var(--text-secondary);
	}

	.owen-comments__empty strong {
		color: var(--text-normal);
	}

	.owen-comments__item {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 0.9rem;
		padding: 1rem 1.05rem;
	}

	.owen-comments__avatar {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.7rem;
		height: 2.7rem;
		border-radius: 999px;
		background:
			linear-gradient(135deg, rgba(255, 198, 218, 0.96), rgba(120, 165, 255, 0.88));
		color: white;
		font-size: 0.94rem;
		font-weight: 800;
		box-shadow: 0 12px 28px rgba(118, 156, 255, 0.16);
	}

	.owen-comments__item-body {
		display: grid;
		gap: 0.7rem;
		min-width: 0;
	}

	.owen-comments__item-head {
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: 1rem;
	}

	.owen-comments__item-author-group {
		display: grid;
		gap: 0.34rem;
		min-width: 0;
	}

	.owen-comments__item-author {
		font-size: 0.95rem;
		color: var(--text-normal);
	}

	.owen-comments__item-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.45rem 0.55rem;
	}

	.owen-comments__item-time,
	.owen-comments__item-contact {
		display: inline-flex;
		align-items: center;
		min-height: 1.7rem;
		padding: 0 0.68rem;
		border-radius: 999px;
		font-size: 0.72rem;
	}

	.owen-comments__item-time {
		background: rgba(118, 156, 255, 0.08);
		color: rgba(87, 101, 125, 0.88);
	}

	.owen-comments__item-contact {
		border: 1px solid rgba(255, 191, 214, 0.22);
		background: rgba(255, 241, 247, 0.76);
		color: rgba(162, 77, 116, 0.88);
		text-decoration: none;
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease;
	}

	.owen-comments__item-contact:hover {
		transform: translateY(-1px);
		border-color: rgba(255, 191, 214, 0.34);
		box-shadow: 0 10px 24px rgba(181, 87, 127, 0.1);
	}

	.owen-comments__item-content {
		margin: 0;
		padding: 0.95rem 1rem;
		border-radius: 1rem;
		border: 1px solid rgba(118, 156, 255, 0.1);
		background: rgba(255, 255, 255, 0.76);
		line-height: 1.84;
		white-space: pre-wrap;
		color: var(--text-normal);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
	}

	:global(.dark) .owen-comments__eyebrow {
		color: rgba(255, 205, 224, 0.76);
	}

	:global(.dark) .owen-comments__count,
	:global(.dark) .owen-comments__form,
	:global(.dark) .owen-comments__empty,
	:global(.dark) .owen-comments__item {
		border-color: rgba(255, 255, 255, 0.08);
		background:
			linear-gradient(180deg, rgba(12, 16, 24, 0.72), rgba(6, 9, 16, 0.48)),
			radial-gradient(circle at top right, rgba(118, 156, 255, 0.12), transparent 12rem);
		box-shadow:
			0 20px 42px rgba(0, 0, 0, 0.2),
			inset 0 1px 0 rgba(255, 255, 255, 0.05);
	}

	:global(.dark) .owen-comments__field input,
	:global(.dark) .owen-comments__field textarea,
	:global(.dark) .owen-comments__item-content {
		border-color: rgba(255, 255, 255, 0.08);
		background: rgba(255, 255, 255, 0.05);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
	}

	:global(.dark) .owen-comments__item-time {
		background: rgba(255, 255, 255, 0.06);
		color: rgba(220, 230, 248, 0.7);
	}

	:global(.dark) .owen-comments__item-contact {
		border-color: rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.05);
		color: rgba(255, 216, 232, 0.84);
	}

	:global(.dark) .owen-comments__length {
		color: rgba(221, 229, 244, 0.56);
	}

	@media (max-width: 720px) {
		.owen-comments__header,
		.owen-comments__actions,
		.owen-comments__item-head {
			flex-direction: column;
			align-items: stretch;
		}

		.owen-comments__item {
			grid-template-columns: 1fr;
		}

		.owen-comments__grid {
			grid-template-columns: 1fr;
		}

		.owen-comments__submit {
			width: 100%;
		}
	}
</style>
