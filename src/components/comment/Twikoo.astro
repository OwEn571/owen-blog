---
import { commentConfig } from "@/config";
import "@/styles/twikoo.css";

interface Props {
	path: string;
}

const config = {
	...commentConfig.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};
---

<div id="tcomment"></div>
<script is:inline src="/scroll-protection.js"></script>
<script is:inline src="/assets/js/twikoo.all.min.js"></script>
<script is:inline define:vars={{ config }}>
  let retryTimer = 0;

  function getCurrentPath() {
    const pathname = window.location.pathname;
    return pathname.endsWith("/") && pathname.length > 1 ? pathname.slice(0, -1) : pathname;
  }

  function createTwikooConfig() {
    return {
      ...config,
      path: getCurrentPath(),
      el: "#tcomment",
    };
  }

  function initTwikoo() {
    const commentEl = document.getElementById("tcomment");
    if (!commentEl) {
      return;
    }

    if (typeof twikoo === "undefined") {
      window.clearTimeout(retryTimer);
      retryTimer = window.setTimeout(initTwikoo, 450);
      return;
    }

    commentEl.innerHTML = "";
    const dynamicConfig = createTwikooConfig();

    twikoo
      .init(dynamicConfig)
      .catch((error) => {
        console.error("[Twikoo] 初始化失败:", error);
      });
  }

  const scheduleInit = () => {
    window.clearTimeout(retryTimer);
    retryTimer = window.setTimeout(initTwikoo, 120);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleInit, { once: true });
  } else {
    scheduleInit();
  }

  window.addEventListener("pageshow", scheduleInit);
  document.addEventListener("owen-blog:page:loaded", scheduleInit);
</script>
