---
import SplashSelector from "@components/features/home/SplashSelector.astro";
import SplashLayout from "@layouts/SplashLayout.astro";
import type { GetStaticPaths } from "astro";

import { PAGE_SIZE } from "../constants/constants";
import { getStudyPosts } from "../utils/study-utils";
import { initPostIdMap } from "../utils/permalink-utils";

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getStudyPosts();
	// 初始化文章 ID 映射（用于 permalink 功能）
	initPostIdMap(allBlogPosts);
	return paginate(allBlogPosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;
// https://github.com/withastro/astro/issues/6507#issuecomment-1489916992

const isHomeLaunchpad = Astro.url.pathname === "/";

if (!isHomeLaunchpad) {
	return Astro.redirect(
		Astro.props.page.currentPage > 1
			? `/study/${Astro.props.page.currentPage}/`
			: "/study/",
	);
}
---

<SplashLayout
	title="入口"
	description="四个内容模块的开屏入口"
>
	<SplashSelector />
</SplashLayout>
